# ============================================
# Super Warrior Z - Server Configuration
# 100% based on client code analysis. NO assumptions.
#
# Every variable here traces to concrete evidence:
#   - Client source: main.min.js (line numbers documented)
#   - Existing data: sdk-server/data/users.json (15 users)
#   - Server code: shared/config.js reads these variables
# ============================================

# ============================================
# MariaDB Configuration
# Used by: database/connection.js init()
# Required: MariaDB or MySQL must be running
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=admin
DB_DATABASE=super_warrior_z
DB_CONNECTION_LIMIT=10

# ============================================
# Server Ports
# Source: client TSSocketClient init (line 76751)
#   login-server   → port 8000 (verifyEnable=false, NO TEA)
#   main-server    → port 8001 (verifyEnable=true,  TEA)
#   chat-server    → port 8002 (verifyEnable=true,  TEA)
#   dungeon-server → port 8003 (verifyEnable=true,  TEA)
# ============================================
LOGIN_PORT=8000
MAIN_PORT=8001
CHAT_PORT=8002
DUNGEON_PORT=8003

# ============================================
# Server Bind Host
# The address each server LISTENS on.
# Default: 0.0.0.0 (all interfaces — accessible from LAN)
# Set per-server to override SERVER_HOST fallback.
# ============================================
SERVER_HOST=0.0.0.0
# LOGIN_HOST=0.0.0.0
# MAIN_HOST=0.0.0.0
# CHAT_HOST=0.0.0.0
# DUNGEON_HOST=0.0.0.0

# ============================================
# Public Host (Client-Facing URLs)
# The hostname/IP that the CLIENT BROWSER uses to connect.
# This is sent to the client in GetServerList response.
# Used by: shared/config.js → getServerList(), buildServerUrl()
#
# Default: 127.0.0.1 (localhost — for local/private server)
# LAN play: set to your server's LAN IP (e.g., 192.168.1.100)
# ============================================
SERVER_PUBLIC_HOST=127.0.0.1

# ============================================
# TEA Encryption Key
# Source: client main.min.js line 52008:
#   var o = (new TEA).encrypt(n, "verification");
#
# MUST be "verification" — client hardcodes this value.
# If changed, client source code must also be modified.
# Used by: main-server, chat-server, dungeon-server (TEA verify handshake)
# ============================================
TEA_KEY=verification

# ============================================
# SDK Configuration
# Source: ALL 15 users in sdk-server/data/users.json:
#   "sdk": "ppgame", "appId": "288"
# Source: client sdk.js → APP_ID = '288'
#
# Used by: sdk-server/config/constants.js
# Note: shared/config.js also reads these as fallback
# ============================================
SDK_CHANNEL=ppgame
APP_ID=288
# SDK_PORT=9999

# ============================================
# Node.js Process Timezone
# ============================================
# Controls how Node.js interprets Date operations (setHours, getDay, getHours, etc.)
# Used by: dailyReset.js (getTimeUntilNextReset, needsReset)
#         defaultData.js (_refreshTime calculation)
#
# This is DIFFERENT from SERVER_UTC_OFFSET_MS (server0Time):
#   TZ → affects SERVER-SIDE Date operations (daily reset, timestamp calculations)
#   SERVER_UTC_OFFSET_MS → sent to CLIENT in every response as server0Time field
#
# Both MUST match the same timezone. If you change one, change the other.
#
# Example mappings:
#   UTC+7 (Jakarta)  → TZ=Asia/Jakarta,    SERVER_UTC_OFFSET_MS=-25200000
#   UTC+8 (Singapore) → TZ=Asia/Singapore,  SERVER_UTC_OFFSET_MS=-28800000
#   UTC+9 (Tokyo)     → TZ=Asia/Tokyo,      SERVER_UTC_OFFSET_MS=-32400000
# ============================================
TZ=Asia/Jakarta

# ============================================
# Server UTC Offset (server0Time)
# ============================================
#
# CLIENT FORMULA (main.min.js line 116952-116954):
#   e._offTime = 60 * new Date().getTimezoneOffset() * 1000 - n;
#   e.getServerLocalDate() = new Date(e._ts + e._offTime);
#
# where n = server0Time from response, e._ts = serverTime (Date.now()).
#
# PROOF: For getServerLocalDate() to return correct server local time,
#   server0Time must equal -(server's UTC offset in ms).
#
# For UTC+7 client: getTimezoneOffset() = -420
#   _offTime = 60*(-420)*1000 - server0Time = -25200000 - server0Time
#   getServerLocalDate() = new Date(serverTime + (-25200000 - server0Time))
#   For correct server time (UTC+7): need _offTime = 0
#   => -25200000 - server0Time = 0
#   => server0Time = -25200000
#
# With WRONG value +25200000:
#   _offTime = -50400000 → getServerLocalDate() 14 hours behind UTC!
#   → Daily reset (6 AM) at wrong time, day-of-week wrong, ALL time features broken.
#
# CORRECT FORMULA: server0Time = -(server_tz_offset_ms)
#   UTC+7 (Jakarta)  = -25200000
#   UTC+8 (Singapore) = -28800000
#   UTC+9 (Tokyo)     = -32400000
#
# Used by: responseHelper.js → success(), error(), push()
# ============================================
SERVER_UTC_OFFSET_MS=-25200000
