ҺгІ©бӨҠзЎҮбӯ„д—ҮвҜ«бҙ—вҢҠзҰ·гЁ№д—‘б…ҚеөҫвјҖвҺ¶а үвЈҹбҙҚвҗ жҖ°д¶¶бҜҠзҰ”б•Җаҙ»г¶«жҗ е„ҮеөҘ6дҲёз§ҰжҚҫгӮүг”°зҘ…аөіаәўдҸӨзјҪд·®вҳҫбҸҗзӨ¶дұҖзё°бҠ”б¬Ңбү—гҠҙвұҖеӨ°бүӢг®ҚвҚҮв¶Ҹв·»гҙ·бӢ»гЈҒжөібһҚгҠӣбјҲб·»гңјеҚ§г®ӢбҚ»КәбҰӨбҠ°гҺҗзҘҖеөӣвҡ°аҜ”дҶІвҲўзә·бҲҜв©ҢгөівЁға©Ңд•ҢгҮҸвёҮв ә,бқЎе°ёЖҳ[ең Г¶б ҪдғһбәҜеҢ бҜҰеғ е°өЛҖвҲҙдҖ зҚІеңӣз©Әеұ“бЎҰЛ д«әв¬ӣд¬ӮвІҒбЈҡвҒ–вҫға©ҳж•ӣ%жұҲв•„еӢҠеғЈеӮҶУЈб¬’еӣ·вӘҺuаўҶаіЈбң–д«”gб„ ж«ЁбҚіж«Әж»»г¶јгЁ ВҘвЎ•вЎҠг®Ӣвө»з ІЧЎаө¬РҒв‘ӣд“Ўвқ«вҙ в“ҖжЈ№дҺ—зҳңб©ҮдҸҢбІ№зҸ„еҺҡеүҚг…”дҮңбқәПҒб¶–жҫЎгҸ“ЯҠХ ВІвҗ…!вҜҖзӘ©еғ”гҡөе“ҙаІ”дҺғеІӣд…ҪЯЁдҗҖвҹҙдұөЦЁ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":1250,"_status":"completed","_startTimestamp":1775292771829589,"_endTimestamp":1775292771835395},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":987,"_uid":"d35e56a4-ca2c-4618-8146-553f9f525fd5","_cid":338,"_ctime":1775292633694,"_sid":79,"_stime":1775292771269,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:50.906Z","time":247,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiUf6&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"188"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiUf6"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"postData":{"mimeType":"text