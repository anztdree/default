essFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":59694,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:56.746Z","time":325,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiW4X&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiW4X"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292776746816,"_endTimestamp":1775292776752212},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:52:58 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1287"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":1523,"mimeType":"text/plain","text":"588:4372[{\"ret\":0,\"compress\":true,\"serverTime\":1775292778067,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвһ еқ‘ж ЈбҶ б®¬ВҢЛүвӣӨв”Јбі°аҘҖКҒвҖ№дұҹбң бҶӨдҖ®fznг’ зҳЎзӨ вұӢгҲЎбЁ…ж Ҷдҫ°Г бөҡвүҰзё гҡҒе§ўгӯҳеӮ„аӨ»дҖ¬жҖөдҢҪзЎ¬гҙ‘Ы•еҚҝаӯҺзһөжҚӘдҳ…бёәаҰғвӢһЙ вҷӢд’‘ж…’еҮҳв”„д‘№=бЈідұ Ч‘дҺҗбҶ„г  зҙәбЎҺбҰ аЎҶМҘвҒӮдҮҠд’Җб Ід–ңбҗЁеҝІФҠаҜЈаІӢв’ҙбӢӘз“ӮеЎҝбҜҢгүҫвіҺжҗЎг№ҳеҰ–зғұб’ҠеұҷбәҝдӮҠбҗӘбЁ»бҒ§бғЁж„§в…•бЎЎвӨҲеҳ“дҲ·жҶҚдёңбЎҫз’ңбҡ¶бЎҺаөҮжҜҗвҒ”еҫўа ©ж…ңбӮҲжЁҖдӢҰаҜ•д¬ЁвҮҢСҙбҲЎвЎұз ӘдәЁе·„жІ”дһ©ж„ҙжІӮдұ©Ж„дҶ§вЁҜдғүаӘҢд—–е¶үдҷЈб–‘еҢ–г®Ўж„”вҚ–аҝ“бҹ‘з·ҷвҺҰбӯҶИҘд«ҳбұҢдүҺеӨ¬б…ӢеҗҒжҰҸбҘ®вҲөеӨәбіҢзҘҘвІҡе®®вӯҘКҡе‘Ёб®…еҠҡе№ӯбӘҗбө•бҸ•аІҚа©®д“ЁзҺҺз·•вў”е’”жӨ©жҶ‘ж§№г®Қж—ҜгӘҷеҘҢжҪ”вұ¶дӨҡж¶ҸзүҪз ®д‘ҺЩҘеҫҳең№жЈ…в“¬е¶Ҹд«ів–ҶгӢүжЈөг”ҶеҫёжҺҫжІ“жӨҠб«ібҺүг°Ҹб«ідӯҪгҺҰаҰҚвҝӢгәҜж—Ңзҹ“еҖҫзіҪаҪӘе„ҶжҲјаӘҲдүңвң§аІҗдӘ»зҡҮгҮ®гқӣжӣҮзһұгқҷбҷ·бңҺеңҫаЁ•жӣЁбҖ‘аҫӢд·Ўзғ»дә»бҸҰдӣҪеӢҸа©ҰдҜәзёҸСөб «вұҺжӘӨд®ҘзҶәеҡЁб·өз—–гҳҠб§ҰгӢҮг…ңвһҜдўҚв’үаіҫвӣӯдҗ§аҪҮб„ҙвҝҒв°ұбҸўзҰҖдҲӮб°ұгҝЎд–ҮвҗҒв”·бҹ¬еІҷЩҶеіһЬҠвүҺгңҮжҙ—аЁҚвҙӣгҲ…вү©бҘҖж’ ж•ўР—вҚҸИ°зҠүеЁқбҹ«еҖ№вІҮжёҢНҸдү№ЪӮгҙ…г°ІвҢҳж—ўбӢһКҲз‘„з·…бҺёж—ӨвҺүаә§бӢ“в—®вҸ”ж”ҝбҸ«ЛүвіҚв— жҠҙеҢјгӢҜбҠұгұ”ж®Ӯбөҳе”…жІӣаӨӢжҢ”з„Җе•§гҰҫб·ңж”ҖзҚҙдҲҜб¶ңеҡәбҰӨвәҙб°¬зЎҙгҚңдҙҫжҙҲдҺ№гҺүгҝҰб¶Ңд©ҝгҗ„еҳҚд–ҸгҰҝгІ’дһ·в’¶б°ҺзҙҠН ЖҘжЎ—МЎбј Ю•жҖ б«ҰПҗгҝ§еҲ”жҖӯзЈҙб ·ЛҖеҗЁдҠ°<ж«ҙДһд§·ЪҶаЈ е ¶еі«зҫ–еҘ«а°ЎбӢЁбҡӨв”ұЙ№вһғжғӣаҙҡбҗөа¬ӣеҪҰаәЈбЎҶаұ—е«‘еөіг Ұе‘ЈбўҶК—е©“еҖўбІЁГ¶вӮҰді¶ж¬Һз°ҢзҮ°$б•ЎеөЈв·ӣвҚ№жҝ дЎҺРәгҖҝХҒж№ҶОҡвҺҲЛ…аӯҫжҷ»дӘјеӣ°б©Үдқәаҫ«бӢ»д«“жҡ°еә©в§ҲеҫқКҖгқҪбҸҪдұҹвўҠ$дҙ§в„…!вҜҖзӘ©еғ”гҡҙг“ҙдӘ”дғігӘңеҺқвҝЁдҗҖбҝҪдІ•г–Ё  \"}]"},"redirectURL":"","headersSize":260,"bodySize":1287,"_status":"completed","_startTimestamp":1775292777065363,"_endTimestamp":1775292777071767},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":1010,"_uid":"402a0409-662f-4d1b-81d6-8272f17ab707","_cid":338,"_ctime":1775292633694,"_sid":91,"_stime":1775292776746,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:56.386Z","time":247,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiV-u&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"