ome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkgVG"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775293343701099,"_endTimestamp":1775293343707408},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 09:02:32 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2168"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":2643,"mimeType":"text/plain","text":"987:43211[{\"ret\":0,\"compress\":true,\"serverTime\":1775293352073,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЖ№жүұбҖўбЈЁДҖТҖЧҖФҮд ®ж„јеҖҘдҮ‘вҖібҘІдӘҷж” аұғзҗ„ж”үвҖҰжңёе№ҖжҜҠбЎұа«Ӣв©ід“ҜбҘЎжӯҲдҗӯвҮҡSгЎ№д№ҘКЎг„ұдҚҡб—ўГҢз„ёб’·ФўК®жҶ ГӢв„ҒзӮӘЙ¬вғҸТјдўЁеҖЈеҺ№еі°аЈҖВқгЁёе„»ж°Ҹзҗ®ЪҘаІ•бҮұбҘёзІӮв§өбә№дЎҒг– жҖЎгҷ°зҷ„бҙҮе„«дӯҗе©№ві Д„дӨ“жҠ°вҖӨвҖҗ/еҗҘдҺәЕҒзјәдҒіж§Җб°Һв ҜС”КӘб‘—вҗ§вҺӯгҠіаӨў вҹ®бғҖж•—ФҘз¶ҲгҒҸжҖ§вў‘б°№д—ҶзЁјб’…е’©вғ•аӘ“бі®бҮӮвҰӣОҖд¬җбҗӯд—ҸдҳІгҺ”ФҰвҒ°Вҡг®«З вҒҙжҖЎеӘҲrеҙ зҷғвҖ»д®Ҳuб“ү%е®¬вӮЁж‘Әб’Ј!жјӮЪ ж—үвҒҲдҖҝдҒ…бҒӨOХӮдҜЁвӨҪб…ўдўүзҷ¬гғҜгӢҲб®”бә„дҚұе“әгҶ ж“’бҙҺвҫ°б”ӘвҢ‘г№ӘеӢҙKбҗІдһ¶б•ӘдҡҘб•Ібұәд»ҸвЎҗг”Ӯб№қШғгҳ°бӮұвҰ >СҡеҚ•зӮҷжүҲеҖўвЈ бөҗmжғ гҢ«гәёв« аў”гҢіб®…гӨўдЈҠві¬гҒ—дҷ§дЎҖг§ңжҡҒдҲҪдҳӮе“ӮПўжҠ б•ҝдҖ°а Ҳа©ҷе·ҜзҚқд’қдҷӮДЁгЎ©ЮғзЎ“г”җаҰӯжҳўвҳЎгЎЈді©е ©1дғҝР»гҰёд“јВҘгӢүајЁЪҰгҷғеЎӮДҗвҖЎе—°в ©зҸҝејҝдҮ аіҲбҺҙИ Юөдғ„б¬—дҒӣеҗҗг№ҜдҒЈзё»еҒҰИ•дӨҗГӮд•ЈзЈ”вҝәШЎдўҪдӮ®б ¬СЎбҡ·дҲҺПҝбҢәв»ЈвҢҡд”»жҢҠаұЈа§¶д•ҙдҷӮбҠўд—ҠзҢ§вҺЁжјідқҺб§Ә жҶӮа·ўдЎҗЪӨеқҲаҫІдөІвҸ»е¬ёСӨаә—жіҰвӨҠбәӮб‘қК°жҳҫв»°жӮӮkеҡ…жІҲзҒ¬ж©Ӣзң®д«°зҖҘдҸҮ а°үгӢ©біҜбЎҢд ЁеҶәаҫӮв”°гҹЎж„һВЈpаҪҸе·Ҳвҝ®аҰЁВ«зЎӨаҝ«зӨҙвҝ©вҮ°гЎ¬бҢҒв®ІЖұв©Ҷві‘аәЈеҖәаіҘзҠ¬дӮўгҠӣвӨӨа©ӯг¬ЁгҺ¬зҺ¶жӨҢдә°З•вҷ§вқҘе·ңбңҒзҚӮгһ°гҷөвөҚв„¬ж•Ғз•ўЕ©бҷ ЧұеҘқдҢ”в©ҘгӯҲв„…вҹҲбӣ„ИҰаөҷв·ҖеӢөР жұЁбҠҺд·ғвҝҺеӨӨб—§дғҚб№ҸгЁҢбҸ®з§һвҒ§зҰЎгЎҚЦҹГӨд—ұгҷүзӣӨдҷӘвү«вҘҲжүүгҚ°жІ№гЈҠж·ҷгҪҲв№ӢвҗҚбҳҶг’үг•…бҘҜг–ҪгёҰеЈӯгҠ–е”ҰбұЎМӯв“…зҳқв—„аөӮа ӢаҙівӘӢа¬Ҹг“«д¶Ів—ӮвҙёжӯҲз’ғг«Ҝз–Ғе үж¶ҢаҫҚзұҫвҹ«зҘҗJХҒвұҸаў·вҷҠбҢ‘г…ӢвүҜв—…в—ҺНҢжҚғг Ӣж”ўГүз·ҶвіҲО°з“–ПҷгҗҝОҳбҖјб Ұбҳәз”ЁжҚҠвөҲжҒәбҗғвҹ—жҺӮзҠ‘жҸҡгқҫвөәз–үбҢӨЭЎб”ҙжҸ®еҢ§вәёгҸҮвұүжЈҢз¬үг“—вқЁв”Ҝв®јжүңз¶ӯг·ҶжЎәз¶ҘвҒҹа°ҹгёӨе•Іж Ҫе”Ҫвёҝд®ӘзЁ№в°җжҝҸвӯЈвҒӣвҸҰжӮәжҢҰзҠІб®ҳж“јбҺҶз¶үIа«»е¶ҺгҠҝж·”жӨҸеҚҮвҰ»зұүЧҝгҺ…зҸ№вӢҫзЁҢе°ңжғңЭӮз°үЮідүҝЮӘжҷ»е—‘ж§Ҳв®ұжҘјвҹҪгҘҳаҙәз”№ж®ҷзҚңаҜёжқҳвёҲзәҹбӯҖбң·бҸӯзһҢеһ§гӨҢгҺҮг Үеўӯж№ҺгһјзҘҚзӯ…зҸҡж җдЎҹж®ҹг»¬д®Қб«ҺаҪ‘зҮҲдҸҸз—үдҸ’жёјвўҠжӯқв§«е·іеҶҡбҝҷбӢҸвӢ·жһ—еҷҶвҢҒеғ…жҲҢзҜ¶жіӢе„ҡб¶ҝжӮҲбЁ‘еҙ®гҢ–в°Ҡд«ҳд®қдҜіз’ӣеЎҷгҜҲгӯҹв„җдҫ—зҺ¶гҲҸа»Әж қв«ҰгІұдәҷеҺўзЁӢбҫ•дөЁаҪҫбҳІвҡЁжё°вҺЎгўӨа»ЁбҒҘР‘бӮұаәһвҗҖжҗ°г№•жЈ¬бЎҢз–ҳбҢҘе·–Ы—вё©в‘һгҖәзҳјбӣӮж»ўжҷјдүғе°ҳдЁўгҜ°еҒ”ГҶаёЎб әжҮ°бЎўбұһг“ҖвҰӣг—ҶзЈ”а§ғдҷ¬ж“Ҳж…ЁжҠ…жқўдЈҰв—°бЎізўұаӯҷбҺ·дӮ‘ПӮбҖ©е©үЖ©аЈ©dбҺ’д ӘГ аЁҙжӯІаұҰв’ҚжӮҷЛ г©Је—ёб¶ўдјӨг…ҰвҙЎд“…еһ©г‘ӮбӮҷбіҗбҖ©ФғаәӮеғҳа°•гң§г Іе‘Ңд ©жіІж№ёг¶¶в‘ЁдІӘд¬«аҘұгҝ…е…°дҰҲз«ўбҖҫб·ігәҫвғёдҺӘгЈҠдҖ¶М§еү•д„ вә§зҖЎР°в„¬б„Ұа©ғбҗ¬вҮӨв–§аІ„дҚЁаІўдҖ»а©…жүІдҶ‘еҹ«д©ҸаӨҒаЁ ВӢбӨ…гҳҫж“ҖжҲҰГів„„дҝўж’«дёҶЙ©вӯЁвӨ В‘аҙЎз¶ҷж‘ја§ўжӨҮбҢЎгҪүзҢЎвҶ“зЎҹвӘҚвӯЎзҙҹдәҷД„Х«дҸёжғӮаӘұвҜҳе…¬КігҹӘвөӨвӘҘжҒҫеүЁа№°бЈҗдӘҒвӢ№з…ҝжҗўзүҺдҠ°вҪҘдЎ»в— еҝҙв—·зҗұвҡөг…ҪбңІжҘҢгӢ®вә…ИӯејҗеҫӘбіқз—‘г®·дҶҸбҡӘеөҸз–ҳа®…ж…№д•Іе‘ӘжЈ„д©…в…¶Ч–б’ңдҚӢ М·зӮІаұөе‘ҪзҶҺб©Ўзұ°в–Өеӣ„а ©жҜӨжү©аіәдЁ   \"}]"},"redirectURL":"","headersSize":260,"bodySize":2168,"_status":"completed","_startTimestamp":1775293351075685,"_endTimestamp":1775293351082730},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"555","comment":"","_id":1723,"_uid":"8eab1517-c307-428d-af67-292af0ef6735","_cid":555,"_ctime":1775293161884,"_sid":67,"_stime"