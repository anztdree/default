\\\":\\\"07630f0051cfe1502d7f08413d758c09\\\",\\\"data\\\":{\\\"appId\\\":261,\\\"orderId\\\":\\\"07630f0051cfe1502d7f08413d758c09\\\",\\\"subject\\\":\\\"LevelFundsx1\\\",\\\"money\\\":652,\\\"userId\\\":\\\"28178141\\\",\\\"buyAmount\\\":1,\\\"extInfo\\\":\\\"2079\\\",\\\"sign\\\":\\\"9051f67efa221621187a961504def714\\\"},\\\"totalPay\\\":0,\\\"goodName\\\":\\\"Level Funds\\\"}}\"}]"},"redirectURL":"","headersSize":232,"bodySize":612,"_status":"completed","_startTimestamp":1775293299296390,"_endTimestamp":1775293299302194},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"555","comment":"","_id":1667,"_uid":"22f90f91-7926-42ac-8572-003e72fcd045","_cid":555,"_ctime":1775293161884,"_sid":48,"_stime":1775293296028,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":34454,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T09:01:35.719Z","time":270,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNkUnK&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkUnK"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775293295719606,"_endTimestamp":1775293295732294},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 09:01:36 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3242"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":4047,"mimeType":"text/plain","text":"265:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":false,\"data\":\"{\\\"_id\\\":\\\"33cabb81-987d-4712-81c8-0d88b4c63132\\\",\\\"_timeBonus\\\":{\\\"23\\\":{\\\"_endTime\\\":1775379696335,\\\"_isBuy\\\":false,\\\"_buyRemian\\\":1}},\\\"_triggerBonus\\\":23,\\\"type\\\":\\\"Notify\\\",\\\"action\\\":\\\"timeBonus\\\"}\"},null]1336:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе ЈбЈ®жұёДҖЖӮеҰ‘бӣҸRд© ОӨа°Ҝв„Ёгҷ•б©ёжҙјд»¶а¬ вң«еӣәжҖ«зӮ°дҲҖбғ еӢ¬Щңгө…аЈӨжӘ Ы°МҲв–ёжҖӘбё вўҫИҰвҖ©зҒҲдҶІеҖ жҙ…аіҠж¶қвҮҖС„вҚ…г—ғдҒҖТ°зіҗжЁӨвҖЎд®ҶжҰёг Ўбў·еҶҫвҘҗ$дҝҘвҡҠдҠ“г•Ңб·Ңдӯ“бҰ©бҢ”ж§¶б¶Ҷж¶ӘгҰҝд№ЎгӣігҚ…ж¶«ең‘з’ІдӨЎд§ЎгЎӘаӨӨгҒӮбўүбҗ гҲёе«„вҝ®К ВҺжӣҗж”“дҗҒгҷӣС§дҢўжӣҠКЁвӮ°зҳ а¶„дқ¬дҪұаЎ вүЈдҢ°Р«зҘЁзЎ–аё°Л©ж„”бӮёе…ҠзјҲвҗӘSз‘ҠгЁІдҮӮеҖ№б’јв„ЈеӮҷЖўд“үв‘ңФӨві«дҳҲвңӯдӘўвӮҳв»ұгҖөЧҙВёв”°в’ІеӨәв¶·ж–ӘеЈҲжөөФҠе©Ұаёҷдұ“в—ӨгҗөвўҡдЁ°в„іб•ІдіҲдҺҙб•ҲвЈҷв»–ж¶әеЁ§зӮІбөҸаҜ—вҝөгөҰдҝҢж ӯН¶д”ӯвЈ·ж¶ұдіҘжҮөеҙ¶зҹ„жё—зёҷжӘқбҜ”дҡ®д®»вҰӯзҢҫдҮҖеө•зёҶжӮүвөҢжҙ№зўҒж»ӯб·ҷзғ…еі”в–©еҺҷб¶Ңв•ҒдһҳИҳвҚҖвҸҡжҳҸе¶ҫжҮҗгұҚбҚ…еӨҚбҫҸдҜҖвҙҡеЈўжҺ•зІҷгІҸа°қзӮғгҙӯг—¶вӢ·гў·зһ«дҺҲеәҢеҗӢеҰҢбІҪвқ№еҳҷжҜҫж°—дҠ…гёјж®ӘеқңбҸ”зҮҪеҶҜзҗҢзҫұз’ңвҺ зҳЈвҝҶгҶјгҢөзҮ¬г–ҙаҝҚзҝ‘зҠқвҺўаіјжҫёаҘўвўңзҺ¬дҜ‘еӣўзҒ№з‘Јб·ҮзҶёжҙ©аЎңж‘°з…қдҫҫаЈңг’’а«ңбҳЈаәЈж’ҢаЁЈжҺ¶зҠје·қаҪЈж»ӢаәӮгўңа°Іжҝ’аЎёз¬ёдЁЈбҠ…а®ҚжІӣзӢ¬аӯ—з—қгҝҶаҰЈвҜүз•івҒ§зҷЈеІӮдЎ’зӘҖаҪ’жұӨз…’гҹӢеҗҢбү аҰғгЎ¬д©ЈаәҘдҲҢжҡҸа№ІЙЁаЁІе¶§дўЈе©ҰаұңзІһд¶ғвәҮг‘ӮдёҜа·ІжҶ…дўӘзәҢдІ”ајўдІўа®јвЁ’еҡ„вҪідЎЈжӢізҷҰвҙӘеҰӮв»ғжҝҒа¶ЁаІғдЈғг№№в№Јг„ҪдҝҪе–ҹа»ӘдҘ¶еӮӢаәәвё«жҠҺаҘҠв№»вЈҢгҢ§в»ңе¶Ғв©Ід№ҙд«ғзЎ»дЁәвҺҮдҪ«жҚӯв¶Ҡж•Ҙв®әжЎўж«’з¶”д »гҰғеҳ»гҺөвёҠбҚӘдҰқеҚҙв¬ҚдҚЎвӘҠдқІжөҠжһҺж¶әеҮҒжҫўеӯҙжӯідү¶гӮҠеһҚгҡӢжҶҹвҜҠзӯіеһ»е¶ӮжҰҠзһӣжЈҡдғ°в¬»аұЈзҗӣеӯӘжІ§вқҡжӨ§гғ¶а¬§зҫқжҝҠдғөгңҡа№ӯжҰӢгұ®в»§дЈ°бҙәзҹҶв№ӣг–қжө»в”үжҸҰгө«ж«Үдӯӯб№“ДүбәҰб”‘вәҮжғұд·Үд‘·діҮгһҶбў§бҪ°бҙІб®—дЁҶвӢұд¬·вқүдІ¶дӢҰбЎ§віјеҰёгҶҖејҮдӢӘеў§в®Үб§Іе¬’е®ҡгҡҖб·‘аөЎеӘғеӢ®еҘ—гҚ№еҙӢгҶҒеҫ§дңҹд¬¶зңҗбҰҰеҢ–еә–Т„б®—з«Ёві–ејҒдҰ—еЈ»еҘҰб»ІеӘ—дҮҜеҜ·ж»·б°®дң”гҰәаө№жҖ–д•ўгӘҜвһҺеІ§жҲңг®ҰаҘ¬е«ҪеЈөгқҶбңһгә“еӣЁг°§гЈЈеЈ®Ш…гЁ–жӢөгҚҜв’ҷгІәдЁҖжўӢдёҷе ®ж·©ж»’еҳҢжјҺаҙӢгҪ§б§ зҰ®гЁ–г—Һзё•бҙ·д— еұ·ајқгј—ж¶—гӢқвҳҸг¬ҫвҜ§г»јдҸұаҝ—б«ҪгЈҸвҜ§а»ҺЯјгӯҸеҜ©з·ҫбҪўз¬ңгҗ•зҫҺе§ҝбёІа»ғе’һбҷӯзҰһд—№д’”зҚҮзҜҘг җдҪҪд һг®ҲЗҸв®қжҝ¬зғӯд’ҷеҶ·зӯҹа ҜбөЁж һеҙ…гёЁбҝјгҘ®зҙҹеҺӣеҸҢзЈ“бӘұд№ҹзҲҺг°ҙзәёбҸ”д‘“е‘Ёг’ҳгҒјз««в”®е№ҳаҙ–д”ғзәіжҠЈаә©дҚғдһҡеЎ»д¬°д®—дғҖаұЎв°¶жҡҸДўеӣҙз·—аёғвЎ дҷ дј«бҪүаҙҒжҳҢЗўбҠЈвңҝдҺёгІҳе‘ұЭғбўӘЭҷаҪҠз ҸжҮҹв·ўдЎ’вҸ ві«аІ’д”Қб °гЎ«зҹҰвҡҮеҮҶбҺғв§№зҳҗгһ№вҜҚд—Җз¶«гЈўз’ҺвҲ¶гҡ“дҶӮУівҸҢгғҘжЈӢд–°еҙЁзЈ“гҒ¶е’үг…ўбЁІгҷӢжҢ№дҹӨбҜҺжҒӨжҙЁбӮ»бҠҗе¬§Г–УҗжёҪдҖ бҡ¶бҖЁбӣ вҖұв“ҳа®Ҙд‘ҲЙүг ЎДҸСІа¬ЈдҶҢбҷҒжҖӘаҜӨвҰўвҫғзҒ©д’Ҡд °ЖҒж°әеҲ аЈ®jвёЎжү…в—”гғ«г‘ҡдӯҗж¬Ўв§Јб” гҢӘXаҰҒжёідҮ гүӯМ°д°үбҖ§ГЈбҡҖдё з…¶У„а ¬жҢ¬ж•Ёеўүд©үвңЎжғ‘а®“дҚ„зғҖб«Ўбұңж“јг¬Ҙжў¶аӘ‘еҫ«аЈ‘а»ЎгҳёгҠҶаў…а©ҙГҢбӢӨе’ў@вңӨв§Јбұ“ж°ёеү¶вҲ б°№дҖ°б¶ дҒ»ФҷвҗҠдӨІбөҳд¬®ГӣдӮЈеЎ•д„ҙді еЎҲНҗдӘҪгЈҘбұ’б°ўжҒӘвҢҶаә“дҸҗХҸе’¬д°ұзҲ°ЩҝбҜ“в«ӨДҙвҹҶгҰҸбҹҲеңӘеЈқд»№бӨҫб…°б…ҒЕӣеҠ‘в©ҙдҖӨе«ғЪ©бЈҚа¶©аӨ„еҮқбҜӘзҝ»д©өг‘ҶвҚҗе’ҠжғҸдҪ“Ьөж•әб•әеҚҠд«„вӯ•гЈ¶б–ҡеҗӘе‘«зЈ«ЗөзҚҪдәҳеҢҠгӣӣбӢҖВЎбҳҙб‘ёа®ўб’ҰдӘ з©ІзҒ®aгҚҳгҗ’гҢ„в№ӨЗўаЎЈЫёдҚҗгӯ·дәұб–ігҝЈжӘӯгә§зҘје Ҳз”ҖбӘ§вӯӯгјәг—¶еҰәвҮІж°Қвқ”з№ӨдҚҶзЁЁзӢ§в©ўг•Ід¶№бјӮжұҹгү¶г¬…е©ҚжҮҙзӯЁгіҜдһҖЮ·Ц—бүІд¬¶бҮҺгЁўбҷ”ж“¬ЪҸеҡ®б–ЁеІҙе °а©“бқҗгҢҖбҠҙбҲідүјзӯ®з«°в«№в ©д–ҷб¶ҳеҖәг¬«вӨЁа «д„ҡзҡғбЎ‘д®ёд“өв—ЈбҪӘзғҠ>г¶ўдҡҷжҗ°а·ўеЎ–д—ЎбЁ·вөҮеҮҘдӯүгӮҰвҘ—жҘҙПҗбҰҘзӣ–дҚ°еЎҪа ЎеҒЎзҚҚзҮҢВЈЩЎНҳг Ҳд«§аёұж§®бҳ‘б©»гү®зҶ’вӢЎд°Јв”ҙз№ӢдҒ‘дҰҗг®ЎФ»е“’з•Ӯж„ІбўҮз…ЁвҢ¬дҮ§гӢ№а«ҚбҖӯгҒҺУҗз’ӮЗөеҒ–б„Қв“ҳвІүдӢІдӯҗеӘёеўҗдңұеІңзҲұг–®в–Һгң№Ы•д«ҙжҰҚб”§а §аЁ»а¬ЁеҸҝв“¶в©Іжӣҙеӣ¬зҮёвөҳИӘеӨӯбғҙаөҳзӯҙзҙҲжІҷг•–зҖҺе§©аЈҫвӯӣзҮңб„қеЈ…вқјзӨҘаЎӯг–ҸгҺҠз§©аҫІбқ–дҘғаӘөдҶ—а®һбҪӢдҢңе‘ңгәҢеӣҚаўҳжӢёг•“е®ҙај®жһӢв¶¬бҢҳв’ҷзҫ№Чҙеӯ…жЈҗеҢІДҗдӘҠж®ІзҖ—зҢ…вӨ…дҺёШҢа©ӯг¬әвҮҷг…ӮвҖ©жӮ®бғҸеӨӢвҫҶжһ»жҳүж–ӢгЈқж¬ұгұ¶ХқеҳІжҰғеӢҝдіөдҪјдҳ•дӨ»гөІжҜјгӯ–зӯ•еқӘжӢ”Ы¬вІ®жӢҪзҠјдӘҪж«ҷд®“гҺІжўҢжӯқгҝЁжұўжҗ•еҚҪжј¶еҰҗдҸ’вөүгҜ¶еІ“г Үе—Јдј„жёӯе—әв–ўжІ“зҜһб®ӯг¬–гҶӮдңҫзәҰеұғг’…зІёз—°ж°§б„ҠзҒөгіҶбһҲеҷәж¬’вҮҝдқӨа·ҝб—ҸеІ«бҺӨдқЁвҙ°вҫҸгңұе”ҸвҹҺж¶Јз…җбұҙгҙӣе«ҷа®§Ц®бұ зҶ‘зўҝзӣ»вӮқзұёгҺҝеЁқгІ•е®Қа°Үгҫқдәҫж·ҖдҮӨжҙ“еҒӣгҗөеҝ“дҶ•Ю—аөҜвҰғж•…зҹҺаЈ¬е№Ҙд–ўз—ҳгӨӢг©ҹбҹҘдҖӢзҢҺе ҷз®ҝжЁһбҪ®И гҗ д• бҖ В’вҲ д„”`аҙӨDаёЈе ҘеұҲгҮҷзҲёЭ—з ӨдҖәЧ з ҜдҶүа   \"},null]"},"redirectURL":"","headersSize":260,"bodySize":3242,"_status":"completed","_startTimestamp":1775293295983857,"_endTimestamp":1775293295989830},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"555","comment":"","_id":1666,"_uid":"139fc9ce-0d0f-4115-84b5-f5f361f86e86","_cid":555,"_ctime":1775293161884,"_sid":47,"_stime":1775293295719,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":34454,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T09:01:35.082Z","time":251,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNkUdM&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"145"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkUdM"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"postData":{"mimeType":"text/plain","