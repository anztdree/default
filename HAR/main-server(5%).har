а№ҒвұҸаӨӘаӘӢг”Ҫг°җж—®вӯҠаҘ§д°ҜжҳӣгҢ“Е…гӨүД…гһ”е—ҚвӣҢзәёгўҸзәёв»“бҮ…бҢӯдҘҜеҚӨжҶ‘вҗҢжҘөг—ўв—®вңӘжЁҺб¬«жөҶв’®ж…§г—”ж‘ҖвЈҢОҮг°Ҫгў·гҮ–еёҮгүҘе¶ӯд»Ҹбөңг‘ӯа¶Ёж‘ӯжӨ°г»ӘеЎһб©Ҝг·ӣд…¬еҲғгҠҺд§ҝвҠҪз·ҚвҹҘа§үгҖҲб§ҡв°әеӨәаіЁзҘ°зҺ»дҚҜе№Үж§Ёз№ӯвҗҳжҢҝдҘёз„ҪзҰҒвјёж»ҒдәҚЛҜгҘҠбҸҚгүӢб…–ЙӢеҺҷд…Ӣв” зҝ©гҸҠжһҸзӨјжқҺзҗһгһ№жҳңзһ—зҖЁж«ҜаІҒг‘»е°ӮзёЈЛҝе§Ҳз—’жҮҜг–„гҸҢеҮҪгҹӢз•ідӮҲжҷҖИҸжҡӘгҘ©Е“гҠ®бӨ“гқЁб№ңгІ‘zжҡ’еҗҶбӨ«жӯӯг®ӢЕҶзӨ«бҜӣдӢҫв…¶жҪ•е¬®гЎҫг»ҝе§јдӯ¶вүұг¶ҫзӘӘв® ж•»вҗ„зҮ–д—Қг«Ұж„¬жҙјжһӯдғ»вҚҰзһ—гўёгҪңгҳ¶жҳҪеӣҘзў•бң¬г¬¬г¬®гҙҫжҮөжҮ©жҸҡг»һдҰӯжҒҫгҹҚеҙҫбІ„з‘ҜгһғвҘ¬еӣ”з‘®з ҳзҹҹдЁқзјјбҖқеққб§ӮгғһдҘіж—©дҝІгіқгҘәгҸӯа§«жҹ«ЬЎгә«ж–ҰдӮҘвң–е®ҚзҸ–еңҶвІ§ж•Ңв§Ҙж·Ҝд»әвҫ«еӯҝб·•еҪ’жҹһеҒӘбә…д”қвӮҘзІҚдүӢдҜҳжҒҘгҸ•гӯҚбһ–бҫҺеә«дЁўзҰ·жёҢеҝәзӘ¶Р•бӘҒЭҗз”–зӢўг»івҢ”еөјжӮіеҲӨеіӮжӘ®бҠ•д„ҳаҰ–вқ©жІЁбІўа№өМ—б°’гӮңОҖд ЎгҪ—зҮ зҢҸб»Ёв•Ҫзқ»СҲг—ЎвўҗзҺ дҢ•зғҜеҳҰе ҪгӮёвўўдғҜз‘ЎдҳӢеӮӢдӢЁеөҖбё©з–җб Ӣвўёв№ҪдұіЦҪеҙ»з’ёгӨ‘гәұжў·бҸұзҶ®з„ӣжҜ…еҒҢеҰҜд•Ёг’№з°үвҲ«жҘҸзҠұдҰҜеӢ’б—ӯз©ҘзҙҘд°ҳгҝҠдқ©гҸ”зӨЁе һз¬„а©Җбҳҙз©Үж–ҳвҚ№еҠ°дңЁдҫҙвӮҙеӮӘвӨҫдЁұвӯӮдҡўб–җвҘ§бҺЎЪ„з•іХҝзҢұг„ҢжӘҺж Ӯг‘ӣб”ҲгҒҷбҚҗгӨӯб өгғәдҮҶаёҙжӢ“в°ЈеұЎг”қдҰҠТҠжҘіа№ғаЈҚеӢІвӨҪгҮ’бҪға©ӣзЎҙгӢҷдғ—вӣ¶бў–з‘ҮеӣўжҠІИҰбЁІаҜёжҚҠвҗ©дұӨдқұб’®аҫҖг—‘зҲҚвү®б«ідұ®г·јвҰҷгІҺб¬ҳжў°Уҡвһ№в»«жҶҙжұ¬еҚҸг·ҳеҳӨг“”вқ“гә·д”Ӣа¬Ҷд Ӯд§Ӯв«іФҙв‘ҡвҜ“гү©жқҮб№¬ФҘгҷ®гјҫаӘүв©ігқҮж‘Ҡг…үдӢ“ж’Ҙбө®еЈјеқ¶зӨігҡҒв«ізӣҪв¶‘в°ұг©»е¬”еҡ®зӯҳбҗ№вЎҢбӨ¬бҗјдұңгӢЁеҸәгҗ»дғҲЕ©ді гҚәж—ҖеЁ‘ж ҚЪҙбЎ’ЦӢе—ҳд®ёаӘ·аӨҢзҚӮб¶ёг«ҝдҝ’е©°зӢ”еө§Ж№ж–Ҳж ұгөӢдҰўжұ…в•Җвҫ“вҷӣШүгӣ’еә•д—Ів‘—еЈҸд·Ӯбң·з§ жҲӮУ•г·ҙдӯӨа§ҡдЁҲз©—жЎ©Ш©з•ӢгҘ’еқҠбӯІбҺ”дҲҮгў¬вҹҡеһҒвӢӨдҪҘгҖҠдҘёеҶІж№§з¶’вҷәКҰжӘҘг«—е¬„з“…д¶ҶаӘүеІҪе•“бҜІдұүбҰғвӣ’дӯҜжӮ§гүҒе№әвҲңеҝІбөӘб°һYд–Ҳж‘ӘдҫҒгӮЈж…°в•…аәјб Қеҙ®б·ҙд…ӣзҗӘжһҠеӘҗжқӯд°ҡж¶ібҮҰе—…вӣҸз—ӯгҖҠвөҘдқәд—«е«—е’•вҝ…ж»ҺеҢ•б§’жҠёдҜҙгәҸеӣЈгҝҺН·а·ҘдҳӮз©ҒеёғжҮҸжӢӨеҠЁг’№жҮҰдһөеіүжҪҗеҗҠд¶ЁеҜ…б§Қд·ҙе”өбҠңдҹӨвҷҠа¬јв©ҚеөҖв—Іж»ҚзҘңе«©в«•е—’вҘҡжЎҒеӢҪгҸ…еӘІжҙӯбһөдөқдӯӣв®·г®ҡе ІеӨӘаӘЎв №дҮіж©ғбІёжҸ“бЎҶвүӣеўӢдҚ§г¶өдңөвұҪзҝјеөәеІҙг«ңа°•в®„зҸ–з–ұб»ӯбҙЈд¬ўеұҙгҙҪжҠӣдғҜжҚҫе ёжә…з“қг¶Ҡж„»ж·ўеӮӮб№һеҘӨа№Ҷд‘ҫд …еҫҹжҡһжҒӢвҫҖвұҶв»…б‘ңбӨ«гқҚдүӮгё·жӯібҘЎзүҢбӨјж·ІСҹд·ЁгҜ…гЈӣзі°ж“–г„‘бһўд–Һв¬ЁеҮҚзҠ·в·”е»Ңд·‘дҜЁж–¶вӨҡеў’зӯӯеҲ„еҹғг»әвҮ¬г—ҙдҸһдҢёгӮӢдқ·аёӣв“ўвҡ№ж¶№г–је•ҪдЈ“г‘қвӯ•вҠ’еһ‘бҜҢжҢҖж»¶еӢҪвөӢеҘҶеҪҶжӣ‘вҡ®вІЁаҰҚгҘ‘а·Ҹв§Ҡжі°аҜҙг…·е°¬дҪҖжӣҢвЈ¬е»ҮжқһзҰёЪ·еһқжғігҺҒеһҮбҮҒжқ©е®«бі·вЎөзіҚвҘҲд¬һаіҪзҗҢж°ҮжҷЈа®ҢеҒҸе“җгҖӮеЎҫв•Ңбұүд«іаӯұвӯ»ж«ҫе©Ід’ӯеӢ’в·…б®ӢвҳӮеӣғж“Қж—ӨбҺ¶б»ҝеӘқд–ҜЮ‘вҪҗеҘҝеҘ—Кҙеғ®дӣ·аә®бӨҡзғҠз…·зҪәдӢөж‘ҸзғәеЁұз…Һб„ӢеҗҢЫҺТӯгҷ®з«№а«”дҲүе¶ғдЈұг¬Ҡгө¬в…–еӘҡгҡ”з¬•бЈҚзҡҡжӢәгҶ…еІҫбҹұгҶ¶гҗәГӢз·ҹвһҢгІҫд“ҡbЖЎг—ҷж’–зғҲзҰ®в¬–вҮ зөЁгіҘж·Өдҫәзҫҳб·ӣз•ҖвөҲгҳңдҫҚб’©гҖҘд„ӮеӨҙдҹҝв¬ўб№®вү—з«ҹгў·в’қвө»вҠӯеҠ§г—…вҷ»в”Ёг°…вў—д¬ЈеҒ·вІҮжҰӣСўзҒҮП°вҢӨг ӨжңөбӢҷжҚІеӮҷеңјаҜҙзҠ–г‘һбҝөеғ®віұбҫӘбҠ—е”Ҫгә”е¶Ҹз’ҡзһ•з¬һзҗӯд—ҢгҸӢвіұбҡ”жјҮеҢ•гң“еөҷзҡҚе¶ңжҝҫзә·г§ЁбҪІжЎқд·ҡз®»ві бҹІвЈҫеҰ©еұӣе§һзӨіеӘ«зЈӢдҸ‘г„Ҹзң•вҙ»г§ҫгҠӘвҪ…г®ҠеҮҜг¬Қжҫ“ж¶ҹвғ§д№ҜеҗқжҳҫПјбі§дүҹдҹӘб‘ҜжІ‘з©үзҮҖжЁ•в®ҲгҚҹб«ёд·Ңдӣҙд§ӯжәіж»“е¶ҹвҹӣвөҫдҝ®еҘӯеҮҠдұёзЈәжҜ©д”•зҶ•бҺӣз“ёаіңзҢһг®ӣд»©а«әзӢӣаҫҷзіҝвёҫв‘—бҒәеғҪв”Ҳг”ҝЕұmзӣұгғ…вҹ№жӢ»зҳ©гҷӘбү№дЈ°аәҺзӮ—Яҳб·«жё®зҲ—вҫүз·«гјҷгҗ–в…№еЈ¬гӢ…г…ҹвҙЁаёјз№ЈжҒ®бҚ№ж«Ұз»№в‘®бҡӣзІ§вӘ„зҲөХҡзҡҰвҡҗвҺівөҳб“¬д‘ӘгғҸгҲүвҜӯвҡ·бҲ жҒҗдҒҶгҳ¶бҺ»РҰаіӘЖҮг–ҶбӣҡеҰ»е»ҢжҸ·бәүбғ г»Ҳа№—гҶҠд·ҙеӘ б……ФӣзІӘгјҳаҰҝгұ»аЈ©жјҹг•ҖдҸҷЗҪж»ӢзӢҖз¬ҳжЎ“г»ҚвӣҝбҗӮзҹЎд„ЎзҠҖж¬ёдқҪдӣ‘з”®вүӣгҠ¬зёӘеғҹв”ұзЁӘз№ңбқҜаЈүжҝ№біӢб–ӢвўӨзҹјв…ҜдӢҮб’Өж§®Т”зҚҸвҲҲб‘…вҷӘа  дӘҰг“Әгҳ¶б” жҡ§бҜ»в„«г—°дҗёжҒӢжҡҗа¶Јг—ёзҰ©Дўж… дҸ№еҒғжҗёа§җеӨӣгғӘжәҳа§—бҹ»бҠ§зң“зһҗдҜҷбҹҫб‘Ӣзқ«вЎӣжҠјаёЎаҪҡбҒҘбӘ©дҡҒа·ҒгҢҰвү•дҶ‘зҺўвҹ“жү—дӣ“еҹ’гү§вҝЁвӣ—зҖұбӮ§в¶ӯг“ҷзқҮб’әаөІвҮ®вҡ°з…Ұж‘ҺФ’аЁ»бҚҡдӣәеёҝвҺҮвөӨг®ҫе„ҪжӢ°д–ӘвҒ•ді°аҝ°ж°ҰаұҮв»ҰаёҸвҚ“зҜөдІҘе“җжЎ»вұңбӣ–аІ«аё»в·ҝЪіаҫӘг“Ҙз»Ўжё з”җзӨҰе–ІдҮҠжӣҖж«’жЎӢг»ҷг”Ёзјӣдүҗз»ғеҡЁд”үвҰәжҖ¶з…ҳз•»жІөгҖәе•ЁзјӨд•ұеҷӢеӮҹг…’з•ЈгҲҜаҰҹбҸҘеҝәд»ҘзҶ°зҪ№ж‘җгҡҗвҳ»дҖҳг®°Е•аҜҸгҡ№бў·вҷҖдӨҺбЎҶбҰўаҰ¬жҒҗжҚ‘аұ‘дұҶа°ҸбҰҰб…җгә¬жҳҝв«’гҒҲв”ғз“ӨзЈ§г…Җд…іа©Җзұ°дЎҺгҶ„аө«гһҘбҷҚг№”гғҝбҙәз·јдӢ°зҲөвұҷа«ЁзәІе‘ҳеҮ»бӘ«дҶӯдҲҖзқҶв№Җв…ӮгҹҹгҡҷеқёвҰӮаІҳж•ӣб№үзЈҸаә’аҘӨж•ңе№ҝаіҸгҚӣб‘Ңз«Әдё ж«ҶЖҪвҰӯаҙӨдә§д…ҸвҮҡдӘӨз»„ж…җжҰҗд»ҰЙҶбҰ©аҘЈзӢҗдӨӣЩӢЗғаҫӣб·ҮжҠ¶жәўЖҗдҸҳжҷҖдӨҫаө¶бһӨвЎҮжҶ„д°җд•…еҷ‘а°»а»ҒбӣҰжҘҮг„ұаҫ§вўҮбІәвӘјаЎЁзң§зҪ·д„ӨзҳігҪҶбҚҗвӨІгҸҜвүҗаҜөе‘Ҙз„ҹаҰҷгҝҙе„¬зҸ¬жҠӨаӯҠе…ҘдЈ‘гӯҷж©ғвҮ дЈҢжӣ…вӯӣвҘ•д»Ұб»ҮгҶ ж§ёжү”зұ„дө•еҰҶд»ҰЧҮдәЈЩҸгӮ«аёҰвҹ«аЁқд§Өзҫұз…ҚжҮғд¶”е…Үеө’гҰҫдёҗзҹҮзұ—жҰ”бҖ”ејҡНҖз»Ўдў„зҲҷдҚҷдҘҰд’¬з„ҖбҸҙгўӣдӯЁдј‘зҘҶзҮәжҸҳзҠҶзү•бӨІајҙж…Ұв•ҚзҮІдӨҳжіҮбІҫвҰөаұҙз•ӨеҪҖаҰҲжҲӨдҫ’гҪҖгіҝд»Ұа»…зҪҺеӨ вўҢеҖөбӯҹаұҚд»Ұб®ҮдөғеҰ¶д¬Ңз—„зӯ—Д®зҡҝв«’жҹӘХғдұ–бӨ…вғӮгҘ„дӘјеҗ·дҘҠЦҙд°Ёз•ҶЙ‘д…Ӣдҝ„е‘§дЈғгӨ©зҹёг”өе¬Ізё·аӨ’в…ҡаҪҳв…ҙж•Үб¬·ЙҸбҮӣдҒҲдҜҘа©ӢбЁҸаә’вҹҘж•ӣзҶ жҢ»вўҙг®өзҰ дҫңе’·дҒ’е§ӯа»ҢжӯҰв…қеҮ°дҫ жұҶбҒ”жҶ—гқҗзҪ§б…қЗҜгһӘг№ӘеҘһжҶҖбҒўзҫ°Э„ж•ІжҚ’еҗ¶аҘңг§ӨдӘўжҘҶжіҶгЁ–в®је–°бқ•гЎ«д№ӮеөҶзӘ«жЎөдҲ   \"}]"},"redirectURL":"","headersSize":260,"bodySize":5205,"_status":"completed","_startTimestamp":1775292671335671,"_endTimestamp":1775292671352605},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"340","comment":"","_id":778,"_uid":"7f532b20-8d4a-4ce9-8857-f110da7c32b7","_cid":340,"_ctime":1775292640285,"_sid":21,"_stime":1775292671082,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":59694,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:51:11.036Z","time":269,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNi6Gn&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"527"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNi6Gn"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"postData":{"mimeType":"text/plain","text":"523:4221[\"handler.process\",{\"type\":\"