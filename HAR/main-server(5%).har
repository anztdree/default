low-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":2303,"mimeType":"text/plain","text":"877:43212[{\"ret\":0,\"compress\":true,\"serverTime\":1775293353009,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЖ№жүұбҖўбЈЁДҖТҖЧҖФҮд ®ж„јеҖҘдҮ‘вҖібҘІдӘҷж” аұғзҗ„ж”үвҖҰжңёе№ҖжҜҠбЎұа©җгҒ”е„ҚвҰІвҮүбҒ•в«ҡз¬№г·’дӨұвҖӘжҶҰвЈЁд•ҢгҒҲОӣгӘІЭ«дҠЎЕ§гғ uеӮҗзЎҘЕҶбҒ·дү®в‘Өв Ўж§¬жәҲС°^еҙ¬вўӯзҳ—зЁ§НЈжҶұжЈҳдүІв•ҚбҶҝбӢӘзҮ•дӮҖГ–вў–бүңзҸұаӯҹб©№вҝ¬Д„д «еҠ°вҖӨвҖҗГәгҗ дҘҡ!зӘ еў“вҒ„вҖҗаӨ”а°Ўа·ҶЗ©бӘ бҳҳжҒ…аҘ¶г© г©ҳjЦЁ!.бҖұбғ„аў°а Јв—°бҗ а¶ҲаҜЈгҚ–е°ҲгЎ°вӯІбҠҰж №жҡ“б…Ұж©үзҷ·ВҰжўЁгҒҫКЁХ‘е°Ўбҙ©дҳўжҖ ЛҰРӨжӮөвӨ¬ВҮеӮ§бё°а»ӮгҘ¬дӯ…ТҮд…ҲаӯҢИӨбҷЁбұңвәҶИҢгңҫаўўЕӮбЎҖЮ•гҚҠЕ’еҶӨбҙЎаЎ‘а·ЈзҠҲдӮҖбЈ„ОЁгӮҶбӢ¬е¬Ўв ӯбі‘гҲ дһҺаӨ®ж„Ғд¬ҶвҒ¬вҖЎТ дҖўеҖ–зҜ©з¶ҒеІҢзҲ гҺҸвҶҲЫұжұҗаӨ бҲЈгұҰгўҘЛ’/гғңа»ӮИҖж‘ҖЩұаЁӨб…Ҹа ЁЖҘд‘…еўҜжҲҶИ¶г’¬вҠ’з”ңе®Ұв’ЁjгүҢдЈҶбҖёеҷҮаҜӨа§‘вӘ¶г–Ҙд ҙ>дјӮжҒқдЁүж¶”Зҷгҡ ХІеҠҳжһ‘дҗұаІ©вҠ°гҒ•гұӘеҸҙеҒ¬вІ•бқ°еҺ№зҶЎП®дҜөз¶ҷеҫҸгҜ•вқЈеҸҙKбҗІд–ёд”Ҳвј№гү вҒҒДЁжҖ¬жӮЈжҗІвҠ»аЎ•вҖЎб’ҖбқҰ$гңЈiвҳҒз–Әв° д„§гҘўГәв№ҜдўӘаҘ дҮҗеӯЈЗһаІ в °Иҙдү©в»Җвүҗз° гҒ©бҗҖЕөз° д–Ӯз’·зһ е’’а§ЈгҝӣЩҖжҰўВ¬ж»ҹЕ„ЙәгҲЈзҢ д“ жәўЭҗбҒўгҖ°жҖі#зү©б„°г“ҠжҮүв©Ө`бЁ©бҷҒж°Ёд–ғИ Н·вҒ°бө©ж…Ұв“«г„ҘеҒўжЁ б№¶К°еөҡж—”еӯ”жҗЁЭҶвҳЁбқ”дңү4в„ЁгіҸбӣҘбІЁж„»еөҪжјҮжҖҘбҺҰзЎ…бҳўаӘҺв©°бҠІб„ӘеӢ”вј·д“Ўб”ўв®ҺЗЁгІ©б”ўа©„ЧӨдҒӯдҡөбҠЈд–…дЁӯЗӮжүҘа«Ӯе’ӣЮ«д‘ёдӮ„зғҰв§°жҖәж…ўжҡ—вғҗзҒёбӣҠбҚҺд»°зҒҘдҜ» а°Үб©©г“°еҰҶд Ёе…әаёіжұҲбҺібҖібөҮМ“вӨЎг“Қвә…з–ЁгһҺв—ұаәҚд–‘г№Ҳв’әаҙёдёҷб„Ів“®дҖЁе–•ж»„ШҢVеҷғж„–ај ж  бқӨдҜ¶зҮ„еўҚб‘ІжҘӘзҳ¬г‘ӯвўҷгңқжӮ‘г”ҒвӯӨвҸЈдўһДқв§…nдҗәгЎҗг§ҙзҲ а©·вҖ®жү‘вәідҗӘдғІаЁўб№Үд°ҝжҡёзҠүжҶҙбҜ¶зҒ°б–Ҹвёҗб·ғгҺҰдЁ§віӨвү°вңҢ'вЈ зҗІдү’гҖЁдңӮв—ӢгҢқв§ӢгҲ«вң©дһҗЦЎПёзӨ®вҙҒг•ўвө«бҰҒдһёд—үв№Ңб–ҳдҡ°з–ҢЮӢаіҸв№«жҰҒЛӨжҺҸК»Цјж·Ӣа¶ҢеҚёб¶ҚеҮ»ОҲд’ҲбҺҸдқӢвә№жҒ»в®Ғдһӣе®ҹвұӣгҠ№ж»ӣзһҮЩ»дҫӢві»бүҜж»§з„®г“ғЧӣбіҒеҲўН“д’Ҹа»ҙв«ҹбё·г·Ўаҫғбҙ•а»ҳбә“гҷҪдҗ§гҳҚе·ІаҘҖгӯЎж ҙдҒ¬з‘Ҫе»ӨР–бҜҲгЁІз—‘зҗЁжҹҢеӢқcз—ҡаҪ·з”ҲеӮҚа№·вІқеү–Д¶аҙ·з¬ғеҒӢР§з“ғдҡӮаўҸбІҸд’·аҜЁд№ з§јд№ідЁ¶жҹівҝҝгІғвҳ…д·”гәғд¶“вў…з°«е„Ҷд•–гқјвҝ»дҺ‘вӮқдӨёзһўгӘ§гҰӨг…„зӮ®еўҰд»ҡжҢҪЫјвҲғеЎҷд¶ёС д©ҖдқҚгҲ–аҙҸЗ‘РјеҜ№О…е”§бҸ•еӘҖе°¬ж…ӨаҜЎгһӮд„ҫж‘ӨеҮҪбөЁвіҖаұҺЭҚвғ—ДҠаІ®б »зң”б–јг—ҜбІҗе°°в®ӨбҘҹгӨ…бқ№д Ғдҗғж…„дӣұаЎ еҒёбҹ’в·ӣПҗЪөзәҹжӮ еЁўбғ’в© жҠЈж’ҹбҖҗеҳӨДҘЪҮдұ°еһӘе’Ҡз‘Қа§қвЎІЗ°е“ҒгғӮд©Ҷа©ів” зҠҠМҜб„Қв®©ж№„дҘЁд‘ЈгӢүвүҲвҚ¶дғөЭҗеӮӘж«ҚвҠӨжҹ°УҡР зЁҝдҖӨбҒҘв °дҢЁбҙЎаЎұМұз„ұбҶІаІІвҷҶвҺ„б№івҡ’е“ҠеҰўб’өа№№жә©а§ҳе„ӘзЈ“зҘ–гҚ•вҙӘа¶әЧҸбҷ“вҮ•еіҪеҖӘЙҗбІҒжҢ–ЩұвҖәв‘ҠжӢӮг„ӨЭҪвөҶЗәвҹҰзӯҹжӨҒаҪЁаЎһдұ–жҺҖжҘҖД№бҡ¬вЎўеҜҰбұ©д”   \"}]"},"redirectURL":"","headersSize":260,"bodySize":1909,"_status":"completed","_startTimestamp":1775293352006338,"_endTimestamp":1775293352013054},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"555","comment":"","_id":1727,"_uid":"be951ea8-ebd0-46e6-a4b7-419a23160fef","_cid":555,"_ctime":1775293161884,"_sid":69,"_stime":1775293351424,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":34454,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T09:02:31.153Z","time":251,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNkiJg&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkiJg"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775293351153349,"_endTimestamp":1775293351160006},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io",