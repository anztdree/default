ientPort":59694,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:56.303Z","time":340,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiVze&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiVze"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292776303289,"_endTimestamp":1775292776316180},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:52:57 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1272"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":1507,"mimeType":"text/plain","text":"583:4371[{\"ret\":0,\"compress\":true,\"serverTime\":1775292777639,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвһ еқ‘ж ЈбҶ б®¬ВҢЛүвӣӨв”Јбі°аҘҖКҒвҖ№дұҹбң бҶӨдҖ®fznг’ зҳЎзӨ вұӢгҲЎбЁ…ж Ҷдҫ°Г бөҡвүҰзё гҡҒе§ўгӯҳеӮ„аӨ»дҖ¬жҖөдҢҪзЎ¬гҙ‘Ы•еҚҝаӯҺзһөжҚӘдҳ…бёәаҰғвӢһЙ вҷӢд’‘ж…’еҮҳв”„д‘№=бЈідұ Ч‘дҺҗбҶ„г  зҙәбЎҺбҰ аЎҶМҘвҒӮдҮҠд’Җб Ід–ңбҗЁеҝІФҠаҜЈаІӢв’ҙбӢӘеІЎгЈЈвҖ«зҮҘдҜ—Ъ©вҚөжҮ©з”ңаӯәжЎёе‘ҡбјҫа№ҙдӯҖдқҒдЈўЭўг•җдӣ–д©ӢзҚқжҹўеҳӢзұҗдјҮгұҚбҷ—бұ”аҝҡжӮ жўһР бҺӨзҰЎеҮҮдё«а·®ж¬¬б„—дҚҒбҖӘдІҜдҒҙе’ҷжө„жҸ„бұ®аЈ„жҢҙдүЁаӯ„аұҡбӮңЕ«бҺ„б–өжөҜеҢүд®өбҮ•еі–з®ўбі—гҙ№а·—ж§©жіұеӨ°бҹ¬е“Ўд…Өбә•д§Ғг…ӯбң¬дҜҷзүІбқҚд§ҢзўҮдұҲжҚөжІӮеұӢжҚөЙҫеөҺбҚөеҠ‘еҺЎжҘүг—Ҳж–ӢбҠ”Щ»бҺ”ж·Ҡж·…вҸҖжҰ¬еҹ…е«©еӘҺаәӢе—ӯдҰҶдӢӮжҰҚзҠҪз ®дҒҢЪҘзҺ§еҰЁз°ҚеҰ„гҸҖв®ғвҰ…еӢҚвҹөаӯҘж·Қвһ•аіІеҸҖбӯівҺ‘гҡ©жҘӯе”ҷеҘ»г·Қдҝҗд№“ж°’ж¬»жӨӢз«һбқ»е“ҲгҘ‘Ь№б©Җаәғе»әбұ…аӯға§°зҠәзһӨз“ёзң–жңҮеҙқгҺҰа «г§ұгЈҹв»«г§ҘгҸҷЖӨб«јзқјбҪқдІҮеҷЁжҘӣдҫӯзјЁеҲЎЧҷжө°дҰҗе№“в«¶Пҡе»ҠжЈҫеү»гҶҢж¶Јг№Ұа·©вҷғжіҷаӘЁеҶӨаҜҜаҙігұҲзҰҫгҹ„г°§гұҮзЈұв”…жұ…б¬ӮЖҮвҹ еіҷб©Ңеөһв¬Ҳгө—вҹӯеІЁж№Ҹд“©аЁүзЈҜг”јеЁҹЫЁМҜгөҒНҖеІҢеҰқвҹ«е„үТ…жёҢбө…дҢҳдёҫжҗҗеҚҲвҸҳд—ЁбҚһг’Ҹг•Өз•„дҙ“бӘҲд·„жҡҒгЎЁзҠ¶вҠёзәҲдіҲдІәвҙіИҮеҸӢвҠҲжҠ„зҺҖбіёе„¶жұӣД…жҚ”зҫҮб”§бәҢбөјжӨҮеүҮДҺбҸңж’әбЁҮб„ҚеҢўжәөгүҲз•ҒеІ§бј„жө¬е–ҝвҚӮж–№еүҸбі…гҙ“аёүгІјдөҢгӮҝа°Үв ә,бқЎе°ёДҳ[ең Г¶б ҪдҺһбәҜеҢ жҹҰеғ е°өЛҖвҲҙдҖ зҚҡе°ӣз©Ҷеұ“бЎҰЛўж«Ұвҗҳб¬’вІӮзЈҶвҘ—ж„өаІҳе„ӣа®ҷбҘӣДҳе‘ӯвҙҳеҪҰаәЈбЎҶПҙб¬һеөігЎӘе‘ЈбўҶЯ—еЁЈеҖўбІЁвқ¶вҮҡжЈҝв©Һд°ҢзҮ°$б• в¶…вҪҡзөЎжҝ дЎҺМҠгҖҝХҒж№ҶВӣг¶ҲГ„еҺӢа ӯг¶¬е ҷа©ӣгҲ„д®ҹбӢ«в—ңжҡ°бӯӯвҶӣзҗіНҡг“ҠзҡҖб¶…в  бҠҲбҙ§бҗ ХҪПҙвҡҘеҮ”г»Ҷе„іеҲҙдҫізҠөзҹһвҲҝКһЪ‘е‘ҢвҖ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":1272,"_status":"completed","_startTimestamp":1775292776638081,"_endTimestamp":1775292776643413},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":1008,"_uid":"800d934a-4a4a-4253-93fd-9d6b2f2995d5","_cid":338,"_ctime":1775292633694,"_sid":90,"_stime":1775292776303,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:55.934Z","time":261,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiVtt&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value"