name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":1935,"mimeType":"text/plain","text":"721:43145[{\"ret\":0,\"compress\":true,\"serverTime\":1775293083294,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁЙҗбғ¬гҖҰжң жЎўдҶ¬жҖ©гҖҫжҖҪд„°ОёжҢ бҠӘгҲЎбў°бӣӨвёўе°ҰгЈ а§ бү©еҠ гҢЁзёҙв‘ЁXДёЖҲЕҷеҲЈеў»жҗЎгғҚд Өжһ·бҫәг№ Міг”үвҗ»з ЎеЎҰж’©жӨҢдҡіШ°ж•Ҷв”ҷгҠ°д“Ҡвһұа ўе  жңҳдҙ°д—ңеӢ©дҢӯаЈҙзӨҲг—…а©ҒбғҪбҸһТідҷҰeд¬»а¶җВҺзәҺвӨҘб„¶вҖ§вҷ’г Јз”ҷаіўз  гӣ‘е«ҮвӯӮеғөдўҠж·ҚгүүжҺӢг–°в‘»ЗұеӢұжЈҲд—Қжӣ¶а¶ғаәЁе©©гҘқвұ°аөҸвҷҙв«“з¬ұжң‘д•әжіҒеҲ¬вЁ–дҡ•еҳ§аөӯжіҢдЎ…вӢңеҺһдӨӢб‘ҫдҶ»вӮұдҹҶз®үдҷ№б’ҶгӨүбӯҷеЎ…г©үдҘҖдҝӮб¬№аЁіеӮғеҚғд®ғб©ӘзҰ•вҪ№бҺҚгӢӯа©Җдӯўд§қгҳұбҲҒжӨҘНЎе¶ҚдһҲдҚӣКҒж®”аё§аҙҖзҚҪзө°в”ҚбҰүдҷёгәҚеҘҪжқӯе¬ӢбүҲзёЈд°ІбўҲг©ӢеҺ…зӯ©дҶҢгҡҠеӯ…вӮ¶г«Ҹб”ҲеҪҺд•§Эӯзқ№еұІбҠҪвҺғСЁеғҲг’·еғҙе“үж¬ӯб®Қг–Ёж¬ҜвҘҫе®ңвӣҸеҘҲг©ўеҚҗвҡ°дҗҙжӮҪаҜӢж®Әд’өгЁ„а®ӯзӯөб© вққдҷ«дӣ№е—ҶжӯҠг«ҸеҜ§дҘҒд«№б•ӣж®ҹеӨ»еҖўеЈҚбЈ¶гўҪеј‘д•ёеӮӯв©·г«©еЁӢзӢҘбөҫвөјвҺҚд”…д–©гӘӢбғҢаў®жҰҫд»’б»ңвӯҝе»ЁеҚјж¶®дҜһбӘја¶»гҳҚб–»б“”жүҹаёӘбҮҢвЁ·зҠјжһ•д©јаӘҪдҰ®еӣҜеҙңбӘ“гҪҹбҹ–д…қгӮіжЁҙдҚҫе°ҸзҰ’ХӢд•ұеү¶еҢҖбӢ»аё…К·аҰӮжҠ’бҖҖз’ўе©ӨеіҜа»Ұеі–д¬‘жҡЈбҗҮбӨӢаІӮаіҗвқіИҘбҫ°в№„е№°вҠ…еҙ¶вў§бҗід ӨдҖҮз“№дҶ“дүғд•ғеЎ°е®…ај–бҢ°з©®еұұбӣӨеӣЎаІӨдў„д№ібӯҰз°Ҝеӣўз№–дҘҮгҷ¶е¬өаІқбІҶбҠ—бҒ‘ж«ёе’ҙз…®дӣІзӣәдҘҒеӘқбөӯаЁҘа§ұвЎҜ6жұ«бӣөеўӣдјҶж©”еӮ¶дұёвҜ–дўқд»ӯеў’бі“вӣӨдҝ…жў»б№ІжҠҘбӮҙб“ёвјҶе»өбҪ“Ь–а°ІгҡІдўҒг»¶еҫ„д««аұ§аҘҮШғаЈ е№·еҙ–а·өвҘһгҰөд°ЎгҠіаұҲеӘөгіӘД®д–Үбҝғб…іа¬®віқб©ұгӘ—а©ҙж°®б№өжў„дӮӘз“ҪаҘ°вІҘИ•ж…¶дәіФ®бЁҒвӘғбңідІЎв”„б©®еӮұбүӯеҒҚз§«е••біқбҹ…жІҷе·“дҙҶ4б©«в©өбІһв№ІгҘІеғ–жҶқвҲ’еҘЎв—өж№«е«ғв°ұдЈ·а¶»вә·аЁЁв–Ҷд¶ӢдўҮб°Ҝгғөд№қаё°дҡӢб…ӘвӘқаҰӘвіҫдҪіж¬ҳе–ідІҸеЁӮгңҶб„ідІ®дҶӮдЁ«а ®еЁ дқҗвҲјгҘҒгӨ®біЁгө¬д§’еҘҸајҮеіёеӯ¶вӢ–дұўгҡӮбӮ·дІўдҲҸбіҜГғдЎ¶вёұШҝгғ„зІҰдҳҶгҸӢб°әвӣібҺ®жҢҷдҲҲвәҘа§–вЎ¶еҲ•вІҒг¬ӮзІһбәғдҷқб’Җгө©б ҢеіҸбҙ–бүҺе’үгұ¶дҹ¶СҳзЈ–дҷҝаҙҖе•ёеҖҢдӘҚгјҖв»©аәҖвё«в°ӮдүһејҮж°ҸеӨ¶жӘға¬ҖгӨҮбҫғбҙ–е“Һе“ҡбөҙзӣҠбәӮеІҙжҫөеӨқаӨЁж—–дҲіг–ІжҙҮа°Ёд„®вҙ—аҘ°в©ғбҲ’еӘ»е Ӣг–ӯгӢ«ж«Ёв»Ўд§Ӯг«ңдөқЬҪвіәдҹҒМ§Ъ°Р–жҖӮзҚәбүұд—қж…·а©ҷв—«з«–аёҮдіҶвё®ж°Ёв„ғзӯўгЎ…еҳҪбҙігіқбіҘЙӯеҳ“зҗӨе’„вёівҲ—г”§В”аі«бҫҶв“Іе’…вўҗзҸ„зҳҝбіөдіқЗҗг¶ҘбҺ•гҜЎб¬ҖжҷҜзҷ®в°Ёд»¶ДҘзӯ»зЎ–дөӨзҳІжЁғбјҖNдҖўзІ   \"}]"},"redirectURL":"","headersSize":260,"bodySize":1582,"_status":"completed","_startTimestamp":1775293082300882,"_endTimestamp":1775293082311501},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"477","comment":"","_id":1382,"_uid":"0cda0297-0106-488b-9488-f35ff4e21170","_cid":477,"_ctime":1775292841240,"_sid":78,"_stime":1775293079147,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":57404,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:57:58.782Z","time":256,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNjfpm&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"428"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNjfpm"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"postData":{"mimeType":"text/plain","text":"424:42144[\"handler.process\",{\"type\":\"hangup\",\"action\":\"startGeneral\",\"userId\":\"33cabb81-987d-4712-81c8-0d88b4c63132\",\"version\":\"1.0\",\"team\":[{\"heroId\":\"c9fe56ad-acf1-4a16-bd75-3c25d725856d\"},{\"heroId\":\"56516d8c-d2ae-42d9-bd1c-46720d0bb67f\"},{\"heroId\":\"32da4dc9-1511-460e-9346-fe31d4a0e4a9\"},{\"heroId\":\"3af5ef3e-ca46-4c1f-a833-54b09cbd3ca2\"},{\"heroId\":\"0d89077c-2f17-4098-a8c6-33f7d656aa88\"}],\"super\":[1120561],\"battleField