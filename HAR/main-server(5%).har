t=polling&t=PrNik6A&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNik6A"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292834196626,"_endTimestamp":1775292834203059},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:53:56 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2541"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":3117,"mimeType":"text/plain","text":"1160:4388[{\"ret\":0,\"compress\":true,\"serverTime\":1775292836348,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖӨбҖ©жә¬Гӯзў б— гҺ¬а¬ дӨ бҢӘГ¬з…Ҳд ЎаІ„ВҗЙҗЛ°К“жҗ§гӮ®в ўжғёеҖ©діүв•ңзҠ ШұзЁ’гҠ”еҖЈгҺ¬вј°г·ібҒҝаҰ’д’ӘДүжҹҳДҡе‘җбјўбҗҫвүҒжҒҗзӮҗг’•д©җМұЫҺе№ЈдҫҢеҶұгЈЁвІ„гҒЁб„ёаұҡг•ұвҫҺаӨ§вҶӘб…ғеҮ‘зЈӨзҠҠвқҪбҰҪдЎ•жһ»зҢ«д—…зҢҺб ¬6ж” З’в„¬Д„дЈЈгЎӨвҖӨвҖҗГәгҗ дҘҡ!зӘ еў“вҒ„вҖҗаҪқгҗҘбәәИүгә е…ҘгқүбҡһгҲ ДІвҸҒдҷҖ$еҗҙаҪҗжһўг‘’бҹӣМұвҶҙгұ°ж№ҡКЈбҒҲ]С…д„ҖбҒ°вҰҒеЁЎеі–дҖҘвҘҙа  вІҳжҲЁдҷӨе…Ёб  ајҺбҖЎвіһбҗҙд“ҖДңбҷүЙҖЖҷзҳҪб• г…ҷзЈөбіЁе„үжҳҪЭӘзҖ°вҠ”аҫ®бҘҖбҒҒбҠі бёЁг¶ дҗғбҮӨа№ҖЙұдӮҠгҖ«ПЎдҖЁбӮ аұҒГҖжҺҷдғҰе—Җ5гҗ·вҪ“д°ә7жӣҢеЎ”зӯқдҫ¬ж’°в‘ҷд«…жЁ‘бҗ«еқҮдўҖг”Ўд«ҒеЁөбҡқдҚҖШҖеҒ•в…ўг©Іе®қеі„г®Ҫеһӣе–°в§қз©ҝеҫҖЯӘж„Җжү—зҸҶзҺҘа¬¬Еңдә ЗЎеҖ©ОҙЕҖаҰ <еҖЈж””ЕЎд«Үгә‘ в”ӨжүқжҖЈвҘҖжҢөгјҖJеҖ г—Җб°®зЎ зҒЈФ©дҗҒв‘ЁеәҘбҒҳбёӨЭңеҶҮдұ°жӘҜв„ўж• зұЎзӮ©бҠҷбҘӘеҗ„зІҷвҸҮб‘”НӮд№·аЈӘжёҜбҹЁдҙҘж…ёеј§бҘ…жҘјеғҲвӮөб–һеҳӨж«әеқ·з№Ұеҳ в„ҳеі§а ¶дӮҰбҗәФЈеү’аӨЈвЎЁНЎг©ҡаЎҗгӘӘбј¶з©’СӨеЎҗФ бӨ–бөўвҒҡбӢҮЪЁбҳҜдҮҠб„®вҮҲгқ жҮ‘д¬©жҶҳвЈ„бҮӨг№ҘбҮ№е’ҮгұҗЪғд°ҙбҰҮві»бҖӨгҙҰ1еӘҖЭ„жЁ бҳҳжҖ©вү°гҳўг§•гң—'аЈҗвҗІдҜј:вҗЁЭӨбҠЎЬўРЁд…Өа№ҳгҒҰаҙӘж…ӨвҠ©е„¬вү«г…ңв«ғзқӘаҫҡзҰһвҙҷа©·жҪҖгј№вҪҠб–…в«Ҡа  б—Ҳз”ӨаЈҖд„ғвӮ аұівЈӮвҙ°аұ§дҗҙбЈҒбҠ…ВӮбө„бә§жҰғЭғгҗҙбҒЁж‘ҙеұ°бҗӘдЁ№вЁәдң¶еҗӨеҝғбӢҙеӨҲбЈ¬еҺӮзғёжҮҒзҠўеҢЎа¬Һб®№зЈҰжҲЎУӯд—’nдҸҖПӢдЁ гҝ•вҖўзүҜдӨ·аЎўжүҳаҜ§еұўаІҶзҡңаҘҙдұҫбў–бҰғдҲ·б§ҖеҖўб”ә#гӢҖВҙвЁ вә“г–ҫд•‘г¶јзҒ”бҺІзҢҝГ„б‘ңжЎҫзұ б“ғзҸҹг°«з°ўдӣҢа°Ҷаә®а« з°Ұж‘№вұұвӘ°ЖҰж®„гҠ§К°аӘЈеҮӨа¶«аөҢЬ¬еҒӨвӨІбғ„бҲ®бҒ№в–®вӢӘзҒҡЬ°ж№©ЯҒжұӣдҘғвүңдҡ”в©қбҒ‘жҠҘдҳЁбғЈжҚҶбқ°еҠҡеҪҙв¶«в¶ҢеЈ–УұвғҶв№Ҹг  гӢҖдһҗвұқж“ҷгіҗбҲҒвҗёРҚОәжҙҪвҡ„б’ еҺөдөҘвқҪд·ҘбІөжј…в№ізҸӣвӢ„вј’еҫҝд°қЖҖаӨ«зҖҫеҗ«вҒ©е’ЈгҶһб”…дө¬Эҗжҳ¬ЯӨбұ–дҮ°Ф№д•°бұӮдӣ°віҒв•ўШҰд„ҒжҳӘЕЎеЈҘЯ—дҲҳдҠ–в»»еӨ–е»әдҳ—зјӮдҗҜз’Ёг¬®бҮҪб§ӯгІҹаЈҷг¶–жҗ зӘҫдҖҝе¶ҲЕӮзҢӣг®јвҖҰеқҷд„—бөібҒЈаҰӢд®ҖеҺҢдәӣвӨүб·–в¬өжӢҢдғўгҰ§еӘ·е©ёвҘ§жүЎзҺ·аўје¬ӢгҰҡзҳ•вўҰзҹ©зјһдҖ“бҜҝг Һз·ҶеұҘд”јЭҰд”ҢдөҳеЈ—еЁ№еЈүбӯүг©Ҳб„ӯЬјб•ЈаҪ–е…ӨдһЁЮӣзҖҮдӨ¬дҶ…аөҒдЈҮзңҜбҫ·зіҰеҝ—з»Јжҫ®гЎ“бәҶгҢҘдҗҠжҺЁvбӨҠж”Ҷв¬ӮДҠдҢҗжјҘг—јбјҖаҙҜжҲңбҗЎвҰ”ДҖгҖўж№Ҷвӣјд«°ГҷзӘ аЁ а° жҘҷвҖ§е»Ҙг®№ж¬—б§Ӯж¬°ВңбЁӮз°ЁР”дҪізӨ·дёӢбҹүеҰқЗ’е¬Ёеғ–еҚЈеғ‘вӯҒаЁәжҲҢГЈг·Ҳг¬„бәўЪғBбқЈг„ҳдІұзўҙгІҸдүҳдӘҘаӯҖаІЎаӨҷМұаӨҪжЈҡОүгӨ«жӨіЕҘб‘Әд—ҡЭіжһҺеҖ а©өд“ё)вҗ дөӢвҖЈДҠ8жөҗЖ¶зә ајңеҺЎ/бҚІбү§в№ҚдӢ ж¶¶д„ҳcШ¬дҮјбёЁжҙ©жү¶дӯ„д“Ҡж·Ҫзҷӯд §дҠівҘӮдҗҲгЁ·б’–вӢ©з¬Ұг“іжҜҢдұһИҮе–Өе»‘еўқбЁҘвҪ°еқҫдЈҠгҗҰРӯвЁҘЗӨбЎ“жӮІб ёгӯӯжЎёдҚҗгӨ®аё¶СұдёұвҒҳбјІжҺҙдҒҹа ҘвЎҰдәүг„ҖдЎӮа»Ідҳ·гұҳбҜ„ж‘Ҹв ҒГӘаІұд»®зҖ«дә¬жҫҪЙҜе‘”аҫӮWж№°ИҒЩҮ`жң№дөІб¬ҖбёәЬңгҝ§еұәЪ¶.е—ҳгҶӯаӨӘж—”д¬°Iвә а»Өг…¶бӯҚвҶҳдҰҷвҘҲзЁ‘бҘ§ж¶¶аЈәвҗҙбўӮбҒүеҜ„вҘҮдғқвҪҪз‘·е®§жҖёв¬җеҝұеҚ»гҒҖе‘ғеҮҚЛ©дЁәзө№бқўзӮ®вӨҲг·’ж‘Ҳеһ–жҠ«з”ҶТ°жҚҸа®үб№ўаҰ‘б‘„аәЈбӢёжғ…ТҜдӘҹж‘°дӨ№д №г Ұг«ҺжҷҖвӣӨВҖбІҫжҲ гһ»еҖЎд“і2аәҚвІҗбҖЎвҢҺХҢЛҪГ‘бҘЎжқӣжҗ°д–өзҙҹдӯ¶бјғд‘җжҲ«е’ЈбіӘбӣ°вӘҫдғібҖҜеӮҪгһҘзҜҢвӨібүідҪЁж°°ОЎг¬ дӢӮеҖ