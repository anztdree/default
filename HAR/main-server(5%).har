6.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:55:56 GMT"},{"name":"Content-Type","value":"text/html"},{"name":"Content-Length","value":"2"},{"name":"Connection","value":"keep-alive"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":2,"mimeType":"text/html","text":"ok"},"redirectURL":"","headersSize":214,"bodySize":2,"_status":"completed","_startTimestamp":1775292955319098,"_endTimestamp":1775292955323197},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"498","comment":"","_id":1212,"_uid":"10e5ccbd-a922-4f69-8507-13278092dde6","_cid":498,"_ctime":1775292900298,"_sid":21,"_stime":1775292955062,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":47456,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:55:53.821Z","time":1524,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNjBJL&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNjBJL"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292953821328,"_endTimestamp":1775292953829437},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:55:56 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2543"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":3118,"mimeType":"text/plain","text":"1161:43117[{\"ret\":0,\"compress\":true,\"serverTime\":1775292956325,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖӨбҖ©жә¬Гӯзў б— гҺ¬а¬ дӨ бҢӘГ¬з…Ҳд ЎаІ„ВҗЙҗЛ°К“жҗ§гӮ®в ўжғёеҖ©діүв•ңзҠ ШұзЁ’гҠ”еҖЈгҺ¬вј°г·ібҒҝаҰ’д’ӘДүжҹҳДҡе‘җбјўбҗҫвүҒжҒҗзӮҗг’•д©җМұЫҺе№ЈдҫҢеҶұгЈЁвІ„гҒЁб„ёаұҡг•ұвҫҺаӨ§вҶӘб…ғеҮ‘зЈӨзҠҠвқҪбҰҪдЎ•жһ»зҢ«д—…зҢҺб ¬6ж” З’в„¬Д„дЈЈгЎӨвҖӨвҖҗГәгҗ дҘҡ!зӘ еў“вҒ„вҖҗаҪқгҗҘбәәИүгә е…ҘгқүбҡһгҲ ДІвҸҒдҷҖ$еҗҙаҪҗжһўг‘’бҹӣМұвҶҙгұ°ж№ҡКЈбҒҲ]С…д„ҖбҒ°вҰҒеЁЎеі–дҖҘвҘҙа  вІҳжҲЁдҷӨе…Ёб  ајҺбҖЎвіһбҗҙд“ҖДңбҷүЙҖЖҷзҳҪб• г…ҷзЈөбіЁе„үжҳҪЭӘзҖ°вҠ”аҫ®бҘҖбҒҒбҠі бёЁг¶ дҗғбҮӨа№ҖЙұдӮҠгҖ«ПЎдҖЁбӮ аұҒГҖжҺҷдғҰе—Җ5гҗ·вҪ“д°ә7жӣҢеЎ”зӯқдҫ¬ж’°в‘ҷд«…жЁ‘бҗ«еқҮдўҖг”Ўд«ҒеЁөбҡқдҚҖШҖеҒ•в…ўг©Іе®қеі„г®Ҫеһӣе–°в§қз©ҝеҫҖЯӘж„Җжү—зҸҶзҺҘа¬¬Еңдә ЗЎеҖ©ОҙЕҖаҰ <еҖЈж””ЕЎд«Үгә‘ в”ӨжүқжҖЈвҘҖжҢөгјҖJеҖ г—Җб°®зЎ зҒЈФ©дҗҒв‘ЁеәҘбҒҳбёӨЭңеҶҮдұ°жӘҜв„ўж• зұЎзӮ©бҠҷбҘӘеҗ„зІҷвҸҮб‘”НӮд№·аЈӘжёҜбҹЁдҙҘж…ёеј§бҘ…жҘјеғҲвӮөб–һеҳӨж«әеқ·з№Ұеҳ в„ҳеі§а ¶дӮҰбҗәФЈеү’аӨЈвЎЁНЎг©ҡаЎҗгӘӘбј¶з©’СӨеЎҗФ бӨ–бөўвҒҡбӢҮЪЁбҳҜдҮҠб„®вҮҲгқ жҮ‘д¬©жҶҳвЈ„бҮӨг№ҘбҮ№е’ҮгұҗЪғд°ҙбҰҮві»бҖӨгҙҰ1еӘҖЭ„жЁ бҳҳжҖ©вү°гҳўг§•гң—'аЈҗвҗІдҜј:вҗЁЭӨбҠЎЬўРЁд…Өа№ҳгҒҰаҙӘж…ӨвҠ©е„¬вү«г…ңв«ғзқӘаҫҡзҰһвҙҷа©·жҪҖгј№вҪҠб–…в«Ҡа  б—Ҳз”ӨаЈҖд„ғвӮ аұівЈӮвҙ°аұ§дҗҙбЈҒбҠ…ВӮбө„бә§жҰғЭғгҗҙбҒЁж‘ҙеұ°бҗӘдЁ№вЁәдң¶еҗӨеҝғбӢҙеӨҲбЈ¬еҺӮзғёжҮҒзҠўеҢЎа¬Һб®№зЈҰжҲЎУӯд—’nдҸҖПӢдЁ гҝ•вҖўзүҜдӨ·аЎўжүҳаҜ§еұўаІҶзҡңаҘҙдұҫбў–бҰғдҲ·б§ҖеҖўб”ә#гӢҖВҙвЁ вә“г–ҫд•‘г¶јзҒ”бҺІзҢҝГ„б‘ңжЎҫзұ б“ғзҸҹг°«з°ўдӣҢа°Ҷаә®а« з°Ұж‘№вұұвӘ°ЖҰж®„гҠ§К°аӘЈеҮӨа¶«аөҢЬ¬еҒӨвӨІбғ„бҲ®бҒ№в–®вӢӘзҒҡЬ°ж№©ЯҒжұӣдҘғвүңдҡ”в©қбҒ‘жҠҘдҳЁбғЈжҚҶбқ°еҠҡеҪҙв¶«в¶ҢеЈ–УұвғҶв№Ҹг  гӢҖдһҗвұқж“ҷгіҗбҲҒвҗёРҚОәжҙҪвҡ„б’ еҺөдөҘвқҪд·ҘбІөжј…в№ізҸӣвӢ„вј’еҫҝд°қЖҖаӨ«зҖҫеҗ«вҒ©е’ЈгҶһб”…дө¬Эҗжҳ¬ЯӨбұ–дҮ°Ф№д•°бұӮдӣ°віҒв•ўШҰд„ҒжҳӘЕЎеЈҘЯ—дҲҳдҠ–в»»еӨ–е»әдҳ—зјӮдҗҜз’Ёг¬®бҮҪб§ӯгІҹаЈҷг¶–жҗ зӘҫдҖҝе¶ҲЕӮзҢӣг®јвҖҰеқҷд„—бөібҒЈаҰӢд®ҖеҺҢдәӣвӨүб·–в¬өжӢҢдғўгҰ§еӘ·е©ёвҘ§жүЎзҺ·аўје¬ӢгҰҡзҳ•вўҰзҹ©зјһдҖ“бҜҝг Һз·ҶеұҘд”јЭҰд”ҢдөҳеЈ—еЁ№еЈүбӯүг©Ҳб„ӯЬјб•ЈаҪ–е…ӨдһЁЮӣзҖҮдӨ¬дҶ…аөҒдЈҮзңҜбҫ·зіҰеҝ—з»Јжҫ®гЎ“бәҶгҢҘдҗҠжҺЁvбӨҠж”Ҷв¬ӮДҠдҢҗжјҘг—јбјҖаҙҜжҲңбҗЎвҰ”ДҖгҖўж№Ҷвӣјд«°ГҷзӘ аЁ а° жҘҷвҖ§е»Ҙг®№ж¬—б§Ӯж¬°ВңбЁӮз°ЁР”дҪізӨ·дёӢбҹүеҰқЗ’е¬Ёеғ–еҚЈеғ‘вӯҒаЁәжҲҢГЈг·Ҳг¬„бәўЪғBбқЈг„ҳдІұзўҙгІҸдүҳдӘҘаӯҖаІЎаӨҷМұаӨҪжЈҡОүгӨ«жӨіЕҘб‘Әд—ҡЭіжһҺеҖ а©өд“ё)вҗ дөӢвҖЈДҠ8жөҗЖ¶зә ајңеҺЎ/бҚІбү§в№ҚдӢ ж¶¶д„ҳcШ¬дҮјбёЁжҙ©жү¶дӯ„д“Ҡж·Ҫзҷӯд §дҠівҘӮдҗҲгЁ·б’–вӢ©з¬Ұг“іжҜҢдұһИҮе–Өе»‘еўқбЁҘвҪ°еқҫдЈҠгҗҰРӯвЁҘЗӨбЎ“жӮІб ёгӯӯжЎёдҚҗгӨ®аё¶СұдёұвҒҳбјІжҺҙдҒҹа ҘвЎҰдәүг„ҖдЎӮа»Ідҳ·гұҳбҜ„ж‘Ҹв ҒГӘаІұд»®зҖ«дә¬жҫҪЙҜе‘”аҫӮWж№°ИҒЩҮ`жң№дөІб¬ҖбёәЬңгҝ§еұәЪ¶.е—ҳгҶӯаӨӘж—”д¬°Iвә а»Өг…¶бӯҚвҶҳдҰҷвҘҲзЁ‘бҘ§ж¶¶аЈәвҗҙбўӮбҒүеҜ„вҘҮдғқвҪҪз‘·е®§жҖёв¬җеҝұеҚ»гҒҖе‘ғеҮҚЛ©дЁәзө№бқўзӮ®вӨҲг·’ж‘Ҳеһ–жҠ«з”ҶТ°жҚҸа®үб№ўаҰ‘б‘„аәЈбӢёжғ…ТҜдӘҹж‘°дӨ№д №г Ұг«ҺжҷҖвӣӨВҖбІҫжҲ гһ»еҖЎд“і2аәҚвІҗбҖЎвҢҺХҢЛҪГ‘бҘЎжқӣжҗ°д–өзҙҹдӯ¶бјғд‘җжҲ«е’ЈбіӘбӣ°вӘҫдғібҖҜеӮҪгһҘзҜҢвӨібүідҪЁж°°ОЎг¬ дӢӮеҖ°вҒҸб“ҘзҰӯд”ёеІЁд ҪжӮөв‘іж”®б…Җа¬ЎеҗҜв¬ёД«аӘҳвӮҒзҒўзўұд”ўбҗәаҜёг’ўжҗіжҒЁеҫҠг°ҰЬҢгҲ®бӮҙаІҶбҺ’гҹёв©ЎаЎ”жЈӯві°еӮҙеһ»Ш°е®«гӣ·жҰЁеһ•г ®жұ К»дЁҢвҶ„В—еіҢЮјзқіаӯһВ¶г•¶дҮЁж„ г«–бҸҒТӨвЎөЯӢа№Ӯд•ўвҷ„гүҰдҘҙдҷңжІҙзЈ§е№Је‘Ңбӯ•бұҸгҰқгһ з„Өдҳ…бёӢжӣІжұўб«»дғҶз«Ҙв©¶гүҪз… зұЎгҒәаІқаөӢбҖЁе•ғбӨјдӮ„зІЎвҖұН®зҰҰаІ…вҫӣжІЈдӮҝвҳ”ГәвҸһз№ЎвҒҸжјҲвҙұеӮҹеҖҰд ®ЖҘв«ҘдҒҝвЁ ИұеҖЈзөіЭҗДӘдӘҗб«„гҠ¬ЖұбјҖBд•ібҜҒдў®в®–дәёвҹөТ°Ф«еҹҖз‘ҒдҢӘгҮҙг‘үз•Ҹа§”зҙҝвҪҘбӘҫд–•бәҲвҠҲ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":2543,"_status":"completed","_startTimestamp":1775292955341039,"_endTimestamp":1775292955345348},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"477","comment":"","_id":1211,"_uid":"62b8095d-4598-482d-9f7a-0f567b2f1b16","_cid":477,"_ctime":1775292841240,"_sid":40,"_stime":1775292953821,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":800