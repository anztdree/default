"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292753046853,"_endTimestamp":1775292753054951},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:52:34 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2295"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":2811,"mimeType":"text/plain","text":"1042:4354[{\"ret\":0,\"compress\":true,\"serverTime\":1775292754838,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЖ№жүұбҖўбЈЁДҖТҖЧҖФҮд ®ж„јеҖҘдҮ‘вҖібҘІдӘҷж” аұғзҗ„ж”үвҖҰжңёе№ҖжҜҠбЎұа«“аҜҸж°»бө°Ж»дІ…гЁәзӯ°зІ¬ФөвІғбҖҘгҖёдҳӮд¬‘е–ҳдЁ·ФўК®жҶ ГӢв„ҒзӮӘЙ¬вғҸТјдўЁеҖЈеҺ№еі°аЈҖВқгЁёе„»ж°ҸзҚ¶ЪҘз‘ғдӣұеў»вҠ’г•қбҰ°вҶӢГ ЖҢе„Ңв‘№жҹӮа®ҰгҪҳе№№дҖЎж’°зҸҘбҖ ХҖЗ”ж ЎбҠ”#з”Ўг„ҶjвҒҶд«°ШЈеҗЈа·ҶЖ¶зә з …г¬үбҫҗзҖҜбҖІвҠұеҗ В ВҙаҰЁвӮҚаҜ§з„ҶбҘӣД§вұәвҫЎж…ўвҙЎбҡЎдәҮб ¬бӣӮдҫҒж§¶б„¬аҜ еӮЎвҒіа· а§°дҒ°бҳ LгҒҖвҳ®вӘ°жҒәгҙ гЁҒг’Ұв ·б¬°ЙҰгҫ°Ьўgгң©ЮҖзҖ°бҒҒд іаЈӨеҒӮЩғгЎ зңҙдһғаЎҲ:ж—ҜеҢ№г№ еҗЁаЁ зқ„bбҢ‘а¬…гҖ©дҒҮгҮёвӮ•Ш ДЁдғғд°·б‘ҠдӘөгҮҙШӨзӢҷеҲҫжҶ жӣҖгһ§вң°еҒҶвҖЎз…Ўж§ўжҚҖаӨұД гҠјгәҢеЁ жҶӮЖҢвҗҗдғ“гҶәвҢ°жҙҠгқҚж„ІвҲ»е„ҙв’іаЎ”гҠЎд–ӮгЈңгұ®еҜҖвЎ’К Піеұёб“ӢеҘҷвә гқҚеҖЎв©Ізңүж№‘Йғб…ҲеҲ¬аІүж§¬еӘҙа ЁИҳЙІС М’б”ҡаәҫжҸ§дұҡгјҗзЈұе®“бҲәдңҺз®¬Р гёҪдңіе”Ҷг®јбҹ•*ж”ӨеҮ·д·¶зӮ„вҘҙдҖҸгӮҜаЁҢР„в…ҺдҶҳбӣЎВӨвңғГғИӘеҮҶбўҢвҶӯ$еҶ бҙё1е°¬Ъёгһҙе‘үгҖўУҘеЈ”жӣ©гӨЎвүҲаЎүв„ вҙ¬Мҳзғ‘вӣЈгў”жғ Ьұа№ҲЩ”ж–ңJеҫ аӨңгӘҙеҖЁЦ«жҶ”гҲЁжЁұд„ӨРІеҫҰдұІвЁҘдҮ“dжҖІд„§бЈЁгЎҗаўҖаҰўвҖЁеёӨжҰ”в‘ӨеӢ«а«ғжӨҰвҚҰдіӨб¶ЎаӨңгҒ ВҠзҗӘВүжӯ–жҹ№Д№бЁЁзҠ в„ңе ҙдҒ№еқҺд“№гӯҖв–ҷе•җвҲҷЩӮжҗ е…ӯжҗҙеЁ°еҲ„з№ д Ів•ҷж ¶аіҚбҡүдӮңдҮ«а©ЈжҸӮв’ҹЦӘд¬үдғӨд‘ңеҠЁдӘҖбҸӮе’‘ЗҒеүөЩөжЈҘб–№е•җВ¶б”ңдҰҳвў•д»§аҰҖжғҗжўӯаЈҙГөа°Ұб‘ӮеҪғвҷҡв»°жҒјжҹҙб’®вҺ гғівәӢбЁ©бӯ‘жҷәж° б»Ҫбўҗгі«е© вҠ©еӘҶб§Ҳз‘ЁжіҫР вӢҳе’өгЎңЮ©еҢ©еҚ”бөӢвүҢИҘзһҖжӯ§жЈӣдқ®жЎ Vе—Үг‘”вғ§аЎңг®Јдұ„вҫҲГҡдҸҺд ңд·ҝз’Қз Өаұғзұ”дҒ з’“з‘©а»әеӮ з– аЁғз§ аәғв’Җзҗ°еңҫЛ”жөҡз“қеҜҺвЎқаҘӘвЎҖеҹ…аұіаІӢз ’еҝҹаёЈж·–еҰЈаҘғеҲёжўҺдҡ°еўһаөғгҹ‘бЁ«вӘҮаҫіз—Җд·”вҠүг—ұгҠ‘в¶ғПҷа»–зӘҺдҷ“бЁЎГӯг©–в¬°гҡүзҗ№вә…еҸқеәҠгҖ“аҘұвҫЈжҶ”аҫЈзҶҠаіЈгўһОЁд’ҷа·»ЦҮдІ”вІҷвіӣдҠ“е§Ңг„ҳбәЈжӘҷа°ІдҺ’зҗЁвҡ–д“”а®ҠжІ“з ҫжҮқбӨ‘бҫқЖ—б»ӣбҸқж¶«дў’вөӮбҰһ8зҫһв·ғеҙ”б¶ӢеІңбҝӢдӨ„дҪ§е––бёӢИҫбҒҪжҺ“е•·бҡ’ж№қдҙӣбҫ“ајҸбөӣгҝҗе¶ҚжҢ“аІӣгҢӣжұҖгҫҺвіғв„ңгұ—бҡ»вҪҜбңҳдәівңһе·§ИҫжҢ—вҜ„жјӣдҲғбҪқеҲҺжҫҸзҙҷжҫҸвӮ„вҝҜбҠ«жө«д¬Үвғ·еҳҺеҝҸжІ‘еіӢдӘңаұ•д©ҷзҫ®еЁҝа Јб№ӨзҗҺРЈеҖ·жұңеҹ§б·§дҫёз»қз©Җдҙ–Нҷз•Һб Һв»ІжҗҚзҳізҙЈе°ҡвҰҰзҰҸвЁ©жҪӯг“ҫзёғз№ҪжҲЎжҒІНҜеҝӣвҝҡг§ дҶ¶еҫӣгҚ¶г°…б»„бӨңв—ӯе…қе¬ҰвҜӮдҺёгёӯвҢұФЎзңҖДұжҜқжүға¶•дҡёдҒҠдӮҝгҠ“бҪЈЦЎзҡҢз«–жӣўбқЈдҺ»е®ӨгӮҸСҸб°‘з®…зҖ®б„¶б…Җб„ңдҒҚе·¬вӘҘж’ҖдҷҲдӘ“бӯ”зҹҡжҳ№жҳЁб…ӮдўІгІ”в·№з‘ӨбҰҖжҢ‘г¶ҒаӯҫвҲ»зёҙвҖңа»¬дҺ г‘ҶдӮ•ЩҲг§іеғ…бҖҺМ«гҷ¬бӣӮгӣӯжҸўгӯӨбҝ—дҡ«гә«зЈЈаҙҶдӮёв…’бҲІв‘қжҸ»б—ҷзһёв’§б ¬бўӣаӯһз„¬д§®бӘів№Ңг·јгҚ…гў–вқҹУ—зӨҷСүе„°г»ІбӣҚж•ҠвҸҢгЎ…з– г§»гңЈжҗ¶ЧҢжҰҮг“іЙҒбҒәЦҲСЎе“үГҖг…ўбӨ¶д‘№вЎ„е °МҙеҶ¶гҲӮеғ«бҮҳе…”вҠҗб…ЁФӮбү„жі№вҸ„е• е•Ұе…ғж‘җаӘөбҷҮб•ӯжӮҷбҮҲж¬’аіҙбЁөвҖЎвҖ·зӮЈЕӘв«ҰвҖ№ИҗбһіжЎЎИ°ж„°гғӮЩҒжҲёжғ„вҠЈвҗ¬дқёж»ӢжӘұбң№ж”ЈбҘ…бӯІд’®а®©аӯӨеӮӮжҹҰеҸҶжЈҫбҝ”З·вҚ а№ҶеЁӘЙІгӯөгү…з–әвҗ®в  а№Ҷв—ҷжӯ…ж°ҝдҶұдәёбҘібқҠаӯҸбҫ“гһ…б Ҙж–ҖаЈҚгіҹдЁЁГ№Х дҚ’зҫ—бңјвІөж№ҫб»’еҢЎзҮўз”№вҘҙд–ҹгҰҢе«ҠдӘ№в®ІжөҪж»ҡеұҠбөЎб–ӯвҚ¶вҰ¶еқғгҲ”вққв№өбӯұб•ҶеҸӘжӣҷаұҖг…¶еө¶в®ӘжқӢеӘ¬гӮ•И«вҮһеӮҠж»җбҜ…гҸөзҰҷеҹЁж—Ҹж¬Ӣв¬өг”Һз•ЎеҮ°вҮҢзҗәб§өв¶ҲеӣҠжӘҺдӣӯв¬•И«аӨ©е Ҡз§Ҡбӯӯгҷ—бҮҚвһҶжҠҚжӣ–вЈҚбЈҝж–’б ұзІЈгҢӮеӢӢзҠҰдЁҚбҖ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":2295,"_status":"completed","_startTimestamp":1775292753935041,"_endTimestamp":1775292753941128},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":967,"_uid":"545b4385-ec98-435d-a754-bd6d107ec12e","_cid":338,"_ctime":1775292633694,"_sid":70,"_stime":1775292753046,"_serverAddr