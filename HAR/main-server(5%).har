«гүҙг©ұд—«ж¬Ңг©·д”Ҡдіўг©јвҳәг Ҫаў„е–¬бҡІвқӯв•»бқҡвҶІб‘ҚжәҸеі¶гЎӣзҖҪб–ҝвҹ’зҢҘдҰӮгӨҲеіҸв‘ӣг”ӘжҮ‘вҝҝжңҰеӢҗзҷіаұ«вқҘгҺҚгҷӮзӢұгЎ б”үб«җзӯҙдҝӘг©қвұҗгҳ¶гЁғвұҡгһ·аҪ«вөӣгЎ¬гӘўе·ІЗёгЈӣТ°зҸ—гјҮвҒәбҸ—гІәжң¬бү§з—·е©ӣж№қзҮ‘жјүж»ҶвҫҒН”б»–зҰ№жғҷбј®в–№жі‘е»—б–№з«ӣеәңгЈҜд’ұеҸәжҗ“жЁіаўЈд¬ідӣҒбҢҒг°¶д·ҮзӨ”зҙӯд»’з©—ЦӯвҚўе§ҢзүӘаЎҳжҺјжӨӮб»Ҫд§јЮёгҜ–вЎізғ–еҮҘзҒ®зҷ вӯ®бһұб¬Һз§ҫаҘҺе·өгЈңз—ҘЦӮбұ§гЁұЙЁд©Івҝ№вӨһе·Әд®ІвқҙдҡІдҪ¬г¬Ҳд©ҙбӯ‘дҮҰдҷҒж•№ЫҰдҘјдўҒЩ„б®Ўа№җв–‘жӯ§дқҶбҙӯЯўвҘ–жҰҒз“¶жЁҒбҘҖдң‘еҺ«гЈңжӢ¶ж°ҺаөҗзЎ‘жіҪеӯұб‘ҷе©ңаҜЎгҜұе•Ӣе¬ӘЬіе§‘ЧӨв‘№г…–зҒ©зҘ®зҸ–ЕӮжҹ©е®§Шүв•ҢгҢЁб•ҷбЎ„зӣӨд‘№жөһа¬Ёеө•вңҫж…ҙзҰәбҖјзўҫзҚҠеҲӨгҜҫзҜҙдҡ М«еӮҺШЈбё ајӢдҖ г–¬ЮҖжҝҸв үдҖҪз—ҲгҒҺХЎв ұХҖYдіҲзёЈа«үаі¬бҶЎгғ…вё·гёөг’¶бЎ¬вҳҒдҗ°вҗғв©¬д·–дЁҪеҚ‘д“үг«Ҳг„ҲбҰўгҒҚвӢҸг••б®Өб•ӨбҰҰгҒӢвҸғвҙ бҮЁдү•гҲ№ең•зӢҸгҹҫжңҪ в…ҙН¶а«ҪеӣөеңңТўзҒҶеҢЎзЎІаўІгҒ“е«¶дҖұе№ӘЫҲвһҠб‘ӣвұҖвӣібіӢвӣўж„өг№»жҰ•еҒҡЧҙзҡЈдӯіб ҰеЎҙ)вү‘в  а«ҡВүдөӢвһҲжөәбЈ§еЈҰГүеқізүҒз «з…Үб–’жҲ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":1248,"_status":"completed","_startTimestamp":1775293128845026,"_endTimestamp":1775293128850642},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"477","comment":"","_id":1420,"_uid":"20a47719-3cf6-499a-a382-a5c19c0b0129","_cid":477,"_ctime":1775292841240,"_sid":87,"_stime":1775293128539,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":57404,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:58:48.174Z","time":253,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNjrta&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36