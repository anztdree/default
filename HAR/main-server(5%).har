p"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNjOYs"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775293008073520,"_endTimestamp":1775293008081028},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:56:52 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1586"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":1952,"mimeType":"text/plain","text":"724:43127[{\"ret\":0,\"compress\":true,\"serverTime\":1775293012895,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁЙҗбғ¬гҖҰжң жЎўдҶ¬жҖ©гҖҫжҖҪд„°ОёжҢ бҠӘгҲЎбў°бӣӨвёўе°ҰгЈ а§ бү©еҠ гҢЁзёҙв‘ЁXДёЖҲЕҷеҲЈеў»жҗЎгғҚд Өжһ·бҫәг№ Міг”үвҗ»з ЎеЎҰж’©жӨҢдҡіШ°ж”ҪВҶзұҠг©ӨжғӢж’ёвўҠд¶ӢгҮ‘еҪәжӢӮдүІгҶЁе—Ңе»¶вӯҘбҸһТідҷҰeдЎҰзҖ жјңж№ІХӮбҷ Э¬гҠҗРүзӨ№дҢҗВҚгҶҘвҮёжӯҚб‘°жўүж”ібөӮжҰҢвӯ б–ӨгӢӮеҷ–ж©Ҳе“ӨбӘҪбҙөгғҘг«әвҜІеҚҫбЁ¬г‘ҘжҺӮж—№вІ®з…§вӯҚг‘һе©Ҡб–¬вқғж—•еҝ’д’‘вү•е•һд”®еӘ®вҲәг¶ӯаәјдЈҒаҰ¬жҘ•д¶Ҷвө¶ЭҢд…’жЎ–еҫ®дІғеөәжҢ®жҡҗгЎ”в§қеҖ–дҲ®жЎ¶жҸҖвҚҡгҺ бҮҮНәб…ҳв·ұа§ҡеҘ•жөға·„б„ЎжҺ•з·ҢбҶ®еҖҗзӢҰбҮҢді‘зұӨа¶ӘдіӮв•ҫгІӯжі‘жҰҢвөҳж ®бЎҷж®Ҝв„ЁдұҡеөүжЈҜеҠҘв‘ҘвҢ”вұҰЕҫв—°дұүгәӣб®ҖзҢ’бҹӣбқҖжҰ¶б®әж®”дІӯб’ҫвҺҚг”ІеӯҚбЁЁз”ҙгҒ§в“•г•Ғжў•жӘ”д«Ұеҫ¶еқҸб·Ӯе§’д·ҖКһгҘҝбіҮбҘ…вЈөж „е¶¶бҮ”д—җжөҫа№®гҜӮдҙҷб®ЁбөЁвҺЎд’Ҝж¬–вҙІвӮҸжө¬в‘ҙбҶӘбҳӘжҷ–вҜҺдё“жЁјгҷЎж…ӘжӢ№зҶёб’‘зҚҪаӘЈг°¬з•Ўд•Үв№—гүҒг…ҠдЈҗгұ‘еҝҚбӮ“дЈ№еҠҢз…җдіҰжҢ№б·Ҹбҙ®дҺҜбӨёжЈҺвҗҷдҺҫдЎ©еҪҒжҗ¬б°®бҪӘбҠӯвҘ‘б№®дЈҮеҙҢг·Ӯб‘үд‘әвҢ’жӯһд—ғгЁЁдҜ‘гҡ‘вҳ’е®…аЎ«гҚ№дҰ“зә…дёҰГҹаӯ‘гӯҸв№ӣеһҺдҪҲдәӢдҜ’вҪәжҙҗЦҺвҷҡзҷ№дҸӮжөЎдҢ’вҷ№жҷҖзҘҒв…җв•ҫдӯҡе‘өдһ°еҗҫдҹәе©ідҸёаҰҚаҰ‘жҫӣЗ’ж®ҲвҸҗгӯІвҜІз‘ҫдіҗзҙ®вҰӣв№ҹд®Ӯбүһвң№жөӨдҹҲгЁҪЛёвҚҸж°«гҳЁд—Ҙгҷ•дӯ№Ж“О‘з•ҰвҸІб•һбјӢгј вһӢеҘ№жў«бҘӨв’°еҲ·дҪ“гЁӯдөҰдҡӢб·ҮдҲӨвҚҗдҷ„дҪҶаӨ в–ӣвҲЎеҖ„вЁ·вҘӢжҷ–в•ҰвӨҶжҫ’в№№жҜ°бҲідҠ«зҷ¶еҖҗзҙ©дҠҷбүҷОҷг•ңвёӣвҰҠв«‘дҠҫб’ҳзӘқжҪӘжӨ¶жҰүеӢҸдһІа№ҘдҠӘж‘ів¶ёз„ жҚ’вё®д„ғгӨ—ж—үзҡҖв¶әзҷӣа°Ғв№ҶвҖ»жҡ’жЎҗг©ҹдұ№е¶ҮдҷҳзҰҡвіҖдәҸжҚӨеӣ бӯ·дҙҙвЈҗв•»а«Җжҡ…вҜ»гҪ‘дӯәжҡІеӯ“гҗ®дҺ“з¶ғжәҗд“ҰвҒҷејҝж№«дұӨдҠ©бҠҫвҜҷгҡҷб·ӮдҰҡвҺ’зӣғдӘ‘зӨўвҳЁгӨҶеә•зүғж¬җеҠ“дғёе¬ҙдҶЁзә©жҰ’ЩӮж…Әе‘©еӣ”вңҜжҝӣжҷәвҙұе№ҢжҫӮдәүб®ӮеҳҪе¬”вҘ№жҳ©д’Ҡв§ібӯЎдҠӯг“ҰгўӣгҡҠвҚ’е„Җв°’бӨідҪҗб«Ёж„«б№ңбЈ…д–ҙж’ҡвҡЎв«ӯз°ҪдҺ’в–ӣдҺ—гәҶж¶»жҶҚа®©дӯЎеҜ‘е”Өв№җв•ӣа Җг•„дҢ’е’ҶжңҙзҷҷаҜ…дөҙж®ӮгҢ•бҚҠаҫӢгҒөв—ҸдҠ°Фҫдў‘гөҺбҸөгҢ г“ҷжҷ«бҗҗзҲҮд„Ізәҹд·ҙб№Өжҫ·жұҷд№җб…өд®Ғгҡҷе…іжөҒбҳ«гҗЎдЈ©аҫҶбңҗз«өдҚҷгӘ‘ж–‘б“ зӣҰбә‘жҘ’з‘ңж•“в«ЎдІҲбӣ•д·§д—ўе—Ұгәҳеӯ“дҪңдәҲдәҚдҹҪбүҚаә’вҷҚаҜҗгҸһз°«гҡідЁҠжҪӨдҮӘеғ„бҳ©бүүд…‘зұңеҺҫвј®вҲ©аәӢд°ӨдёЁв„¬д–җг©©дӢ“д„©бүӣаёҜг©ӮзҜұжҢҚбӢёеҶҚаӘӢе…ғж‘—г‘ӣж–җжәҳгҡЁе‘ӮРёвҗҲг¬ёб•Ј\\\"зҗ бҹЁ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":1586,"_status":"completed","_startTimestamp":1775293011901292,"_endTimestamp":1775293011906297},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"477","comment":"","_id":1325,"_uid":"36ae84fd-90c4-4bee-9140-796a729373bc","_cid":477,"_ctime":1775292841240,"_sid":54,"_stime":1775293008073,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":57404,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:56:47.698Z","time":258,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNjOTE&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"def