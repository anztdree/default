ұ“а®ӢбҠёзІҸбҠҪвҠҙбҠ”г”ҙж”¬дҜҸвҺ¬жҢҙеӢҺб¶Ҹж¶ӢаҜҶжҚҙдңҪеҺҮв әбҘӣЧҚж¶ӣЮҲбҺ§аўҙжҗјб®ӮеҢңз”ӢжҢҮЮ…еҚҢзӮ«еҲ°в‘¶жІ¬ж®»вҠјзӮҰгҚјд–ҙбҠҜбӢӮУ»г¶·зҢјж–»г°©РғбІҝЕҪзҸҝв …зҙҠН ЖҘжЎ—МЎзј Ю•жҖ б«ҰПҗдҒҮеҲ”жҖізЈҙб ·ЛҖеҗЁдҠ°<жҮ·ДһдҸ·ЪҶаЈ еў–еҮ©ГҺеқ«аұҝбҝ“бӣҙв·Җг’•вһҖбғӣаӘ©жҳҜжҳҡбў”аіЎбЎ‘е—¶вңҠд·Јб«ӮаіЈбЎ“е»°вә аӨ„вҶҰеӨӘб°Ҷжқ°з«ҹгҺ®дҖ бғҠРӢд¶қжўәбһһЙЎг ЁжҰ зұүЮ‘б §жј»вҒқб…»б”әжўЈеҳ¶д…°вЁ¶зҖӮжӢ—д®ҷеҷҚгқҠг”ҜжҝҖд°ҪжҫЎз§“И»дө Вів„ҲбіҖJзҗҫе…”бҡӯеҒӯбӘӘдә°еӘһдҫҙеҝ—зӨ°з°ҝзў“ж»қг„   \"}]"},"redirectURL":"","headersSize":260,"bodySize":1279,"_status":"completed","_startTimestamp":1775292771160355,"_endTimestamp":1775292771165628},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":985,"_uid":"1f45a0b6-8531-4480-bea6-a78f21aa0fae","_cid":338,"_ctime":1775292633694,"_sid":78,"_stime":1775292770460,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:50.099Z","time":259,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiUSj&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiUSj"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292770099863,"_endTimestamp":1775292770105814},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w