34-aa65875843c0","_cid":585,"_ctime":1775293201578,"_sid":13,"_stime":1775293218283,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":51308,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T09:00:18.004Z","time":537,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNkBp4&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkBp4"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775293218004032,"_endTimestamp":1775293218011859},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 09:00:19 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2548"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":3118,"mimeType":"text/plain","text":"1161:43178[{\"ret\":0,\"compress\":true,\"serverTime\":1775293219538,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖӨбҖ©жә¬Гӯзў б— гҺ¬а¬ дӨ бҢӘГ¬з…Ҳд ЎаІ„ВҗЙҗЛ°К“жҗ§гӮ®в ўжғёеҖ©діүв•ңзҠ ШұзЁ’гҠ”еҖЈгҺ¬вј°г·ібҒҝаҰ’д’ӘДүжҹҳДҡе‘җбјўбҗҫвүҒжҒҗзӮҗг’•д©җМұЫҺе№ЈдҫҢеҶұгЈЁвІ„гҒЁб„ёаұҡг•ұвҫҺаӨ§вҶӘб…ғеҮ‘зЈӨзҠҠвқҪбҰҪдЎ•жһ»зҢ«д—…зҢҺб ¬6ж” З’в„¬Д„дЈЈгЎӨвҖӨвҖҗГәгҗ дҘҡ!зӘ еў“вҒ„вҖҗаҪқгҗҘбәәИүгә е…ҘгқүбҡһгҲ ДІвҸҒдҷҖ$еҗҙаҪҗжһўг‘’бҹӣМұвҶҙгұ°ж№ҡКЈбҒҲ]С…д„ҖбҒ°вҰҒеЁЎеі–дҖҘвҘҙа  вІҳжҲЁдҷӨе…Ёб  ајҺбҖЎвіһбҗҙд“ҖДңбҷүЙҖЖҷзҳҪб• г…ҷзЈөбіЁе„үжҳҪЭӘзҖ°вҠ”аҫ®бҘҖбҒҒбҠі бёЁг¶ дҗғбҮӨа№ҖЙұдӮҠгҖ«ПЎдҖЁбӮ аұҒГҖжҺҷдғҰе—Җ5гҗ·вҪ“д°ә7жӣҢеЎ”зӯқдҫ¬ж’°в‘ҷд«…жЁ‘бҗ«еқҮдўҖг”Ўд«ҒеЁөбҡқдҚҖШҖеҒ•в…ўг©Іе®қеі„г®Ҫеһӣе–°в§қз©ҝеҫҖЯӘж„Җжү—зҸҶзҺҘа¬¬Еңдә ЗЎеҖ©ОҙЕҖаҰ <еҖЈж””ЕЎд«Үгә‘ в”ӨжүқжҖЈвҘҖжҢөгјҖJеҖ г—Җб°®зЎ зҒЈФ©дҗҒв‘ЁеәҘбҒҳбёӨЭңеҶҮдұ°жӘҜв„ўж• зұЎзӮ©бҠҷбҘӘеҗ„зІҷвҸҮб‘”НӮд№·аЈӘжёҜбҹЁдҙҘж…ёеј§бҘ…жҘјеғҲвӮөб–һеҳӨж«әеқ·з№Ұеҳ в„ҳеі§а ¶дӮҰбҗәФЈеү’аӨЈвЎЁНЎг©ҡаЎҗгӘӘбј¶з©’СӨеЎҗФ бӨ–бөўвҒҡбӢҮЪЁбҳҜдҮҠб„®вҮҲгқ жҮ‘д¬©жҶҳвЈ„бҮӨг№ҘбҮ№е’ҮгұҗЪғд°ҙбҰҮві»бҖӨгҙҰ1еӘҖЭ„жЁ бҳҳжҖ©вү°гҳўг§•гң—'аЈҗвҗІдҜј:вҗЁЭӨбҠЎЬўРЁд…Өа№ҳгҒҰаҙӘж…ӨвҠ©е„¬вү«г…ңв«ғзқӘаҫҡзҰһвҙҷа©·жҪҖгј№вҪҠб–…в«Ҡа  б—Ҳз”ӨаЈҖд„ғвӮ аұівЈӮвҙ°аұ§дҗҙбЈҒбҠ…ВӮбө„бә§жҰғЭғгҗҙбҒЁж‘ҙеұ°бҗӘдЁ№вЁәдң¶еҗӨеҝғбӢҙеӨҲбЈ¬еҺӮзғёжҮҒзҠўеҢЎа¬Һб®№зЈҰжҲЎУӯд—’nдҸҖПӢдЁ гҝ•вҖўзүҜдӨ·аЎўжүҳаҜ§еұўаІҶзҡңаҘҙдұҫбў–бҰғдҲ·б§ҖеҖўб”ә#гӢҖВҙвЁ вә“г–ҫд•‘г¶јзҒ”бҺІзҢҝГ„б‘ңжЎҫзұ б“ғзҸҹг°«з°ўдӣҢа°Ҷаә®а« з°Ұж‘№вұұвӘ°ЖҰж®„гҠ§К°аӘЈеҮӨа¶«аөҢЬ¬еҒӨвӨІбғ„бҲ®бҒ№в–®вӢӘзҒҡЬ°ж№©ЯҒжұӣдҘғвүңдҡ”в©қбҒ‘жҠҘдҳЁбғЈжҚҶбқ°еҠҡеҪҙв¶«в¶ҢеЈ–УұвғҶв№Ҹг  гӢҖдһҗвұқж“ҷгіҗбҲҒвҗёРҚОәжҙҪвҡ„б’ еҺөдөҘвқҪд·ҘбІөжј…в№ізҸӣвӢ„вј’еҫҝд°қЖҖаӨ«зҖҫеҗ«вҒ©е’ЈгҶһб”…дө¬Эҗжҳ¬ЯӨбұ–дҮ°Ф№д•°бұӮдӣ°віҒв•ўШҰд„ҒжҳӘЕЎеЈҘЯ—дҲҳдҠ–в»»еӨ–е»әдҳ—зјӮдҗҜз’Ёг¬®бҮҪб§ӯгІҹаЈҷг¶–жҗ зӘҫдҖҝе¶ҲЕӮзҢӣг®јвҖҰеқҷд„—бөібҒЈаҰӢд®ҖеҺҢдәӣвӨүб·–в¬өжӢҢдғўгҰ§еӘ·е©ёвҘ§жүЎзҺ·аўје¬ӢгҰҡзҳ•вўҰзҹ©зјһдҖ“бҜҝг Һз·ҶеұҘд”јЭҰд”ҢдөҳеЈ—еЁ№еЈүбӯүг©Ҳб„ӯЬјб•ЈаҪ–е…ӨдһЁЮӣзҖҮдӨ¬дҶ…аөҒдЈҮзңҜбҫ·зіҰеҝ—з»Јжҫ®гЎ“бәҶгҢҘдҗҠжҺЁvбӨҠж”Ҷв¬ӮДҠдҢҗжјҘг—јбјҖаҙҜжҲңбҗЎвҰ”ДҖгҖўж№Ҷвӣјд«°ГҷзӘ аЁ а° жҘҷвҖ§е»Ҙг®№ж¬—б§Ӯж¬°ВңбЁӮз°ЁР”дҪізӨ·дёӢбҹүеҰқЗ’е¬Ёеғ–еҚЈеғ‘вӯҒаЁәжҲҢГЈг·Ҳг¬„бәўЪғBбқЈг„ҳдІұзўҙгІҸдүҳдӘҘаӯҖаІЎаӨҷМұаӨҪжЈҡОүгӨ«жӨіЕҘб‘Әд—ҡЭіжһҺеҖ а©өд“ё)вҗ дөӢвҖЈДҠ8жөҗЖ¶зә ајңеҺЎ/бҚІбү§в№ҚдӢ ж¶¶д„ҳcШ¬дҮјбёЁжҙ©жү¶дӯ„д“Ҡж·Ҫзҷӯд §дҠівҘӮдҗҲгЁ·б’–вӢ©з¬Ұг“іжҜҢдұһИҮе–Өе»‘еўқбЁҘвҪ°еқҫдЈҠгҗҰРӯвЁҘЗӨбЎ“жӮІб ёгӯӯжЎёдҚҗгӨ®аё¶СұдёұвҒҳбјІжҺҙдҒҹа ҘвЎҰдәүг„ҖдЎӮа»Ідҳ·гұҳбҜ„ж‘Ҹв ҒГӘаІұд»®зҖ«дә¬жҫҪЙҜе‘”аҫӮWж№°ИҒЩҮ`жң№дөІб¬ҖбёәЬңгҝ§еұәЪ¶.е—ҳгҶӯаӨӘж—”д¬°Iвә а»Өг…¶бӯҚвҶҳдҰҷвҘҲзЁ‘бҘ§ж¶¶аЈәвҗҙбўӮбҒүеҜ„вҘҮдғқвҪҪз‘·е®§жҖёв¬җеҝұеҚ»гҒҖе‘ғеҮҚЛ©дЁәзө№бқўзӮ®вӨҲг·’ж‘Ҳеһ–жҠ«з”ҶТ°жҚҸа®үб№ўаҰ‘б‘„аәЈбӢёжғ…ТҜдӘҹж‘°дӨ№д №г Ұг«ҺжҷҖвӣӨВҖбІҫжҲ гһ»еҖЎд“і2аәҚвІҗбҖЎвҢҺХҢЛҪГ‘бҘЎжқӣжҗ°д–өзҙҹдӯ¶бјғд‘җжҲ«е’ЈбіӘбӣ°вӘҫдғібҖҜеӮҪгһҘзҜҢвӨібүідҪЁж°°ОЎг¬ дӢӮеҖ°вҒҸб“ҘзҰӯд”ёеІЁд ҪжӮөв‘іж”®б…Җа¬ЎеҗҜв¬ёД«аӘҳвӮҒзҒўзўұд”ўбҗәаҜёг’ўжҗіжҒЁеҫҠг°ҰЬҢгҲ®бӮҙаІҶбҺ’гҹёв©ЎаЎ”жЈӯві°еӮҙеһ»Ш°е®«гӣ·жҰЁеһ•г ®жұ К»дЁҢвҶ„В—еіҢЮјзқіаӯһВ¶г•¶дҮЁж„ г«–бҸҒТӨвЎөЯӢа№Ӯд•ўвҷ„гүҰдҘҙдҷңжІҙзЈ§е№Је‘Ңбӯ•бұҸгҰқгһ з„Өдҳ…бёӢжӣІжұўб«»дғҶз«Ҙв©¶гүҪз… зұЎгҒәаІқаөӢбҖЁе•ғбӨјдӮ„зІЎвҖұН®зҰҰаІ…вҫӣжІЈдӮҝвҳ”ГәвҸһз№ЎвҒҸжјҲвҙұеӮҹеҖҰд ®ЖҘв«ҘдҒҝвЁ ИұеҖЈзөіЭҗДӘдӘҗб«„гҠ¬ЖұбјҖBд•ібҜҒдў®в®–дәёвҹөТ°Ф«еҹҖз‘ҒдҢӘгҮҙг‘үз•Ҹа§”зҙҝвҪҘбӘҫд–•бәҲвҠҲ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":2548,"_status":"completed","_startTimestamp":1775293218535536,"_endTimestamp":1775293218541271},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"555","comment":"","_id":1552,"_uid":"cbe6ff94-a920-4f1a-aaa1-339f611646eb","_cid":555,"_ctime":1775293161884,"_sid":22,"_stime":1775293218003,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":34454,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T09:00:17.672Z","time":278,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNkBk2&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkBk2"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775293217672442,"_endTimestamp":1775293217679790},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 09:00:18 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3039"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":3792,"mimeType":"text/plain","text":"1343:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе ЈбЈ®жұёДҖЖӮеҰ‘бӣҸRд© ОӨа°Ҝв„Ёгҷ•б©ёжҙјд»¶а¬ вң«еӣәжҖ«зӮ°дҲҖбғ еӢ¬Щңгө…аЈӨжӘ Ы°МҲв–ёжҖӘбё вўҫИҰвҖ©зҒҲдҶІеҖ жҙ…аіҠж¶қвҮҖС„вҚ…г—ғдҒҖТ°зіҗжЁӨвҖЎд®ҶжҰёг Ўбў·еҶҫвҘҗ$дҝҘвҡҠдҠ“г•Ңб·Ңдӯ“бҰ©бҢ”ж§¶б¶Ҷж¶ӘгҰҝд№ЎгӣігҚ…ж¶«ең‘з’ІдӨЎд§ЎгЎӘаӨӨгҒӮбўүбҗ гҲёе«„вҝ®К ВҺжӣҗж”“дҗҒгҷӣС§дҢўжӣҠКЁвӮ°зҳ а¶„дқ¬дҪұаЎ вүЈдҢ°Р«зҘЁзЎ–аё°Л©ж„”бӮёе…ҠзјҲвҗӘSз‘ҠгЁІдҮӮеҖ№б’јв„ЈеӮҷЖўд“үв‘ңФӨві«дҳҲвңӯдӘўвӮҳв»ұгҖөЧҙВёв”°в’ІеӨәв¶·ж–ӘеЈҲжөөФҠе©Ұаёҷдұ“в—ӨгҗөвўҡдЁ°в„іб•ІдіҲдҺҙб•ҲвЈҷв»–ж¶әеЁ§зӮІбөҸаҜ—вҝөгөҰдҝҢж ӯН¶д”ӯвЈ·ж¶ұдіҘжҮөеҙ¶зҹ„жё—зёҷжӘқбҜ”дҡ®д®»вҰӯзҢҫдҮҖеө•зёҶжӮүвөҢжҙ№зўҒж»ӯб·ҷзғ…еі”в–©еҺҷб¶Ңв•ҒдһҳИҳвҚҖвҸҡжҳҸе¶ҫжҮҗгұҚбҚ…еӨҚбҫҸдҜҖвҙҡеЈўжҺ•зІҷгІҸа°қзӮғгҙӯг—¶вӢ·гў·зһ«дҺҲеәҢеҗӢеҰҢбІҪвқ№еҳҷжҜҫж°—дҠ…гёјж®ӘеқңбҸ”зҮҪеҶҜзҗҢзҫұз’ңвҺ зҳЈвҝҶгҶјгҢөзҮ¬г–ҙаҝҚзҝ‘зҠқвҺўаіјжҫёаҘўвўңзҺ¬дҜ‘еӣўзҒ№з‘Јб·ҮзҶёжҙ©аЎңж‘°з…қдҫҫаЈңг’’а«ңбҳЈаәЈж’ҢаЁЈжҺ¶зҠје·қаҪЈж»ӢаәӮгўңа°Іжҝ’аЎёз¬ёдЁЈбҠ…а®ҚжІӣзӢ¬аӯ—з—қгҝҶаҰЈвҜүз•івҒ§зҷЈеІӮдЎ’зӘҖаҪ’жұӨз…’гҹӢеҗҢбү аҰғгЎ¬д©ЈаәҘдҲҢжҡҸа№ІЙЁаЁІе¶§дўЈе©ҰаұңзІһд¶ғвәҮг‘ӮдёҜа·ІжҶ…дўӘзәҢдІ”ајўдІўа®јвЁ’еҡ„вҪідЎЈжӢізҷҰвҙӘеҰӮв»ғжҝҒа¶ЁаІғдЈғг№№в№Јг„ҪдҝҪе–ҹа»ӘдҘ¶еӮӢаәәвё«жҠҺаҘҠв№»вЈҢгҢ§в»ңе¶Ғв©Ід№ҙд«ғзЎ»дЁәвҺҮдҪ«жҚӯв¶Ҡж•Ҙв®әжЎўж«’з¶”д »гҰғеҳ»гҺөвёҠбҚӘдҰқеҚҙв¬ҚдҚЎвӘҠдқІжөҠжһҺж¶әеҮҒжҫўеӯҙжӯідү¶гӮҠеһҚгҡӢжҶҹвҜҠзӯіеһ»е¶ӮжҰҠзһӣжЈҡдғ°в¬»аұЈзҗӣеӯӘжІ§вқҡжӨ§гғ¶а¬§зҫқжҝҠдғөгңҡа№ӯжҰӢгұ®в»§дЈ°бҙәзҹҶв№ӣг–қжө»в”үжҸҰгө«ж«Үдӯӯб№“ДүбәҰб”‘вәҮжғұд·Үд‘·діҮгһҶбў§бҪ°бҙІб®—дЁҶвӢұд¬·вқүдІ¶дӢҰбЎ§віјеҰёгҶҖејҮдӢӘеў§в®Үб§Іе¬’е®ҡгҡҖб·‘аөЎеӘғеӢ®еҘ—гҚ№еҙӢгҶҒеҫ§дңҹд¬¶зңҗбҰҰеҢ–еә–Т„б®—з«Ёві–ејҒдҰ—еЈ»еҘҰб»ІеӘ—дҮҜеҜ·ж»·б°®дң”гҰәаө№жҖ–д•ўгӘҜвһҺеІ§жҲңг®ҰаҘ¬е«ҪеЈөгқҶбңһгә“еӣЁг°§гЈЈеЈ®Ш…гЁ–жӢөгҚҜв’ҷгІәдЁҖжўӢдёҷе ®ж·©ж»’еҳҢжјҺаҙӢгҪ§б§ зҰ®гЁ–г—Һзё•бҙ·д— еұ·ајқгј—ж¶—гӢқвҳҸг¬ҫвҜ§г»јдҸұаҝ—б«ҪгЈҸвҜ§а»ҺЯјгӯҸеҜ©з·ҫбҪўз¬ңгҗ•зҫҺе§ҝбёІа»ғе’һбҷӯзҰһд—№д’”зҚҮзҜҘг җдҪҪд һг®ҲЗҸв®қжҝ¬зғӯд’ҷеҶ·зӯҹа ҜбөЁж һеҙ…гёЁбҝјгҘ®зҙҹеҺӣеҸҢзЈ“бӘұд№ҹзҲҺг°ҙзәёбҸ”д‘“е‘Ёг’ҳгҒјз««в”®е№ҳаҙ–д”ғзәіжҠЈаә©дҚғдһҡеЎ»д¬°д®—дғҖаұЎв°¶жҡҸаҙ•зЎ—д¶ҹдёғвЎ дҷ дј«бҪүа®ЎеҝҚж…ЁбҜ”еүҹдҺёгІӣСӘЭғРӘеӯізқҠз Ҹж…Әб°Јд“Ҝз· ві«аұ°д”Қб °гЎ«зҹҰвҡ„аә’б«ғв§¬вӢЁвәҘвҜҚд—Җз¶ҜаЈўз’ҺвҲ¶гҡ“дҶӮУівҸҢгғҘжЈӢдӣ°д„Ҝеғ“аҰёЦҠдҡ¶б№ЈаЈҰжӢңгҶёзұЈг¬ҢС¬аЈӨд«Ұвң«гӮҗа®Җд¬ӯжҮё\\\"жҰӮВўж°ӨМҙд®ЎгЎёдҠ жҠ·0ај‘д•ҒгҒҳбӣўжҲјГҒгұҘбЎ…зҷһв¬ёдӣүД бҳҪдӮҠвҖЎаҙҖб“…жҖјв…ҙеӯЎаі–дҹүгҢӯгӮөбү’еҖҰгғҖОЎбҳҪж…ҳб°Ўв“°г„©зәІВҗЙ’жҳ©жҖ®б–Ӯд©ЎГ¬аЈӘе’«Ж№жҠҙзҖја¬°зқ„гү®аЁЈв°ідҒҢд·§гҒҪаІ‘б”Ҫбі‘а¬ұж°¶жҒҰвҡғЪ‘в• а«ўвұҠдЎҖИӨзғҘбү’вҚқдҒӘг–„вҖЈдҶёДЈе ЁЧҗвҫҙгәүбҝғеҺ©г„ҖаҜҳаЎӣНёг…ӯд“ҲНҗвӘҪгЎ…бү’б°ўж…ӘгҢ…аә“дҸҗХҲг“¬д¶ұб”ібіҝбӢЈгҪ—з…ҳгҰҳдІҲв‘ЁгӘӘзғЎвҝ№б¶ібҶҡб”ўбҲ°бҠҡгң·в•Ёkв©җжӨ…а«ұбҖ§аӨұжҒҠзө•вІЁг®өзҷ®е‘ҳб»Қв«ҒвҰјаҘІе–ӮеӮӢгӢҷвӯҘгӯ·жһ№д…ҠжӣҚз”ҢдҜ•аө·дәҺб”із№®зёҷв§·еІҢдҘҳбҗ бҒ…дҡҘа¬ўзғҘбЈІеҖҫд©ја§ а јж’¬д…Әеі«дў гЎўаЈұе¬ұзӣҲж©ҚгӮҰзҒӯЦ„жҝҠвҶҸвҫөвңҪбұӮе—Ӣд»һдӢӯвӣөдӯЁгҘәжҸҢбӣҫвў°Э¶з–ұб…Ӯз№•жҜ°гқ”гө»Рјж«©еі–д—ҳзӘұжҰҜбЁ‘ж°ұзҗҒгјҶд©ІжӢӨа·®дҒҘдҶ№бҰЎд·–еҪЈг„ҜбҠ¶ИЎдҷөж”¬е°ӨеҠӨдҠҗв®ұжӨЎеҳ«еӯҠГ‘гҪҮвјҙNе–ӢзўўЖҗдғҪдІҶа№’зҢӯб«үв’ҮжҰңб• вҸҜгҒ‘дЈҷИЈгЎ¶Ыұе§’вӘһвөҙеҷІжҢ¬з·ҸеӢҲЮҖгҢӨб¶ҚЫҖзғҡб…ЈвӮ бҷ»жҚёДЎаІўЪҗ^г–«еЁӢгјўвЁІвҪ”дҳҪжҲ„д–ЈбЎҰд№үЙ·ДғбҢҖзңІа®—гҰҮж©Ҙдү„аЈЁбҠ°д„№О®ж•Іе‘»гјәжҒјаҰҒбЈӨПӢбўҚвҮҡдҰҗв“»Ц…бҡҖз•‘г„Ға№ғзЈҘжҷӮжңәЗ°дәја¶ҮбҳҺеӢәвЁ®бҖ®а©–бҷ‘в”һеҰҘЪ·Щ№гӘҪе§ңгң«вң дғ¶гҮ„б«ғв‘ҫж„ёбў»а§Қвӣұж¶әг…ёаӯҡвҸҗзҢ–зЎЈзӨӮдҡҪзӨӣвҮ‘дӣҫжҙјеӘғзӣ“жқӢвҮ¬дҒҠвҜ№жһҠвҶңе–«гқӣдЁҜЙәг»ҺбҷҳдҲҖв®үг‘ҷжӘјвҫӢв»«з“ңд°Ғб Үд·Җбҷ’зҷҶбӢ№вҙөеӘҝж—”е©«еіҷв©…г¬Ҷе–ӣПўжғ—зҙҡв’¬бҺўбұӘеҙӢж“’еЈқгһ«гј»еқІж»•е–—в¶…еө№гҳҒе©ёжқ’аӯјгҪ»еҶғгҢҰж…·г«»г–ҸвҘ»з—өбөёб—қжҢІа··а¶қвқ–жўҸзӣ№е¬ҚжӢҪж“ҢбІ«дӢҡж¬«а©–б¶ҹвҸӮж—Ўв»Ўвҝөзғ»зҲ“еј»Т©зӯҶе¬ҒбҺҢгһһзҗҖзјһжӣҳгҒёжёҶе«»зҹһеҜ„бІ—в®Ҡб®Ўжқ¶еұҒж»өдҒҷПӢжҒ§зЁҚаЎҸг•—б„ҹгҷ®Мҝжў”вҸҪжұһзҮҖеәҫвӣҡа¬ҙбӮ‘еӨ•ајұз„Җа§Ёг јг…ҳдҺіеә«гҡҜз¬Ҝг«–з·Ғдјңв„ҒдҮ¬бі“еқһдҺјжіҮбӮ–жЎ•гӯ»бҙҸгӣ№зӨҫв—©бұҪдһұзҗҳеөғв–‘д¬¶а»·зҢңгҡёз•ҝбӢЁг”Ӣе°—гҫҒг°Јб№јбҮҰвӮ аҙ б…°Р <дў бҒқ0НЎ)О зҳҜгңӘЦҺгІҰДҚзёЎбҖҰдҶҗбёЈзҒәвҲ   \"},null]"},"redirectURL":"","headersSize":260,"bodySize":3039,"_status":"completed","_startTimestamp":1775293217945342,"_endTimestamp":1775293217950916},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"555","comment":"","_id":1551,"_uid":"c5124911-e935-4719-93aa-2b3416ed859e","_cid":555,"_ctime":1775293161884,"_sid":21,"_stime":1775293217672,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":34454,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T09:00:17.364Z","time":253,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNkBf3&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"196"}],"queryString":[{"name":"EIO",