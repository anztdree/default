Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 09:02:47 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1681"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":2031,"mimeType":"text/plain","text":"769:43219[{\"ret\":0,\"compress\":true,\"serverTime\":1775293367168,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЖ№жүұбҖўбЈЁДҖТҖЧҖФҮд ®ж„јеҖҘдҮ‘вҖібҘІдӘҷж” аұғзҗ„ж”үвҖҰжңёе№ҖжҜҠбЎұа©©бҷ—жҝёЦҮеӯүбҮқв«ҡзјҙбЎје№ҰЫҖг•өзЈ д—ӯа¬–бҰ“бңӘИҘа»Ј!вӯЎжҲҖШӨдұЎвј©бІұаЈҖПҖжҗіе°ұвҖ з¶”бЈӮбҜӨв°ҖаЁ©Ю№дҠ”б…ұХёж«ңг…ҷбӘҫд¬Ҷг– жҖЎгҷ°зҷ„бҙҮе„Ұгқҳе№»д°Ўж’ұзҚҘбҒ ОүеҖ¶аәҲФ’гЁ аёӯВ°гҘ вҗўгҖ ЭҲИ„зЁўдҶҙгҸ„з·ЈдҖӨеҒёдҖ вҖЈвҘҒжІҺШЈз  а«Ҳ:жҚ–г“ҫОҘаі•б…ҲжӣҹдәҮаЎ”жӣҠвәҒжўҶб„¬аҜ еҮҒеІһб»җб…әбҗ№Е Иүж№ҢЬЎЙівқ б®¶ж  е•ҠвӨ Яҡа© Гӯе°ЁбҺ№вӮ’ж‘ӘаәҖ{гӨҲгҚ вңҖвҮӨгңҰеҠўб„ гј д©Ўа  еәҷбҝӘдӨүвӨӯГЁеӢ…жүөб…ЈбҜҒзҚ„бӘҘв“іаІҡвҰәжҳ“аЈЎг„әбһӘбўәдҖҘгҠўвЈӘж«Қвәҗз‘ёж»ҹв»¶е…ҳзЁ·дү№бҖ°бӮөвҰЎеӨЁгҰҙдёҖд—Ө=жҖўвҘ„аЎҗа©іКіеӣҡвғӢ@вЈ”г’өдӨ…зҘўд„ўвўЎдҙёаёғбҢ…е§јз’ұдҖјд—Ӯе…Әвҡ°гҒҙжҖӘе ҖТЈзҪ…еёҰдЁҒз¬ёдҷҒвҖЁбқҗбҖӮдҘідҙҶб®ёТёвҒҒб©ӯдҒЁВ¬КҒвҚ»е¶„вңҖСӢв• зў бҖәвҘҳдһҖд’ЈжӮҜзқўж җвӘ¶зҝһбјў9вЎғбҗӨ>в¬ўдЎ«ж’ӣб©ӣж„ҷЭҝж»ҡСҖбғәвј а©Ҡе“ дҗөз° еқ…ж—ёвқғЕ з°ЈгҙӢвјЈеҙ—б№Ұг“ӣЪЎеғ•вӘӘеҲҢгҰ«вҺҲжҘҖжұӨаӨ·ШҖвҠ®вҗңгІҘд’ӯб”өвҠ·г”… гғҢе•ҖжҖёа№јеҖҫвғ”Т»г•ғТһж–ңжұҘаұ°е‘ӯбҖ•зў“в„ҙжҙ¬ЩҒд’ЁЖёеўңжҮЎб§Ҡг—Ҫжҙ«вҮ аӯ‘бҳ Oе«Әвҷүе•”зҳЁбҜ“еҳ¶гәӮеҘҖУ·дҒҚГ©жғ®г’ұдўҙа«°гӮ”дҶұбұҢе¶ҙзүңдҮ°аӘөбЎұдӮӮдү·аӨ’дҘұв¬ҠеЈ·дЎ®аЎҗбӘ®аҪұдІҙбӘ‘аўӣЦ© бұ вӢӘв §зҺһжҝ§зҶңа«ҸаӨңд”§зҢ°в№§зҺЁгҒІаӯўЛҳд„өзһҫаҘҖд‘№а«Ӯз‘ұвҸЁМЈвғ¬в  вҸҖбҗ«е«ҲбӘ·д—¶ДҜеӘ№вҡ®еӘ°жҲ вҺәзҳёж—ҚжҪ•жҡҢжү ОӢдҙ–дҸғвўҫж·ЈжҡҮб¶„}б¶је¬Ұдў§еЁӨгӯ¬г¬ҺзәҠвҒҖвҜ¶гҚјзҘ…вӨ”еҹізӯ¶еҜ°дҒһж¶ёзӯјЗјжҰңжўәжҲўеҒёдҮүаЎ№Гўд‘ұж—ҷвҪҸж’Ҫгұёд®әаәўдҜқб©¶е‘ҳдҡ©е—’жҮҺвҗ’ж…јв¬®$б—ЁдҘҹбӣӢг–қв№Ға¶“в¶Ӣж¶ҮвҘ еғүбҡҲгөҝвҘҠаўІб•ҚвҺҳжҝҗеҚ¬ж®»д№ўж©»бӢҲб°ҡгӮ¶ж§»гҫҡж¶Ҳдһҳбӯҡа Ҙжҫ°еқӯж¶ғзһғжІөдҫҡеҫ бҫҗбҪ—жҷ бәІз—ҖжӨҰвҷёбЈ–аҫҚдЎҒжҲҰе®§з№Ҫгҗ«д…ҰЗ•жӨӢб“§е…®б®ӘвәӨе җд“Ҝеқҙз©’дӘ‘зҳҫеҮӘжЈҠдҮҮгөҪбЈҒеҝҹб—©віҪвјҷбі«в®Ҡб¶ҳбҗҮе¶ҚвҖӢаЎҲеёәжўҰбң»зү”е¶»зҺӮжҫқдӯІеЈ·б®–ж°ҘеңҒжі“е¬ӢдҪҡаӨЎе·ҡаҫүбҚқв«ҷеі—зң—ж¬Һж’Ҙб……бҗғеҝәб„„б ¶еӢҺвҶҒд“үЬҒжұӣХ„вүҳг’¬бҒҚД°бҜүЦ·зҒӮгҷқз°’жӮ аЎ»бҺ№дЎұеЎҒеұғвҶҰЧ„К“зҒҳе»Ҫг®ёЪӮж‘ІдҘІг©ҸвҠ•дЈӨзҝ№ж—ёеҺЁз‘—аӨ‘гә…вҺҲжһҲжҗЈзӮһа ұд„ҙбҮўбүғб‘”вҠ¬гЈ§еЎ„д…Ёг’Ҝвў•д№…бү©аІЎд»җд”ІЖҙВІж„Ізһ бі®бІ•дҒҙжҖ·з‘ңеҚёзҜ—д§ӣаҝ•зүҹзӢ’дёөж‘»вқ”дЎ©д•Ёд…“вІ°  \"}]"},"redirectURL":"","headersSize":260,"bodySize":1681,"_status":"completed","_startTimestamp":1775293366183361,"_endTimestamp":1775293366190078},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"555","comment":"","_id":1743,"_uid":"18c2875d-ce8f-4b8f-888c-62ec1434cadc","_cid":555,"_ctime":1775293161884,"_sid":76,"_stime":1775293365097,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":34454,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T09:02:44.739Z","time":264,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNkldt&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"202"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkldt"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"postData":{"mimeType":"text/plain","text":"198:42218[\"handler.process\",{\"type\