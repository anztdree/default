pp":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T09:02:58.821Z","time":828,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNkp3p&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkp3p"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775293378821488,"_endTimestamp":1775293378827846},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 09:03:00 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3493"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":4350,"mimeType":"text/plain","text":"1572:43230[{\"ret\":0,\"compress\":true,\"serverTime\":1775293380647,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЖ№жүұбҖўбЈЁДҖТҖЧҖФҮд ®ж„јеҖҘдҮ‘вҖібҘІдӘҷж” аұғзҗ„ж”үвҖҰжңёе№ҖжҜҠбЎұа©ғжҳ¬е„ҢвҝҗжӯҲд‘ұа«Ҡе¶ӣг“’д… а«Јеҷ°Жәб’ғЩ‘Т№ЙҰдҘ«дҠЎЕ§гғ uеӮҗз ЈЕҶбҒ·дү®в‘Өв Ўж§¬жәҲС°^еҙ¬вўӯзҳ—зЁ§НЈж…ҡдЈ„г’ңд№‘бІәдҪ¬жһ„аЈәжҒҗ{б‘ӣаӨұгЁҲдҢҖвҪҺеҹ¶гҖ гҘ„бҢүвҗ°ДҜз° РҠЖҒжҡ дўҹжҖҙж№°аӘҡгҗӨзҘҡЗҫзҠҮдҖҰжҰӯз®”дІҡгӘҮвҢҗвўӮб®ӘвҶ \\\"в…ёд„ұбҖ°гӣӯеҲҳдёҙб«ҙд“Ғе©‘гҰјжңұе¬Ӯаәөжһёд‘җвјўдҺӨаҘӨеӣҫгқЎЗ•а  ЯҮгЈҗб°ӨН¬ГҷзӘ в  гҖӯбҺҙИҸг…”дҖўж·ўдӢЁд©үМ ЗјЪ“ЩҸвҘ вў бҫ в•Җдҗ вј¬вҮҒжЎ…ж’¶в»ҮаҘ”з…–жәўвІ°жЁҘЭЁг„№бҷ§б·«зҲҘб’ҳеЈҶа©ҘзӘ Ц…Й°зҠҘгҘҝгғӨг…өбҘҸбҺЁгјӢаұҚеўЁГқдҲӨбҒҠгҖ ПЎЬіжӣңаҪҳд„ҙjб ·вҳ а§ҳбЎңжҪ¬гҒҖжӢҢВ§вҚ‘з§ҺвҫІб‘ӘСҷвҲЈг’Җбҫ¬дҒ°вҒ“вҙңжҶЎб°«еӢӮдҪ—еЁ е–һgжҝҖвЈҶзҚқді¶Д–бў¬в… а ӨдӨ®жҗ‘зҚ©зӘ‘а№ҢЙ¬бәҗдҺ№зҮҗаӨ бҶ д°ёв®ҹдһҗК•дӣҲг»ЈзҖӯбәҢвҸҗвүһзҒ ЗӢеҒ“з°»г§ҚжјҜзҫҖЩҙаҘҠД ПӘжҒІаҰӣаҪҜжҫҡбјЎа ӣеқЎа°Ҙжӯ«жҖўдҗөг ¶жЈҹбҗёИІЙ®жӮ§а°ҰПҝајҮеі в…Ҝе•ӣЪЎеҒІвӘӘеҲҢЩӢвҗҶб¶ӮбҒЁжүҸДҙгӨіаЁ„гҰЈеҲқб”өвҠ·б”… гғҗб”Ҙвў’зҠЎХҒеҷ…в·үаёҒг®ӘжҒЎвұҘа¬©е’ҷд‘°г©ңд•ұзҢҜб”ҲгҒ‘Н„вҒ–жҮўд¬®Х¬вҠҫзҢүжҙ®Щёж“җ!г»–вҠҙвұ«Ы©mбё§г’Үд…ІаЎ®в—¬вЈҚбІ’з‘Ҫдӣ‘дЈјбҪ”еҡ…б““жҰҖбҝЁз‘һгҝ¬вЈҠвҷҢзҗӘг•®зӣјаҰҖвЁ–вҮ©еҳўб‘·бҘ‘г’ҰбҖўГ·гғҶгҪҸгЁғд№ҸдҖ бӯІжҳҘбјӯб’…з ёеўӮеӯҖМӢгӢ–дЁ„д‘’еҒҒгӘҠеӣҙзҚІДўзӘ«б№ҷвҘүбҚ№бӮҒе©”бҖЎеҫҮжҷҲBвҘІдҲҷеЁ°ж «ФҲеўўе’“\\\"дЈЎвҳ°дЎ©DСЎгӣІЖұв©Ңві‘г¶®б—–аЈғЗ°в”Јж—–дҶЈаЁҶв”ҘбұӨбҮ¬жү бӮҙбҙҒбҹөЦһж§Ҙг«ұЩӢгЁ¬аәўЗ’ж®Ўв©ҡбқӯвіәаЎ¶а¬«СівІЎвІҙд«Ҡж  д¬ңдүңд©ёж©івөЁг©»аі’зі«д«¬еҪ°вӘӘдҘ»б¬©е•»вЁўдҠ°гҶұеҘ”жЁ¬гӯ№жҜҡжҚҗбӘҰдЈ·д®үж…‘бҜ©б“іб®ҘзҪұжӯҡеӢІеӯ°дӣ¶г©Өд»ҝе¬®еҳІгӯ–з§ҙд—Ҷз—№Ыәб·ҙжЁҶвҸјзӯҫе–ҒзӘӢгҒ“з®һФ гЁүзҙҶТҹг©ҙеЈЁвҮ°бӮ„бҒқзӯЎзӣ’д‘ҒжҷҸеҹ№жұҗвҶ•в…•жӨғгҒәа©ӣб–үаҜ‘еҚқгҗӮжүІа№ІеҒҝЧ©зҚ№вҡ’е“—вһӘзҙҲжқҢзҚ—вЁҙзғЁжӯ’дқөвҹҶдҪ№дәҠжғұбҡҘдө–б©ҡбЈҗгҢҘзҪ“бң¶зӢІд…¶з№Ҡг«–д”«еЁ®еҮұеҡөд—ҫЪҺзҝҳгҡӢгҮ’з«ҫз§–жҘҚеҹҳд„ҹвӨ Гқе°ёбҖ дүҗбӘҲзӯҖз«јвҒғжҪ»е¶һгӯүдҺ©зёЎжӨ“б”јдңёж·ӮжҸ»вҪӣдңөгјәвҳ•гҘңзҢЁб•§вқҪгӢҹг’Ҙгӯқб—ҝзӢҲбҫ«б©ғКҙвЎ·з•®з„®гҒңжҷјаӘҘе¶»дҖӨб®№ЙӯбӯҰдөәзқҠз§ӢбңҚж§јг–ұвІӣд•»зҜҡеҜ¬г«¶зқҚгҸҫб¶Ӣзҷ°ж№ңжҙІгөӯдіҖжһјз¬Ҹа ЎзәҖвһҖЮҶВ„Ь д‘ҒдҢһеҫҷз¶Ҫж¬ҠЛұж–’зҖ з„ЎШӨгҹ®жўҙЩғе°ӘЖңдҷүв’ҳдҡҢгҠ—гғҪжһҖ.еҠҡвЁӮдӘӢв–…д№®гҳҸдҰҒб’‘гЈ‘бҮ”жЈәаҫҡЭҖгҶ»Зӯв§№бІҲгӘҡвІҖШёжў–бЈӣаӯ‘Ь·дҒ¶б—ұжҹҙд¶Ңг“Өд¶Јд“«вӮЁбҢҜбқҺжҪҖзәҳжҙңа©ўзұғеұӢбҸҚзӨғС¬аЈҸзҸҺвҙҖжҳЁбҜӮж’ёК©е§ жұів§ҠвӯҙзЈ¶гҷҶгІ°еҲјвӯҘеҒҲвҺҖгӢҳЦӯг¬ҮгЈІв„‘г…ЎдҰҠдҘөжІІзӢЈеі—б»Ӯзў®Т°зӢ‘В”вҒҒжҸ„вҮҳб©ЈбқјдҚ§еҜіжҗЈжҜҳеҶғв¶ҺаөҳгҳӢд©Ё!еҡҖП©еү…з“ЎiбҒҢдһҗвҺӮзғҜг’Ғеёөд”Ңв“°зғӘбҸҸеҢҷжҠ”г§ҝбҺ©еҰ„д»ҶзӢғзә–зҖқвөҖжӢ’вғӣа§ҳХ•вҠ з…§аӨЎбҠјг…”в…ів—ӘеүӢе—ҶжӘ“в—ҖдЈ”еҘҰзӣёеҗІжјҚб–ўеөҮеҺЁгҚ»з©ҰдӢӢД‘аіһдёҫаҰәеҲҰЫ°еұӘдҗҢвәҶгәұжҳқбҝҜбЎҗвҳұж–ӯе№¶жҸўУҸжІӮбҸІжҮҸбўЁз’Ёдў«гҢ…гӨ°дҳӘбҚӮдҷҶеЎҙгәҗг‘ вһҲжҺІГҸаә©еј»зЁһб—ғдөӘКӘгҷӢбҷ•дӣҳзіҚе„”вҲҶз”ҸЫҒбҳ…гЈӨbгЈҮбҸ•жҹғгұӘд•ӨдҜұзқҲзӨЁб°қжҘқзҗҺгҪ§аө«дҢўд•®вӘјдўҠеҘ»аҙ…б«ҙжғӢе—«дёҘж©Ұвҹўз°¬дӢ¶зҮҢаә№жіҪб§…гөға©Һдҡ©ЪҖзЁҖзЈ©з®”в‘җжүҙзҒ“б№Ӣа«ӮдӘ—еҖүбҡҶз§Ңдӣ®ЙҚд§№г¶°гҘ•дӯқб“Ңа¶№г”„гЈҖгў в»Һб”„г••д»«гҰ¶е„“гі¶жӯҫг»„е•өеһ„д°–бӨ‘ЗӮqз—…бӢҘжҠҙа©ҷг«…дҺҲгқңдҚ®еҲӨвҰүзҗҫа¶ҚаӨәа©әб«ӣд№”в ¶бҷҶж№Һж»’аөӯдүұд·„еӯ’г§Ӯж·Ӣвү жЈҚбҹІжҮ«жҡәж©қбҷәеҖәа»ӘгҒ„в…Өгұ§ж’ҸбҹҘб ҢвЈ е–ҢжҲӘеҶӮеғҠаҘ§вҗ“д§ҘХӘг§Әд”“б»Қвҫ•вқҶе•ҫеҠӮгӮӣб«•вЎҮгӢҗгЁҠдў§УӢвІ©еҗӮг—‘бҡӢж·–б¶җжӣҙб¶ңб„–дҷҜЗ вұҗг„…МҙжјӢЕҪд¶¬вҷӮвӘҹе“®д¬Ӣд»ёвЎҪжҗёд••б«ӣжҜҢе…—гҷ•ЮҘВ‘бјҢеӣұеҖүзёҺд·ҳд«Җе§Ғвӯ„бқ–бҰүжӢ°аў ж№ІДҺб„ зҷ®жҢҚmж°№гәҳеҺҺеЁҗжҷҖгӣҶж°ҘбӣёвҺҚеҰ¬бӣ„дқӣвӘ»гӯҝз¬–жҷӘгӘәвҖ”бҷҳвҘҝбҙҖгҸӯзұҮгҹ·вқӨбҡ‘еӮҸбҮӘв’үвңӮаӯӢеІ«зӢЁвӣұв©¬в»Һз—Ӣгғ¬д§ңвј–е¶ӢбҺ°бғҮг‘үвҷҸгј”в  Е©бҖЎбҶўг„ в‘җвҖ Х бҜјвҗЁгҸ§бӯәжўјдҗ»гҢҜа©Ҫа»–діүеҪӣбӨҷеҡҰвҗ“е…§дәҠдӣ…г§·жұҮд¶ҷзҮҢз¬ҡб№Ҷе©…ЖһеҹӯзІӢд ӢдұҺбһңж·ӯВ№вӢёеҰӯз‘әбҺЁаў¶гЈ…бҳҜгЈ¬вҶҰвәҫзҡүжҠ…б©“ж‘ҲбӮҙД жұғдҺҠжҰ¶бҫҚж©…вҸ¬зӢҜзҖ…жҝёз»ҹеЎӢзҝҳв«ҠзөҘдҫҲа№ӘзҫҺд¬„бў»гңІг°Ӯа©ҡаўүа·өв”®б“ӨбҝЎж«үгЈ„б¬§д•“еғәеЎӮвҹ«Ъҗжҫ·гі¬в—ға¶ёз–ёзҢӢжӯөжё„гһҠг§ гҡЎзЈҙа°Ҫаёҷж¬јгҮ–гңҪзӨҰжҸ“гӯӣбҶӣдң°вҰҸеЁ”еӯҘжқ«бҫҒбі»ж“ҫбҚ©г’әжҚҶвҡ©в№ӯгҢ–жҜӮб§јгғ•бЈівө“еҚ«аҙҚвҗөж·Ҫдј”е“әвұ°з»“бҰ«дөһвӯҹд ҚгӮізҡӣеқ©зҹҸд§»жң•ж®№е–ҸбӨ“в‘һв§ғе өжҲ·жқіеҠ—вңҖвёҰз‘үгҰ°жјҮб—ӣжҹ…ПҖМһбҡ—г¬¶аЎҫж¶ҚдҮ»вҡ©гі«аөҪб “бҰӣа °еһӘз“Ңв«өв¶ҫб·ёгәібөҷдӣңз¬ӘдҲҡгү“зһ„в •е»ҝзҹ•дЈӢзёҢж §дқігң°гё—в„–бјҶгҲҫбҮҙгӯғдҺңв¬”г№©в»ҸеҰҳвЎЁа ¬д·ёб¶ЎгқёгҸ«з“ізҸ•еғәгғЁдүұдЈҗвЎҪз§’е®Је°¬в¬ҶвҚӮеј»е‘Ӯз·ӨжҠ„в“„е‘Өа¬ҲдӣҗбЈҶзұүб¬°з…ҺбҲӮг‘јеҫ°а§җвҖ§е„ңAИЁвҶӨСўд‘ёдһЁв’ўдӨҸвҚҗеӨҜж”ҳеӘҗв“…НҖдҪҒбҖІеҖўвҮўаЁ еҷӨгЎҚдғқб ўдҡҘж’қеӮ“г–ҡдҖӯж’ІбңҡвҲ№еЁ°ЖөЙ№аҰҠжЎ№еЎҗЫӘбҮүвӯӘаЈҲаҪ д°ўгҒӣдҖӘеҺјМӮзҒҖдҖ¶г“–вҗ»аЎ”дҲ„аҫјгј гғҫвүҲа©§бЁҘDдҶ»б—ҒФ§бЎҖдӮёз—«гҳ№жҜҫдҮја»әвјҰзҒ“е‘’ЭёаЁ зӨӘз»ҶУҗаў дҗ§вғғХ°г‘Ӯдҳ§вҒҗа ”бЈўеҗЎбғӘС°аЁўеҗ§вҒҫдӢЁКўв°°ж‘ЁЦІвӘҖбҲ·бҗ©д‘ҹа¬ұеў жғҠPбӘіг”«д“№вҒЁб…°г®№Т¬в•ӮбңӮжІЁ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":3493,"_status":"completed","_startTimestamp":1775293379645162,"_endTimestamp":17752933