(KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkF6x"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775293231564774,"_endTimestamp":1775293231572224},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 09:00:34 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2548"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":3118,"mimeType":"text/plain","text":"1161:43185[{\"ret\":0,\"compress\":true,\"serverTime\":1775293234417,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖӨбҖ©жә¬Гӯзў б— гҺ¬а¬ дӨ бҢӘГ¬з…Ҳд ЎаІ„ВҗЙҗЛ°К“жҗ§гӮ®в ўжғёеҖ©діүв•ңзҠ ШұзЁ’гҠ”еҖЈгҺ¬вј°г·ібҒҝаҰ’д’ӘДүжҹҳДҡе‘җбјўбҗҫвүҒжҒҗзӮҗг’•д©җМұЫҺе№ЈдҫҢеҶұгЈЁвІ„гҒЁб„ёаұҡг•ұвҫҺаӨ§вҶӘб…ғеҮ‘зЈӨзҠҠвқҪбҰҪдЎ•жһ»зҢ«д—…зҢҺб ¬6ж” З’в„¬Д„дЈЈгЎӨвҖӨвҖҗГәгҗ дҘҡ!зӘ еў“вҒ„вҖҗаҪқгҗҘбәәИүгә е…ҘгқүбҡһгҲ ДІвҸҒдҷҖ$еҗҙаҪҗжһўг‘’бҹӣМұвҶҙгұ°ж№ҡКЈбҒҲ]С…д„ҖбҒ°вҰҒеЁЎеі–дҖҘвҘҙа  вІҳжҲЁдҷӨе…Ёб  ајҺбҖЎвіһбҗҙд“ҖДңбҷүЙҖЖҷзҳҪб• г…ҷзЈөбіЁе„үжҳҪЭӘзҖ°вҠ”аҫ®бҘҖбҒҒбҠі бёЁг¶ дҗғбҮӨа№ҖЙұдӮҠгҖ«ПЎдҖЁбӮ аұҒГҖжҺҷдғҰе—Җ5гҗ·вҪ“д°ә7жӣҢеЎ”зӯқдҫ¬ж’°в‘ҷд«…жЁ‘бҗ«еқҮдўҖг”Ўд«ҒеЁөбҡқдҚҖШҖеҒ•в…ўг©Іе®қеі„г®Ҫеһӣе–°в§қз©ҝеҫҖЯӘж„Җжү—зҸҶзҺҘа¬¬Еңдә ЗЎеҖ©ОҙЕҖаҰ <еҖЈж””ЕЎд«Үгә‘ в”ӨжүқжҖЈвҘҖжҢөгјҖJеҖ г—Җб°®зЎ зҒЈФ©дҗҒв‘ЁеәҘбҒҳбёӨЭңеҶҮдұ°жӘҜв„ўж• зұЎзӮ©бҠҷбҘӘеҗ„зІҷвҸҮб‘”НӮд№·аЈӘжёҜбҹЁдҙҘж…ёеј§бҘ…жҘјеғҲвӮөб–һеҳӨж«әеқ·з№Ұеҳ в„ҳеі§а ¶дӮҰбҗәФЈеү’аӨЈвЎЁНЎг©ҡаЎҗгӘӘбј¶з©’СӨеЎҗФ бӨ–бөўвҒҡбӢҮЪЁбҳҜдҮҠб„®вҮҲгқ жҮ‘д¬©жҶҳвЈ„бҮӨг№ҘбҮ№е’ҮгұҗЪғд°ҙбҰҮві»бҖӨгҙҰ1еӘҖЭ„жЁ бҳҳжҖ©вү°гҳўг§•гң—'аЈҗвҗІдҜј:вҗЁЭӨбҠЎЬўРЁд…Өа№ҳгҒҰаҙӘж…ӨвҠ©е„¬вү«г…ңв«ғзқӘаҫҡзҰһвҙҷа©·жҪҖгј№вҪҠб–…в«Ҡа  б—Ҳз”ӨаЈҖд„ғвӮ аұівЈӮвҙ°аұ§дҗҙбЈҒбҠ…ВӮбө„бә§жҰғЭғгҗҙбҒЁж‘ҙеұ°бҗӘдЁ№вЁәдң¶еҗӨеҝғбӢҙеӨҲбЈ¬еҺӮзғёжҮҒзҠўеҢЎа¬Һб®№зЈҰжҲЎУӯд—’nдҸҖПӢдЁ гҝ•вҖўзүҜдӨ·аЎўжүҳаҜ§еұўаІҶзҡңаҘҙдұҫбў–бҰғдҲ·б§ҖеҖўб”ә#гӢҖВҙвЁ вә“г–ҫд•‘г¶јзҒ”бҺІзҢҝГ„б‘ңжЎҫзұ б“ғзҸҹг°«з°ўдӣҢа°Ҷаә®а« з°Ұж‘№вұұвӘ°ЖҰж®„гҠ§К°аӘЈеҮӨа¶«аөҢЬ¬еҒӨвӨІбғ„бҲ®бҒ№в–®вӢӘзҒҡЬ°ж№©ЯҒжұӣдҘғвүңдҡ”в©қбҒ‘жҠҘдҳЁбғЈжҚҶбқ°еҠҡеҪҙв¶«в¶ҢеЈ–УұвғҶв№Ҹг  гӢҖдһҗвұқж“ҷгіҗбҲҒвҗёРҚОәжҙҪвҡ„б’ еҺөдөҘвқҪд·ҘбІөжј…в№ізҸӣвӢ„вј’еҫҝд°қЖҖаӨ«зҖҫеҗ«вҒ©е’ЈгҶһб”…дө¬Эҗжҳ¬ЯӨбұ–дҮ°Ф№д•°бұӮдӣ°віҒв•ўШҰд„ҒжҳӘЕЎеЈҘЯ—дҲҳдҠ–в»»еӨ–е»әдҳ—зјӮдҗҜз’Ёг¬®бҮҪб§ӯгІҹаЈҷг¶–жҗ зӘҫдҖҝе¶ҲЕӮзҢӣг®јвҖҰеқҷд„—бөібҒЈаҰӢд®ҖеҺҢдәӣвӨүб·–в¬өжӢҢдғўгҰ§еӘ·е©ёвҘ§жүЎзҺ·аўје¬ӢгҰҡзҳ•вўҰзҹ©зјһдҖ“бҜҝг Һз·ҶеұҘд”јЭҰд”ҢдөҳеЈ—еЁ№еЈүбӯүг©Ҳб„ӯЬјб•ЈаҪ–е…ӨдһЁЮӣзҖҮдӨ¬дҶ…аөҒдЈҮзңҜбҫ·зіҰеҝ—з»Јжҫ®гЎ“бәҶгҢҘдҗҠжҺЁvбӨҠж”Ҷв¬ӮДҠдҢҗжјҘг—јбјҖаҙҜжҲңбҗЎвҰ”ДҖгҖўж№Ҷвӣјд«°ГҷзӘ аЁ а° жҘҷвҖ§е»Ҙг®№ж¬—б§Ӯж¬°ВңбЁӮз°ЁР”дҪізӨ·дёӢбҹүеҰқЗ’е¬Ёеғ–еҚЈеғ‘вӯҒаЁәжҲҢГЈг·Ҳг¬„бәўЪғBбқЈг„ҳдІұзўҙгІҸдүҳдӘҘаӯҖаІЎаӨҷМұаӨҪжЈҡОүгӨ«жӨіЕҘб‘Әд—ҡЭіжһҺеҖ а©өд“ё)вҗ дөӢвҖЈДҠ8жөҗЖ¶зә ајңеҺЎ/бҚІбү§в№ҚдӢ ж¶¶д„ҳcШ¬дҮјбёЁжҙ©жү¶дӯ„д“Ҡж·Ҫзҷӯд §дҠівҘӮдҗҲгЁ·б’–вӢ©з¬Ұг“іжҜҢдұһИҮе–Өе»‘еўқбЁҘвҪ°еқҫдЈҠгҗҰРӯвЁҘЗӨбЎ“жӮІб ёгӯӯжЎёдҚҗгӨ®аё¶СұдёұвҒҳбјІжҺҙдҒҹа ҘвЎҰдәүг„ҖдЎӮа»Ідҳ·гұҳбҜ„ж‘Ҹв ҒГӘаІұд»®зҖ«дә¬жҫҪЙҜе‘”аҫӮWж№°ИҒЩҮ`жң№дөІб¬ҖбёәЬңгҝ§еұәЪ¶.е—ҳгҶӯаӨӘж—”д¬°Iвә а»Өг…¶бӯҚвҶҳдҰҷвҘҲзЁ‘бҘ§ж¶¶аЈәвҗҙбўӮбҒүеҜ„вҘҮдғқвҪҪз‘·е®§жҖёв¬җеҝұеҚ»гҒҖе‘ғеҮҚЛ©дЁәзө№бқўзӮ®вӨҲг·’ж‘Ҳеһ–жҠ«з”ҶТ°жҚҸа®үб№ўаҰ‘б‘„аәЈбӢёжғ…ТҜдӘҹж‘°дӨ№д №г Ұг«ҺжҷҖвӣӨВҖбІҫжҲ гһ»еҖЎд“і2аәҚвІҗбҖЎвҢҺХҢЛҪГ‘бҘЎжқӣжҗ°д–өзҙҹдӯ¶бјғд‘җжҲ«е’ЈбіӘбӣ°вӘҫдғібҖҜеӮҪгһҘзҜҢвӨібүідҪЁж°°ОЎг¬ дӢӮеҖ°вҒҸб“ҘзҰӯд”ёеІЁд ҪжӮөв‘іж”®б…Җа¬ЎеҗҜв¬ёД«аӘҳвӮҒзҒўзўұд”ўбҗәаҜёг’ўжҗіжҒЁеҫҠг°ҰЬҢгҲ®бӮҙаІҶбҺ’гҹёв©ЎаЎ”жЈӯві°еӮҙеһ»Ш°е®«гӣ·жҰЁеһ•г ®жұ К»дЁҢвҶ„В—еіҢЮјзқіаӯһВ¶г•¶дҮЁж„ г«–бҸҒТӨвЎөЯӢа№Ӯд•ўвҷ„гүҰдҘҙдҷңжІҙзЈ§е№Је‘Ңбӯ•бұҸгҰқгһ з„Өдҳ…бёӢжӣІжұўб«»дғҶз«Ҙв©¶гүҪз… зұЎгҒәаІқаөӢбҖЁе•ғбӨјдӮ„зІЎвҖұН®зҰҰаІ…вҫӣжІЈдӮҝвҳ”ГәвҸһз№ЎвҒҸжјҲвҙұеӮҹеҖҰд ®ЖҘв«ҘдҒҝвЁ ИұеҖЈзөіЭҗДӘдӘҗб«„гҠ¬ЖұбјҖBд•ібҜҒдў®в®–дәёвҹөТ°Ф«еҹҖз‘ҒдҢӘгҮҙг‘үз•Ҹа§”зҙҝвҪҘбӘҫд–•бәҲвҠҲ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":2548,"_status":"completed","_startTimestamp":1775293233415351,"_endTimestamp":1775293233421145},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"555","comment":"","_id":1573,"_uid":"b37deaeb-e4ef-4de4-ac8a-47a302996081","_cid":555,"_ctime":1775293161884,"_sid":32,"_stime":1775293231564,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":34454,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T09:00:31.256Z","time":270,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNkF2G&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"177"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkF2G"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"postData":{"mimeType":"text/plain","text":"173:42184[\"handler.process\",{\"type\":\"hero\",\"action\":\"getAttrs\",\"userId\":\"33cabb81-987d-4712-81c8-0d88b4c63132\",\"heros\":[\"bc01476c-19d6-4660-8e3b-cb53e2f6b326\"],\"version\":\"1.0\"}]"},"headersSize":309,"bodySize":177,"_status":"completed","_startTimestamp":1775293231256514,"_endTimestamp":1775293231266128},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io"