ment":"","_id":754,"_uid":"0edec58c-c361-4da4-9b4c-2f465d08c572","_cid":338,"_ctime":1775292633694,"_sid":18,"_stime":1775292661921,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:51:01.622Z","time":260,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNi3zd&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNi3zd"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292661622748,"_endTimestamp":1775292661639941},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:51:02 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3941"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":4942,"mimeType":"text/plain","text":"1341:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе ЈбЈ®жұёДҖЖӮеҰ‘бӣҸRд© ОӨа°Ҝв„Ёгҷ•б©ёжҙјд»¶а¬ вң«еӣәжҖ«зӮ°дҲҖбғ еӢ¬Щңгө…аЈӨжӘ Ы°МҲв–ёжҖӘбё вўҫИҰвҖ©зҒҲдҶІеҖ жҙ…аіҠж¶қвҮҖС„вҚ…г—ғдҒҖТ°зіҗжЁӨвҖЎд®ҶжҰёг Ўбў·еҶҫвҘҗ$дҝҘвҡҠдҠ“г•Ңб·Ңдӯ“бҰ©бҢ”ж§¶б¶Ҷж¶ӘгҰҝд№ЎгӣігҚ…ж¶«ең‘з’ІдӨЎд§ЎгЎӘаӨӨгҒӮбўүбҗ гҲёе«„вҝ®К ВҺжӣҗж”“дҗҒгҷӣС§дҢўжӣҠКЁвӮ°зҳ а¶„дқ¬дҪұаЎ вүЈдҢ°Р«зҘЁзЎ–аё°Л©ж„”бӮёе…ҠзјҲвҗӘSз‘ҠгЁІдҮӮеҖ№б’јв„ЈеӮҷЖўд“үв‘ңФӨві«дҳҲвңӯдӘўвӮҳв»ұгҖөЧҙВёв”°в’ІеӨәв¶·ж–ӘеЈҲжөөФҠе©Ұаёҷдұ“в—ӨгҗөвўҡдЁ°в„іб•ІдіҲдҺҙб•ҲвЈҷв»–ж¶әеЁ§зӮІбөҸаҜ—вҝөгөҰдҝҢж ӯН¶д”ӯвЈ·ж¶ұдіҘжҮөеҙ¶зҹ„жё—зёҷжӘқбҜ”дҡ®д®»вҰӯзҺЎеӢҒбұҚбҚ…д“„бЈҜдҢ®зҡүж·ҜФҫдҮҖеө•зёҶе¶’жҰҚеҚ–е®ҳИҳвҚҖвҸҡжңҸе¶ҫжҮӮвұ®Я©з¶”гӯҚдҸҖвҙҡеЈўжҸқзІҷгІҺеҹӯд«Ңгҙӯг—¶вӢ·гў·зһ«зҫҲеЁјеҢ»зӨңеІҪвқ№еҳҷжҜҫж°—дҺҖг№ҚдҸҗгқңбҸ”зҮҪеҶҜзҲҢзҫұзҖўдҝҡзҚқбҜҶгҶјгҢөзҮ¬г–ҙа°ҚзҝғзҚјвҺўа¶ңе®ёаҘўвўңзҺ¬дҜ‘е–ўгўҗаұЈж·ҮзҶёжҙ©аЎңж‘ӘзҗЈдҫҫаЈңг’’а«ңбҳЈаәЈж’–аөқв¶»зҠјб·қаҪЈж»ӢаәӮзӮҺа°ІеҜ’аЎёз¬ёдөқбҠ…аөҚзЎІаІ”аӯ—з—қгҝҶаҰЈзұ°аөіжІӣз‘ғеІӮдЎ’з©ігқ’жұӨзҷўбҳӯз–”г¶Өд№ңвІңаҰіж©¬жҸ’е©ЈдЎҪг©ҝаі“вұ»дӨғаәҪдўЈе©Ұаұңз№©зӢ“Ж‘дӨҢдёҜаё“д© дӨўжҝ’аўҳаӘ„аЁ’б…ІвәӘвҘЎа®Әе¶№дёӮгҘ вҜ«зӣҒа¶ЁаұідЈғдҰ•а»јгҚҢвҹ“зҜ•вҝів•Ҫв№Ја¶ғеғӘжҶҳдҫўв–ӢдӯҠб–Јв»ңеөөв°Ӣд№ҙд«Ӯж©°вёәе¶ҒвіӘд©ӨжҘІвҫұдЈҠвҺ–гҢ»гўҹвәіОӣзӢӯб¶•зҺјжҷ«гҖ’НҪвёіз®•зҢ“д¶ҳж§ӢгҰҷжӨҢЮҲвј“аӯҪж®ӢеҺҢвіӣеһҚг…ҡеҶӣж©’бөіеһәг¶Ӣж¶Ҡжқ§жӯ»вқ“жҜқаҘІж·Ҡб„ғжЁҰжЎўжІӮаҝүж§»ж¶ғе’ӢвңөгңӣаәҚжҝігұ¬в°ҰгЈ°бјҠвҫҠб«ЈжЈҙжө»аӨүбөҳзӨҸв«әз„қжЎ§б„ҮгҡҰгӘ–вҰҮзҫҲаӨңв”‘а©Ӣгғ»жј§г“·жҜӮаҰ—бӨ¶бЈўбј·вҷӘб№ҠгҙҲе°ҮжҢңвЁ¶еӢёбҰ·г“әжҙҮж…іа©¶е«ӯд«ҰзҢів¬Үз¬”е§Ҷдңҗж·җвҺ„еҪ—б¬…еЁіаЈӯеІ•аҙүаӯҰзҫ’еӘ—бқ«е®ёзӣ§еҰ“Ь—е°§гј’бӨ§б“Ҙдҙ–дҲһв§·дғҘбұ¶бңҒдҘ¶вҮҝеҪ·зң•б©®д»әж¬ҜзҲҗеў—бЁҢд№–е—ҷбҰҰб«ҰгҘ»д§ұг®ҜвҳҡгӘҜајһвіҡе—Һе««гҳҖгҝҺе«ғвӘҸвӣҫе ҜбҚЎгҫ“б·©е®–бҲ„в®Ҹзёӣгӣ®бӯәгёҸд®•дё®е—ұжЎ¶зЁҷг®ҝШҗж«Ңеһ©гӯ–гҗңб Ұа°Қеәҫе“Ҫгјҫз®ҖбЈҫеһҹе©һжҸҘг«ҜаӨҷзёҫаЁһг§һгҲҗдў•а»…зІҜе Ҡз·№а»Ҡг©ҫжҳ‘зӯҹбҖ“б°·г„һеҲҮж№ бҗөгҝҰж°ҝеҰҡВ—зЎҜб°“б°јзҮҺбёҠжӣәжңңеҜ§еіҸдҲӨбӮ–зҶёвЈҙбҪҜз—ЎжҠҖвҶ“в–ўв·ӯОҷеәҳаЎҘзӨ°з ӯдјёеғҡб§«вҮҗбҖўеҝ©дҚҗгҖӣдҸғзЈҸвң«Е—дҢЎж·Һжёөдң‘е·ІдҠҗгҶҰзҡ д‘“бӮЁб¬ұаөһИөЪ’бўҪбҒ‘вӢӨв”§гҹ„дңҸбҪҗаӨҶз”Ұгё»е©ҢбЁЈдқ дҙ¬вҲҠвҢЈдҚ·аҝібӨҳаҙҒд¬ігңҡб–…дү„зҙ”вӘҳеҮҸжўҗз’«гј»г‘ҫз„үз…„бёӮа№Ӯвө¬гҰәе‘ҫЧҳзі—зЈ»а¬‘ЯҖбҶәбҫ¬ж…үзҙҗвҡ’гҡөЦӣвІІгЎ»О е¬ӨеўҺа» 6д¬°Р¶жҒҖГ„е°«дӢӨбҗ б“ҳВ зһ вӨ«ЗЎгҳ¶б„ҖФ«жүүдҗҹв®”Т«аӨ бӮЎг„ҢаҘІ(жң д•ҺДӮбі…е©Җж—”аө«бўӢНүдҶөSФ б°©г„Һа§ЎжҖўв•“г©®дқ„бҺ дҶ¶гҒ®В‘в¬ЁеҲЁЪӮЪҷв‘ёв“Ёб“ҮДҖеўӯгҰЈбҠҗеҖәжӮјбҡ„ж№ӣЗ„зҡҜв„„з–Ёеў®жғ–аЎ’гҢ гҲӘвЁ еҳІжҺҙд„ бҒҮIдҶёбЁҢаЎІдӯӮ<аі а ҪдҒ в¶§гі°д»№ФҪбұ«ЬЎб· дҮёб« а©§дҘ бҰ§б”Ӣд‘үдҶұжҖ¶СІжқҹгҺјб¶ўдҰҚв’ңз„ӘдЈ¬г…ұж’ҝг…ҖЫўеөҚд®…еЁҖгҰҷд ’жӣҜгӯҜд»ҒЬӮВһб®Ҫжұӣеҗҷг‘Әг©¶бӣҳжҝўд”үвё…бҙівҶўеһӮд…ҶгўјгһҘг•Ҝв–ёаЈүај·аӯұгҒ…б—ҲбҷҠбҘқвҳ…вһҘжӮҢв ’ж–Өж¬ӣвЈЎбұҙз—’еҖ¬дёӘ(аҰҖв…ҘдғҳЕ«е“ҲЗ…бңӨзҖӨаө“Н—бҸ®вҙ„вҖјбӮӨвўҚд‘“З•е•ёе–ҠбӘіз‘„ж©Ӯг ҖзҘӘгҡҶд’Ҙж«ӣвҫ•ж”„г–ҡеҙӢд§јж«”г–·е•Өе•Ҷд—ҢеӣҸдё®б•»вҙ¬б•»ж•¶аў¶гҢ…е©Қжғҙжӯ«еіҜдһҖг®іХ—б‘Ід¬¶б…ҺгЁўбҷ„ж“¬бҜӢзӢ‘г„ еўӯдҘ«ДЎдҚңзҗҡвёЎдҘўв…ҳг§ӯг“ҸвёҘа¶өДҲеҺіеһӘЗҮв—”гўЎГҳгҹҺжҷ“Д№гҰ дё„еЎ’г“Ҷа«ҖајҮеЎҗжҡјд„ЎеұӢОҲаЁәб–•е№ҠдЎұгҠ¶ВҶбҚӯб• г¬ЈбЎҫж®Ҳг”ӯЧұбҖҠР¶гӢҫб« аЎҖжҗ°гҺЎзјғвҫұв•ҪбұҰеҖІгҸҶж”Һбӯ„в°№дҮҙд…ӯжӢҳД№бң§гўҖе§ҡаӯҶеүҢб…ӮЪҺб’ӨвғЁб°¶вәҚз«ұб—¶МҖд¬ҫдҷҖЪҒв…ӨЕҒз•©г ёжӘҘжҠ¶гғөбЈҗзӮ®бӮҳз”…ж…»аІҶзјӯзұ•гҒөдӯіеҘғЬ°ЬӨб¬¶Г„гҫҒеһҙдӢ®е’ӯд¬ғжЎәг Өаі’з•‘е”Ҡв””гӨӢгҗЁзҰҺжғҹж«•е„№е№–дҖҡеҒӢзЈјз§®гә«У¶д–ҸгҲ—бҝЎзҘ…зҗҠгЁЎжҘӨбҹ‘гҘҜвІғд°Ҙзһҫдё§дҹӯбҘ·дҸЎж„‘д—Җе®ІжүҙбёЈдұЁеҺҪШҳеӨ©е•ӣд®ұг…Җајұе°ңз…Ҝг•Јжғүж·Ҡв—іжөһЮ©в¬үеҰ§вӣҹд°ЁгҚЁвӢ©зў бҺўб°®еҰӢбӢ’еЈқг®әе¶қз„Ұж®·г«әв»өж¶ёзҶҺе»«еҝ»а®ҷгіҮвӯ”гқҠжһҜбӣҜвһ•з•ҫвӣ•б№ӢжҮҳж®ҘгҪ–г®ӢбӢҮв§Ҹдүёжҝёб«»гҚ—зҒёд“–е•ігҳ¶вёҪЩ«гғ”еҢ—аұҪжҙҚг »е§ӯгҮ‘вҰҸгІҪвё¶гҷҗз”Һв¬…ајқдҜ»б–ёеЈӢз—’а·ҖзҰ·б•Ҷаә°е©ғајһж№ЈзҪҺд‘§еҪ«г«ҹаӯҮајҜеҺҺжӮ‘жҹӯе¬ӣд“өж·јЧҺејқзІҹа®§ЕҜдӘҚе…һз®Қб•©в·”У№бҸҳе§ҮВ”з¬№гӮ®жҙҜжҷҒз§ҚЫЎжҺЈд№ёб¶ҰгӯҮд·”жөҲзј–зңәд№Әж»«в—·вҙұеіҡг «ЫӯзӘ—ж°’зқ®д–„вәөзҰҪгј—дқҗд„¬аҜҷеў·еҙҪб°ЁГ°Дө`!ж’ЁДЈж ЎTа  дЎҳЮҖг®җеӮ¶зҸЁгҖ¶зҖҖаӨ гҗ·ИҖбјҘеүҖ  \"},null]464:4315[{\"ret\":0,\"compress\":true,\"serverTime\":1775292662860,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвҲ зҢёжҖЁбҢ¬вЁЈб·‘Kд§”ЙЁЕҗеҒ“бҝһвё вҢұ<В¬Г”Вјз„ЎжұқеҲ е ¶вҗўгҚӘдҝ®бөҖЖ§еІҳдўөз° жҙқбҗҳгӣ‘вғўжј бӯӨа¬ҺгЁ•дҘ“з®“з‘Қв·Өа®ҲзҰ…зё еҷјбЎЁеңәжғӮеҠөдў Ж”г  гқ”бҢ©бІұаҘҖПҮж«җИ•г ¬жҳӨбҸҲбғҲдҳЈ%е©ҡдҖ«зӮөвүһгұһдң°е©Ұж—ҲвӮүдҲөг§’аҙ вҫ®бүЎЛ¶жІҙзһ–з°ҒбҠһеҙһеЈЁбӣ№еҲҘв®Ҳж«¬зЁұбүҠз№јеўҠзҫІг§ҡжЎ§зҢҸж ҷжӣғб°ө