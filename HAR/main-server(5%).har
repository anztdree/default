{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiBNI"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292691939735,"_endTimestamp":1775292691948373},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:51:34 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2952"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":3660,"mimeType":"text/plain","text":"1327:4330[{\"ret\":0,\"compress\":true,\"serverTime\":1775292694921,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁЪҗб— еӯ”аҫҖб¶ЁЗҒAдӮғб ўвІҗвіҡв·җЛғбңўвҘғGВІlеҗ¬жҳҳеӮ бҶ°дҖ®fznвў зҷҺдӨ вІ“жҲЎбҘ„вңөаІ°ГҘж©”вЎІз„ гҷҫзҮңж°“бҮ¶дҺҜУҖдҖ»е¶ІХјд”ӮДүгӘҢРӢа  бҡӨж° гҰ¬О»&г“ вҠЈзіЁжҒҗг‘„гұЁбұ·в№Һдұ©зҸўгҸӨФһжІ”ЙҳдҘІжҖ«зҒғв ўеҰ”зүҷгүңеөЈвЈ„еҡ д—Ңе”•а¬Ёеұјг©¬бЎҒ&жӮ Ы°в”§еҘ‘еұҙв№…в»ҒеӮӯвҮғЖўзҢ“б•ҘУҶд¶ҲжҰІеҘ«д‘Қб—ӢдӘ«вҢ„д©ӘгЎӮді»бҢ ЙҶвүўдҠ®аЎҒзҗҷг–‘вөЈжӯҗВҘС¶(бҢЎдӮҢа№ҙгҶўеҙғг№ЁеҺҰгғғв® ЖідҠҖТҺдөұИңдҹҶ&вўӯе„ҳбқӨв«ҒгҒ–бӮ°Н№дЈғвЈЈаҫӨб„„е№ҠШәбӨ„бЈ©д«§жӢҳзҫІдҫӮжЁ”жЈ Йұд…ёгҖ аұүдғҒеЎҗЦҙвҜ“дҰҷвІҰб®«бҠ№в№°е–Ід” бҮ¬дҢЁзӮҒбҚ№б•©зЁңдҮҲжј©жўҲбҗҙжҘ©еҢҗгҖ·еҸҘв·Ұж·Ҡ б•җ[е¶Ёе—ӣЬғгўёвҒӨж•ӮдЎҰжғЎРәв©ӢаӨ„еҶёжҡіж‘ғХңгҳјжңҠзЈўбҲәв‘„дҘ§вӢҙв«ҳжІ—бҠЁдӮЎзіҗбўҶбЈӘд Ҫв…ӢзӣҰгҖ б•ҫжә•зҶҘз§ҷж¶—зұ‘е¬ӯдҚғдҲ®дҫ…зҖҶгҚёз®”гӘ—дқЁзҺҘа¶җжҹҘе№үП„б§«жҫ’жё¬дһҪжү¬ж¶Ҫз¬ӨеҒҡб¶®г ғзҪҶ г¶ҖвёІвҲҖЖ…СӢз•ҳбҖҳб…ҙдӣқдғЎТҙаҘғз«’зјҙгҢ®б©Ёгү¬7в‘іДҢНЁQбҸ©жҘӢб…ӯаІ°аёӘаҰЁа°§гҶҖб°Ҡв·«вһўГҙвәЁвҲӘЦ®еҶҠб–ҮдҮҶвіЈзЎ’бӘӘгҶ”вҰЁвҠӨв’«жҶҠа°«еҒ®вјӯаҘ„бӮЁвҮӨвҠ«жҮ„г‘ӘжӢҳв„ӨеҶҳН®вҢЎбҸӘз§ҫвҹӯзӨ’гӘ®б…¬г’№дҒЎгЎҮдІҒвҷҶдёҮвҢғЕҝбҘҸжҗ©вўҠв” жғҚв—·вҚҚеӢҝгӢүж“өб–өдұҪХӮдғүгғҖж‘•а°ӯб–…гіғгүҷв«Һе‘…вһөе’ңзҡҸзҮҪвјҖв°Ҝа¬ҶаӘ—бЎ©з—ҜбҫҺа¬Ӯе·ғзҳқвҰҝе–ӮжўҺаҙұб№„д¶ғгІҮаӨ—б№Ід·Ңд№ҙНӘжҖ»діҒЙҝж–җдһҘвҒҲе№ғвұҰвЈҜвҙ»б№ҢжІүб®ҒжөӮеҶ…еІұв„Ёб¶§а§Үе·ӣвҲҒб·”з”Ҡб«ӮзҪ·д–ұв©ҖзҶҡеӨҮжі·аЈғв©’з—ӮбӘ¶зЈәеүҜгҠғвӯҸаёүеЁҸаёӨзұҝХҙвЎҹОғдӮҹвҖҶ еҗІЛ з°ЎбҘҖдҡӮРҖжҳЁдү bдӢ°зҳЎдӢҗдҺЁМҠд–ҖвҠЁеҷҘдҘЁеөЎвӢҲеҸЈвҠҙг‘«вҘӨг„ӨбҶҳв„©б…¬ГЁеҒҠЫ©еғҳбӘӯжҺҠв„«еҮ„гўӘеў®г©—з…ҙжІұзЈһаҝ©гҶҙж»әТҖСҚв¬—в”ғеҢҶдҢҖеЁ¬д№Ҡеү¬е°ҺгӢјдҺ»ж•ўж¶ҝзҚҘдү„зҚ·а®ҙб•ҢдһөзҸ•вҫІе“ҷбЈҲаӘөдЎёКІз«ҙаө–зұҪб¬ҡеҙҮеҷқа©·зҗЈвЎҙд«’дҺ®дёңг…°в¬івЁӮв«“в·ҷжӣҝб•ҝдіӣаіјг ңвЎҹдҢәзҫ¬ж¬Ӣвҳ жІ’вқҪж®•зҫҲбӘ§СөзҡӯеҫүжӣҶзӣҪа°ҶеҢҲгһ¶зҪҠе©—гӘ“е©ӯжІҹеёғеҶјТҪдҮҙд’®еёҺв…®зҗҮжқҺжҸ…з¶ҺиҖҮдӨ зҗәМӘжҜёзӘҖжҹҪз®һд“Ҹз¬Ўз¶ЈдӢјгөёд„Ёз„өЯӨбӨ»Ь‘ЕғвҸұеү“ЖӨд°©б„ӨбҠҜеЎ¬гўӯжҢЁвўҜж…„вөӨеӮӨвҘҡдӣ–вӮӯгӮүеҜ§вҳҙеҘЎгҮ„гҚ‘еҸ№дүҰзӣӘжӘҹеүҠеҶ”зӨҘжЎјбқҢд¶–ж”ңе«җгҠ…дҒұж–ҘдўӘвӢ–ФҪвҗўаҰҶеҡҖбё„бҒғг–ӯбүҷбҠЎеӯҮвіұд–қгҚ–г“Ҷзұ¶жү‘еҘ¶жёҚдҷӮаӘўвҢөЖөг¬«еҮ¬дөғд»ұв ҢаөәеҰӢб—ҲдҸӣв°ҳгў’вқҳзғ®З„б¬ҷжҷ•е…ұбІҡе–ҰзҸҹг„“бӘ‘вӮҝгӢ®жҰҮжҮұвҸҚб‘•ОҜУҷв‘ҘзҶ·вёҒб¶ҢНҡвҖҺзІ•жҺ•гҫұеіҝЧӣб»ӣгҜқвһҗв„ҰеҷўејҚд„ҲвҰӨПҙб—Ҳв’ҳвҶ©аЎҜаұ–еҗўжҶҲзӘ§б„Қа©ұзҖ»е…ҲеӘӣвўҫвӮ Н жҪҪЪЁб ЎеҒўЭҒеҲЈв…·еЈўвҗ¶зӯҢвҡҰбҒҺб‘ҳа®«еғҡаҝ Д дҰүе№ЁбҰҝжғүбһӘгІ•б–ҶаЁ°з»…в®ҚдҝҜдіҝдў°дӨ°е¬ дЈ•вЈҲаҝ’9д№өбғҢб«јЙөд»ЁЛҶеӢ еҳӯд•Өа¶ӘжҗҫбҮҲб’ўбЎӮж·•еҚҲзҒӯе©ҰбҸҗгӯӮеҠ–бҲөК„вҖҖб»ІбіҢв ҠжЎ«в§•бў‘гҳ¶аЎҺгҳ·б«ұжұ•бҮ§дҚғеЁҡвҸҲд””жӣҙдң№аҝәгӨіжў§вЈғб—№вҸӢеә…в»қгӘҲз·Ігң®з–ҺаЎҒзҘҪж’ӮзўҜз•¬вҖ»дІ–а©ёе„“Нұз’Ұдҡүбё®бҺІзҢ§жҠўг©ўз °дҮҲбІўвҫӮгң°жҲ¬еғӨЗқбЁӯаҙҙб“ЈзЁәдҗҗбўҰдҗ©ЫҶбЎҫдЁ”жЈ„зј©жӮҒвҪ…е§Үе®өаҜ•жҘҫг–һЖҒвҰҝжЈІвҠҰеҢҹд»Ҷд«ҖЦҹв ®г“®дј¶б№ҫжҘЎвұҠвҚңзҸҺг®“еӮҸЮҢзј¬аҙҸвқ–з“ҮдәҒа¶ҢбҶ·б•ҶвӮҰб·’гӢ¬дҡҮдіҘдәөбӢӘШһж«“дҮҙбҙ—бҰҘж•·ЫҖд„ҒдқҚе үбҫҲгҘҰе·¬з©ӨзҚҢдҙ„бҒ«е ӮгҶ’еҙҒа§ҷФјг¬—бӢӮдҪқвҸҹбҳ„б»һдҡңдҜігөҖб„ҡдҢҙдҠҹбҠӮжҷҲаҙ§ді“ЯҳбҰҜв‘ҸеЈҜаЁ•зўғзҮҡаӯ°е°№бүЁЭЎеҗЎзў‘бҠҰдЎҙгҲӮзҙ§бӮІqеҜӘзғҙбўўж©’д«„жі еӢ«зҹЁв–Ұеғ—жҫізҹҝвӘ№г—ҙеҘ¶гҗ“аұҲзҪ“б”…Щӯж—ҠжҜ«а№ЎеҚјд§„гӘ’еўӘеҙӢа«ӯгҺЎе•№з•–дһҲгҜҷб’өгҢҰв·Ҳж–ҰгЈ¬ж¬„жҠ№вҲібҘҘбқ’жҸҸеҖӘгҮөзӯ’жҗ§бӮ—еӮ«вӘҢд¶Ҫг—ҫжҹёзӣҹгҸқг§·з¶…зҲЁжӢҙг»¬з„•жҪ№бҶ гҜ•гүҗЮҺвЎ–бҪғж—ҫе№ҶгІӯаҜҡдЈ·аөҗвҜғгҮ…еІһг…—зұҹж“Ҷд–©Мів«ҖзҒ»г…°е®әгҸ§жӢҳбўўзҗ©бЁЁгӣ вӢ„д№°з„ЈГ¬в·қжҲ§вҒ„еҰҒз№ҷвҚӮж¬°зҡ№бқһаІөвҳ…аҝ»з“Ӣв–§вҒҘз“үв—’жғҙе“…ж¬…зҰ»в§јдҹ«аҜһвҙҘв–•г–ІеҠӘз«’ж§ҚжӯЎвҪөПҠеҹізӢӮвҺҡвў„е–ҒдҫӨг«Ӣб–ңаЎ¬жҰ»е•—е‘ҡжӢІеҗҝві®еӮ“з–әе°ҢгғӢв©ҷг¶№жҮҝе…•зӮ«гҠҚвҹ»аә—еҡјдҗҫз”ҸвіҷгҸӯб–җг…јаўңз’°жөҰгҪҠа¶ҲжЎұжЈ–зӣЈзЈөз«ҹбҫ§д§җаӯівҗ·еҚёб“ёзӨҗеҮҳг–ҘЦҘжғұаҙұж——вҶёдҘҶбҶ’дҲ°а°ўдЎ‘бҡғв”ҰеЈӨЫҗвҗ©вғҳОӮУ«жҢ©ж•Ӣб‘ўбҮһе©ІжҳІгҮӯдәҡвқ§г—ӯдӘ„зқҷвҠ№дј…б·ізӘәе¬әгј„дӢ•гӯҖгқ¬жӮһжҝ жҒјбңіеЎқз·№з“үвұ“жһ–жңҗвӯҙбіөз•ҷе’јгҪ—б°ҪаҪ“зҷҫг‘ұвҝқгҚҚгҗ—зі§Сҡдҹёвқ©еҢқгҸ’бөўбЁҰб’јЮ¬з«ӯЗёвҙҫвҝҸд—ёб°ӯв“•в№үг¬Үг—ҪбҹЈвҙҜе№ҙг–ҒзҹЁвҡҝеҷ‘е‘ҖШқж°«д’Ңе җдІ®в¬қдӣҰжҢ§гҒҗдӮ Р§вүіеҶ г ®дғЁаҙ в•ҡвҺ„г°Ұж“ҫ`жІҙеӮ…О©б”Ё  \"}]"},"redirectURL":"","headersSize":260,"bodySize":2952,"_status":"completed","_startTimestamp":1775292693921842,"_endTimestamp":1775292693931486},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":812,"_uid":"b52ec8c0-0cef-4a7b-ac70-9085e4dd521c","_cid":338,"_ctime":1775292633694,"_sid":39,"_stime":1775292691939,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:51:31.623Z","time":262,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiBIY&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"3"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiBIY"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"