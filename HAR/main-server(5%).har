ue":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292757212554,"_endTimestamp":1775292757218942},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:52:48 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1257"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":1503,"mimeType":"text/plain","text":"579:4357[{\"ret\":0,\"compress\":true,\"serverTime\":1775292768582,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвһ еқ‘ж ЈбҶ б®¬ВҢЛүвӣӨв”Јбі°аҘҖКҒвҖ№дұҹбң бҶӨдҖ®fznг’ зҳЎзӨ вұӢгҲЎбЁ…ж Ҷдҫ°Г бөҡвүҰзё гҡҒе§ўгӯҳеӮ„аӨ»дҖ¬жҖөдҢҪзЎ¬гҙ‘Ы•еҚҝаӯҺзһөжҚӘдҳ…бёәаҰғвӢһЙ вҷӢд’‘ж…’еҮҳв”„д‘№=бЈідұ Ч‘дҺҗбҶ„г  зҙәбЎҺбҰ аЎҶМҘвҒӮдҮҠд’Җб Ід–ңбҗЁеҝІФҠаҜЈаІӢв’ҙбҠӨг–ӘеҸҝбөҒеҖҘзӨӮж—»дҚӨеҮҠз„„зӘһПҚгҒҢвЈҢд„јдҚғРҪУҙзӢ…вЈҸд§ұбј«еҷҸзғўжҜқзғ”еЈӨзҮӮзіёвҒ”аҫўР‘ж…ңзҝҲжЁҶЛҰбҸ•д„©д·ҒеҒЁЛҮдҗҖб•ӮбҠ–дҘұжӨҰбҺӨвҘұд•ҺбҲҘдӨҰаә бјЎбҠ©еӨәжә—бҸүв©№жҷӘжіҺб¶ӯжҢӯв¶ҫе©¶жј•гҢ–в’Ңд ’зҚҠвӮҸбҲ©б¶„зҒ°е…ӘдҚҘзҡ‘бңӘд®„жӯ”бЁҮзүұд–ҡбӯҸзӢ‘д•®б—Ҹа°‘д–ҒбҝүжӮ”еүҰж©“бӘ©бҙӯб“¬е·–ж«ҺжҚ‘жҰӨдј©жҸ„гүҚд®«бӨӢгҺҶз§ӮжјҢзҢҚз¶Ҝб°ӢзҸҪд…ЁгҸҒаҜЈгҶүеҘҺдҡ…гЈјеӮ•вҲ®ж®ҡеҙјж©ів‘®дҸҺдң•еҙӣеўҺдһӯжӢ®аұҮбӯҫв¬Ӯбҫ¶еўҫеӯ·еңҗгӘҪгҘЈдӘЁгў©е…Үгҳ»гҡұж„ҙгіјаҝӣд”җзІҝзҡҫХЁгұҶв©ӯбҒҗд–ҫаә“дЁ…гҒҫаә«е—ўз©ҫаҝ«в·ҰдөҝбҲҜвүҰд“ҪгөҜжЎ©бҗ’вұ®жӘӨд®ҘзҶәеӣҹж·өз—¶дҗҲж№•дҜүПһві•вөұв®Ҷж‘”вҙҸдЈҪв§ҺдөҸб· зўҫвһҚУһбү„б·Ҝб…ҶбөҫФҶж’ұг”ҢжҙҮЦҢд•ұа¬ҒдҚ‘гҷ„в’—вҜ§еҙЁж«ЎзөҠб ӢдҸүвҖҙЙғв«©з•ҫвәҘв–ЈгҺҸгғүбҲ·в–ғбңҒб” зЁёжҚ®г¬әзЎҪг—ҚжҚҚвјұвҚ®вЁҫв’”вӮҝаө®бҳәбҠҗеңғеӮ·вў°вҠӨзәҺдө—г’іе…ЁеІҫвҠӨе–үжІҲзҫҸвҙ»вһҖжҢҙдһ…б“ӣгҙғжёҢеҫҚбҢ§вһ…бү¬жІәбҘҪгһҢеҸ©вҙҚжұ”зҫөеҺҢз¬ғвҙ”дҰёгҸңзҶёеҲҜв©ҢгёҮвЁҸаӘҢд•ҢгҮҸвёҮв ә,бқЎе°ёЖҳ[ең Г¶б ҪдғһбәҜеҢ бҜҰеғ е°өЛҖвҲҙдҖ зҢӘеңӣзЁәеұ“бЎҰЛЈд«әв¬ҷв¬ӮвІғбЈҡвұ—в…Ҙаұғд•ӣа ҘжІҲвҡҲжҪ»жЈЈеӮҶУЎе«Ҡе§·вӘҺаұөаўҶаіЎең–дҮ”gб„¬ж«ЁвӯҝжӯҠдҮ»г¶јгЁ ВҘв Ҫв№Ӣзӯ§вЈ»з ІЧ вө¬РҒв‘ӣд“ бһӣвҙ в’Ёж«ёжҺ—зӣ‘б№җдҷ°еҚ№зҸ…гҺҢеҒ’вЁӘдҡ°аӯӯвҮӣзҗіП»з¬ӯвҡҖд¶‘в  бҠҲбҙ§бҗ ХҪПҙвҡҘеҮ”а»ӣајғКғОҙеҜҒзӨ°з°©зҘіж«үг„   \"}]"},"redirectURL":"","headersSize":260,"bodySize":1257,"_status":"completed","_startTimestamp":1775292767580144,"_endTimestamp":1775292767587574},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":975,"_uid":"e2c7e8aa-0da5-4daa-a49e-009e41ca2a31","_cid":338,"_ctime":1775292633694,"_sid":74,"_stime":1775292757212,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:36.869Z","time":287,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiRDn&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiRDn"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292756869628,"_endTimestamp":1775292756876388},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:52:38 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2546"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":3117,"mimeType":"text/plain","text":"1160:4356[{\"ret\":0,\"compress\":true,\"serverTime\":1775292757235,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖӨбҖ©жә¬Гӯзў б— гҺ¬а¬ дӨ бҢӘГ¬з…Ҳд ЎаІ„ВҗЙҗЛ°К“жҗ§гӮ®в ўжғёеҖ©діүв•ңзҠ ШұзЁ’гҠ”еҖЈгҺ¬вј°г·ібҒҝаҰ’д’ӘДүжҹҳДҡе‘җбјўбҗҫвүҒжҒҗзӮҗг’•д©җМұЫҺе№ЈдҫҢеҶұгЈЁвІ„гҒЁб„ёаұҡг•ұвҫҺаӨ§вҶӘб…ғеҮ‘зЈӨзҠҠвқҪбҰҪдЎ•жһ»зҢ«д—…зҢҺб ¬6ж” З’в„¬Д„дЈЈгЎӨвҖӨвҖҗГәгҗ дҘҡ!зӘ еў“вҒ„вҖҗаҪқгҗҘбәәИүгә е…ҘгқүбҡһгҲ ДІвҸҒдҷҖ$еҗҙаҪҗжһўг‘’бҹӣМұвҶҙгұ°ж№ҡКЈбҒҲ]С…д„ҖбҒ°вҰҒеЁЎеі–дҖҘвҘҙа  вІҳжҲЁдҷӨе…Ёб  ајҺбҖЎвіһбҗҙд“ҖДңбҷүЙҖЖҷзҳҪб• г…ҷзЈөбіЁе„үжҳҪЭӘзҖ°вҠ”аҫ®бҘҖбҒҒбҠі бёЁг¶ дҗғбҮӨа№ҖЙұдӮҠгҖ«ПЎдҖЁбӮ аұҒГҖжҺҷдғҰе—Җ5гҗ·вҪ“д°ә7жӣҢеЎ”зӯқдҫ¬ж’°в‘ҷд«…жЁ‘бҗ«еқҮдўҖг”Ўд«ҒеЁөбҡқдҚҖШҖеҒ•в…ўг©Іе®қеі„г®Ҫеһӣе–°в§қз©ҝеҫҖЯӘж„Җжү—зҸҶзҺҘа¬¬Еңдә ЗЎеҖ©ОҙЕҖаҰ <еҖЈж””ЕЎд«Үгә‘ в”ӨжүқжҖЈвҘҖжҢөгјҖJеҖ г—Җб°®зЎ зҒЈФ©дҗҒв‘ЁеәҘбҒҳбёӨЭңеҶҮдұ°жӘҜв„ўж• зұЎзӮ©бҠҷбҘӘеҗ„зІҷвҸҮб‘”НӮд№·аЈӘжёҜбҹЁдҙҘж…ёеј§бҘ…жҘјеғҲвӮөб–һеҳӨж«әеқ·з№Ұеҳ в„ҳеі§а ¶дӮҰбҗәФЈеү’аӨЈвЎЁНЎг©ҡаЎҗгӘӘбј¶з©’СӨеЎҗФ бӨ–бөўвҒҡбӢҮЪЁбҳҜдҮҠб„®вҮҲгқ жҮ‘д¬©жҶҳвЈ„бҮӨг№ҘбҮ№е’ҮгұҗЪғд°ҙбҰҮві»бҖӨгҙҰ1еӘҖЭ„жЁ бҳҳжҖ©вү°гҳўг§•гң—'аЈҗвҗІдҜј:вҗЁЭӨбҠЎЬўРЁд…Өа№ҳгҒҰаҙӘж…ӨвҠ©е„¬вү«г…ңв«ғзқӘаҫҡзҰһвҙҷа©·жҪҖгј№вҪҠб–…в«Ҡа  б—Ҳз”ӨаЈҖд„ғвӮ аұівЈӮвҙ°аұ§дҗҙбЈҒбҠ…ВӮбө„бә§жҰғЭғгҗҙбҒЁж‘ҙеұ°бҗӘдЁ№вЁәдң¶еҗӨеҝғбӢҙеӨҲбЈ¬еҺӮзғёжҮҒзҠўеҢЎа¬Һб®№зЈҰжҲЎУӯд—’nдҸҖПӢдЁ гҝ•вҖўзүҜдӨ·аЎўжүҳаҜ§еұўаІҶзҡңаҘҙдұҫбў–бҰғдҲ·б§ҖеҖўб”ә#гӢҖВҙвЁ вә“г–ҫд•‘г¶јзҒ”бҺІзҢҝГ„б‘ңжЎҫзұ б“ғзҸҹг°«з°ўдӣҢа°Ҷаә®а« з°Ұж‘№вұұвӘ°ЖҰж®„гҠ§К°аӘЈеҮӨа¶«аөҢЬ¬еҒӨвӨІбғ„бҲ®бҒ№в–®вӢӘзҒҡЬ°ж№©ЯҒжұӣдҘғвүңдҡ”в©қбҒ‘жҠҘдҳЁбғЈжҚҶбқ°еҠҡеҪҙв¶«в¶ҢеЈ–УұвғҶв№Ҹг  гӢҖдһҗвұқж“ҷгіҗбҲҒвҗёРҚОәжҙҪвҡ„б’ еҺөдөҘвқҪд·ҘбІөжј…в№ізҸӣвӢ„вј’еҫҝд°қЖҖаӨ«зҖҫеҗ«вҒ©е’ЈгҶһб”…дө¬Эҗжҳ¬ЯӨбұ–дҮ°Ф№д•°бұӮдӣ°віҒв•ўШҰд„ҒжҳӘЕЎеЈҘЯ—дҲҳдҠ–в»»еӨ–е»әдҳ—зјӮдҗҜз’Ёг¬®бҮҪб§ӯгІҹаЈҷг¶–жҗ зӘҫдҖҝе¶ҲЕӮзҢӣг®јвҖҰеқҷд„—бөібҒЈаҰӢд®ҖеҺҢдәӣвӨүб·–в¬өжӢҢдғўгҰ§еӘ·е©ёвҘ§жүЎзҺ·аўје¬ӢгҰҡзҳ•вўҰзҹ©зјһдҖ“бҜҝг Һз·ҶеұҘд”јЭҰд”ҢдөҳеЈ—еЁ№еЈүбӯүг©Ҳб„ӯЬјб•ЈаҪ–е…ӨдһЁЮӣзҖҮдӨ¬дҶ…аөҒдЈҮзңҜбҫ·зіҰеҝ—з»Јжҫ®гЎ“бәҶгҢҘдҗҠжҺЁvбӨҠж”Ҷв¬ӮДҠдҢҗжјҘг—јбјҖаҙҜжҲңбҗЎвҰ”ДҖгҖўж№Ҷвӣјд«°ГҷзӘ аЁ а° жҘҷвҖ§е»Ҙг®№ж¬—б§Ӯж¬°ВңбЁӮз°ЁР”дҪізӨ·дёӢбҹүеҰқЗ’е¬Ёеғ–еҚЈеғ‘вӯҒаЁәжҲҢГЈг·Ҳг¬„бәўЪғBбқЈг„ҳдІұзўҙгІҸдүҳдӘҘаӯҖаІЎаӨҷМұаӨҪжЈҡОүгӨ«жӨіЕҘб‘Әд—ҡЭіжһҺеҖ а©өд“ё)вҗ дөӢвҖЈДҠ8жөҗЖ¶зә ајңеҺЎ/бҚІбү§в№ҚдӢ ж¶¶д„ҳcШ¬дҮјбёЁжҙ©жү¶дӯ„д“Ҡж·Ҫзҷӯд §дҠівҘӮдҗҲгЁ·б’–вӢ©з¬Ұг“іжҜҢдұһИҮе–Өе»‘еўқбЁҘвҪ°еқҫдЈҠгҗҰРӯвЁҘЗӨбЎ“жӮІб ёгӯӯжЎёдҚҗгӨ®аё¶СұдёұвҒҳбјІжҺҙдҒҹа ҘвЎҰдәүг„ҖдЎӮа»Ідҳ·гұҳбҜ„ж‘Ҹв ҒГӘаІұд»®зҖ«дә¬жҫҪЙҜе‘”аҫӮWж№°ИҒЩҮ`жң№дөІб¬ҖбёәЬңгҝ§еұәЪ¶.е—ҳгҶӯаӨӘж—”д¬°Iвә а»Өг…¶бӯҚвҶҳдҰҷвҘҲзЁ‘бҘ§ж¶¶аЈәвҗҙбўӮбҒүеҜ„вҘҮдғқвҪҪз‘·е®§жҖёв¬җеҝұеҚ»гҒҖе‘ғеҮҚЛ©дЁәзө№бқўзӮ®вӨҲг·’ж‘Ҳеһ–жҠ«з”ҶТ°жҚҸа®үб№ўаҰ‘б‘„аәЈбӢёжғ…ТҜдӘҹж‘°дӨ№д №г Ұг«ҺжҷҖвӣӨВҖбІҫжҲ гһ»еҖЎд“і2аәҚвІҗбҖЎвҢҺХҢЛҪГ‘бҘЎжқӣжҗ°д–өзҙҹдӯ¶бјғд‘җжҲ«е’ЈбіӘбӣ°вӘҫдғібҖҜеӮҪгһҘзҜҢвӨібүідҪЁж°°ОЎг¬ дӢӮеҖ°вҒҸб“ҘзҰӯд”ёеІЁд ҪжӮөв‘іж”®б…Җа¬ЎеҗҜв¬ёД«аӘҳвӮҒзҒўзўұд”ўбҗәаҜёг’ўжҗіжҒЁеҫҠг°ҰЬҢгҲ®бӮҙаІҶбҺ’гҹёв©ЎаЎ”жЈӯві°еӮҙеһ»Ш°е®«гӣ·жҰЁеһ•г ®жұ К»дЁҢвҶ„В—еіҢЮјзқіаӯһВ¶г•¶дҮЁж„ г«–бҸҒТӨвЎөЯӢа№Ӯд•ўвҷ„гүҰдҘҙдҷңжІҙзЈ§е№Је‘Ңбӯ•бұҸгҰқгһ з„Өдҳ…бёӢжӣІжұўб«»дғҶз«Ҙв©¶гүҪз… зұЎгҒәаІқаөӢбҖЁе•ғбӨјдӮ„зІЎвҖұН®зҰҰаІ…вҫӣжІЈдӮҝвҳ”ГәвҸһз№ЎвҒҸжјҲвҙұеӮҹеҖҰд ®ЖҘв«ҘдҒҝвЁ ИұеҖЈзөіЭҗДӘдӘҗб«„гҠ¬ЖұбјҖBд•ібҜҒдў®в®–дәёвҹөТ°Ф«еҹҖз‘ҒдҢӘгҮҙг‘үз•Ҹа§”зҙҝвҪҘбӘҫд–•бәҲвҠҲ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":2546,"_status":"completed","_startTimestamp":1775292757151010,"_endTimestamp":1775292757156821},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":974,"_uid":"1bec02a1-6fef-4119-8714-76988e9b39bd","_cid":338,"_ctime":1775292633694,"_sid":73,"_stime":1775292756869,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067"