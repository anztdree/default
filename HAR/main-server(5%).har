"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiVYJ"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292774558517,"_endTimestamp":1775292774569956},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:52:55 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1281"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":1526,"mimeType":"text/plain","text":"587:4367[{\"ret\":0,\"compress\":true,\"serverTime\":1775292775926,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвһ еқ‘ж ЈбҶ б®¬ВҢЛүвӣӨв”Јбі°аҘҖКҒвҖ№дұҹбң бҶӨдҖ®fznг’ зҳЎзӨ вұӢгҲЎбЁ…ж Ҷдҫ°Г бөҡвүҰзё гҡҒе§ўгӯҳеӮ„аӨ»дҖ¬жҖөдҢҪзЎ¬гҙ‘Ы•еҚҝаӯҺзһөжҚӘдҳ…бёәаҰғвӢһЙ вҷӢд’‘ж…’еҮҳв”„д‘№=бЈідұ Ч‘дҺҗбҶ„г  зҙәбЎҺбҰ аЎҶМҘвҒӮдҮҠд’Җб Ід–ңбҗЁеҝІФҠаҜЈаІӢв’ҙбӢӘдӣ”дҚҝбӯҚгҖҘзӨӮж—»дҚӨеҮҠз„„зӘһЗӢбһјвЈҢд„јдҚғРҪУҙж„¶бІҸдЈұбј«еҷҸзғўжҜқзғ”еЈӨзҮӮзіёвҒ”аҫўР‘ж…ңзҝҲжЁҶЛҰбҸ•д„ЁвҮҢжўҲбҲЎвЁҒз Әд’©б·„г’”дҰ©ж„ҙг’Ӯдһ©Ж„дҶ§вҖҜд…©жҠҢдӣ—бұүбӘ•бҡ—бӢ–в®®жҺ‘дҚ¶жһҪб——гі№г·’бў“вҢ®жӘҳб·¬е“Ғг№ЁбҠ”вІҘд’„ејӨз Ҙе‘ёеҘЁжҗ…Ж–бӢҚдҰ‘з–”еҒӘжӘ©еө®Пғбү–еҶ©еұ©жҰүжҡ…ж·–е––д«‘д®„г¶ӯвҷ№еҰ•гҗҚзҡҒжқҗв¶¶жҚ·бҺҸдӮ”е№·еҝ©бІ”гҫӘеӨјеӯҘвғ®д…ӢЫ…жҚјбҙ»дӘіаәүжіҸдӣөаҙ’бҸ„ж°ғбөҫг„ҝж°ғдҚ©гҺҰаҘӯеҹ•г’ҜжҳқбҖҪдҡ«еҰ©Ь«гЁҲгӯ“е„«гЁәзһұж„ҙгҗја»»гӨӣең”в ӣвҹҠгұҹвӣҮв¬–г№һаҰ“з§ігЎәвҫ«еҳҗдҷәв№Ӣе—ҰдҚёеҲҜжүЎжҡЁб·ҒеүҜж“‘б·ҠаҘҺаҜҰг•әзҝ—вҜ·вҙҜеҮҳжҪҢдҷҙж„ЈгІҮзё жҖјгҒҪаҘ„б—Ғг–ЁеҖӘвһЎаіұвһҺж”ҺПӨзЎ»г‘…зҰұб„ҺбІЎбҮӮГ§вҜ©б·№гүғб·§бҙҸдү®вҢҠзЎ·аӨідҮ·вҜ©еөҲд ЈеөҫбјҮвҚ©бғүзөӢаҘҚг—§Н…дҺ”бғҮПЈвқ„б”ӣгҢҫдҚҫгғғжҠҗзөҮдҲӨж§Ёа·§аўүг•Өд•ғаіҗдҠӢП„зҠҠгӨЁжҜЈеҶЁдІіеғЁзҠұвҗ”з”јеҺҲзә°жҺҙеҢібҸӢа®ҶжҗӣО„зҘҳж¶Үг“—бҜӢвёҳжҡіжұөвўҰжІҙжЈўбіҗзӮ©бҲўдҡҪж·”д•Ңб„”еһёгҲўзҶөзҚ¬дҒҫгӢңж–°аҜҢжҡ°гіҜг¶·вҚҜа«Һгё…вҳҚгІҸбө ж  гғҡЬҖжҖ«жҖЎж»ҳ&еЈ зҳ№зӨ”гәёНҫбӘҰМҖеҗөД°еҲ О»б«·жҝіе¬Ғдіўб ¶УөжӨ·ж«ҙдҰғајҮжҘҷеҙЁаәӢИ§жІҮбҪӘе®ҷвЈӮб‘ӢжҺҡбў”аіЎбЎЎе«ҙдңҠд·Ўж«ӮаіЈбўғе»Ідә аӨ„в„ҡеӨ б«Ҷдӯ»гӘҸгҺ®дҖ бғҠФҠз•ӯжё»вһһЙЎгЎҹвҰ зұүЮ‘бЎӢжЁ»вҒүбһәеӯӮжЎӢеҷқдҒ“еӢ“гӢөбӯҰгҒҚеҪ”дүҠг•ҮжҝҖдұ•жі…б»“ШҠз• Вів„ҲбіҖJзҗҫе…”бҡӯеҢӯбӘјдә°вӘҶдҫҙвҝһзӨ°з°ұз«“гӣүг„   \"}]"},"redirectURL":"","headersSize":260,"bodySize":1281,"_status":"completed","_startTimestamp":1775292774932193,"_endTimestamp":1775292774936148},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":1000,"_uid":"209539de-8357-4137-b2cb-39df4012a06d","_cid":338,"_ctime":1775292633694,"_sid":86,"_stime":1775292774558,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:54.180Z","time":275,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiVSP&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiVSP"},{"name