92696522,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвҲ зҢёжҖЁбҢ¬вЁЈб·‘Kд§”ЙЁЕҗеҒ“бҝһвё вҢұ<В¬Г”Вјз„ЎжұқеҲ е ¶вҗўгҚӘдҝ®бөҖЖ§еІҳдўөз° жҙқбҗҳгӣ‘вғўжј бӯӨЮӘзјғе°әеӘҖж„—з•·а¬ғд·”ВҶзҢөвӘҜС¶вҖӘжҒ·аӘӨб‘ҙвӘҗбұӯг§һеіЈвҝӮбҡ·зӢӨжҲ”еҲңе„үаЈҺбү№вҝ«б”Ёб”’зҒөзҙҡХёж¬Әе‘–б№Ҹд„·зҢғв—¬гұЈе•©вҝ–дһЈвҷ»а·§ж«Әв“ңбҶқзө¶бҫҮвҳ®еҢӯбҳұвўҘдө„ж—ҳз…Ўг“Ңв•Өвӯ“зҖ–а«ёзҒ»з°ҡеӮёбҡЁд…¶в—ғеө–дЁјг·•зЈ…з„ҳеҪҜеҲ©вұҮеҷҜжӮЁбЁҘбҺҚб©©зЎөбјҜе®үг¶…бі«дҒӯИ©б‘…бҚҚгқёдһ¬Р°зЁӯбҙҢвЈүгҲҫеіҲгҒүеү©бҪ©б„ҪаӨӯбј«а©©жҷ¶ЮҜдҗҲгҺҒNФўвҢёаҪ„гЎ“зҘҖгұЎеү©бҲөаЁ°вў’гұ°е‘Ӯвң„ЪҖвҪӮеҢҖгҖ№бҮҖб“«дҙҸВўе„‘гё°+еҮ ВҺгҗіЙ§б„°дӨ Э«д’ ВқвёЎдҡҖбҒ®в Ҙж©ҒдҒҗ6жӨ…Ж¶з Ҝе‘ЈзҲҖзҙ®МҚбғёГўЦҖв Ҫб’ а°ҺдЎҒжҮЁзүЈа·ҰаЁҳб«ЎеҸҶвҒ»аұҡз‘Ұа ӯбқҹаұҒеҢһЗ»а¬·зұ¬зіҷбҖ‘еҳңзҫ д¬¶вЁ¶зҹ№аіҲб¶ӨбҪ¬в·”жҳһж„«аӨ®еҲӮз¶ҫбұ·зӮ“бӘ’бҙҖа©һжҶҗеҚҸдҳ‘б¶ҷаҫЁе®јбҷ«еұҒгҲЈжҗ§вңҫШҲз—·дјҜд—үгҢ•б–ҝб©§ж«“гі¶гҗ”е§ҹбҫҮжё—зҪ’е·Ҝвҫғз¶Ӣв„ҸзҙҸг©Ұбі“в¶…б· ж ҺгҙҮгҗ°вІ·б°»аӨ ж’Ұеұ дҶүеҙҖзЁіеіҗдҚҢзІҜДәг¶җзҶғдҘҸа№Ұгө…в”ідҙҖе–ӯд§ЁжҰ„дҸңг”„дұіаӘ®вҸҹа¬·з¶ға ҲЙ”гҖІжӢ еј°ПЁеҗәжөӢв°әбүҖдҰҲдҚ„з°ЎеҒ°дІҝЛҒв”ідүҙдӮҝдүёзјҶвҠҗЪ¬вүёжӨ№еҠ»вў„дҺәгҢҖз’ҢбҺүб…Ҹб–ҰгІҢб¶¶зұ¬дёўУҗжӮ зҠӨдҠҝжҒӨжёҸМ…г®ҪбҢңжҖҝжҲ„д”ҸЕўдҺ№дҸ¬дҡјаӘ»гҡҪзҺ”д®ІВҠб¶јгҢӮдё®з…Ҹг®Ұгұҙв¶өдҢ’з”Үв‘§вӘҺд·Јгҝ„аұ»бҰ°еҸҸаӘів§¬ПҺбҲҸвҗҚб¶¬гӨ№вҸҮа№Ёжөје¶¶жҢёжҷҪд«ҜТҫаӘўзј»бөҸгҠұд© г‘°еҺӮеЈідҖІзЎҙд«ҶжҶ°еҸІзіҫг·ҠзЎ·в–ҝг№ҙдҠҝбәҫг¶ёдҠ№еҶҝгңІг®ҳе“Ҫб”ҝвҫұеӯ„гғ°еёҺзҗҶа¬ҫж“ұзі°зёғбҜ–еі¶бҸІвӢёз®¶е·әеҜ–з«»з©«бӣ°еіҲжҮівӢҗж“„в¬ӮгқІв¶®зЎәжҗҲжІ жӘәзәҫг©ұж—ұе¬Өж”»г«Ўдҡ зӯғг…қвүҫжҘ–зӘ©еҹ№ЪһжІұеҲһжҘҳЪ©зҒҷЭЎжІјжӨҢжөја«ҢеҶҠзҢ–зһ·вҺІжҺҫзҺје“¶зҸ¬ж№–Ъңе¶ёвҷҷдҘҳдөҰз“‘вңіб•‘жҡүе®Үв ңжҚҳд¶№дқҡжӣ»гӯҹЛ’д…Ҫжҷ–е№ҪдӘҘеҫјвӯӘеҘҫвұҠзӮӮAж’Ҷг “вҡӘгЎігҚ°вӢёзҠҲдһұж‘”в®Ӯг¶Ҡжў»вҪҝвҸӣГ°вӘҰжҳ„еһ„д«ҳеіҜЫҗдғ•жҖіе Җб»ҹИӯдЁҢз¶Ҫж¶Ҡзһ„дҗҖвӢҚе·ҝзҹ“бЈ—гҜ‘жҸөбҳ«еһҪе¬…з°ҝг¬ҝвІҗзҖғеӯҚбұһз©ӨдҝҗзҗҶдјЁжҮ№бғ“дҶ„гҳӨжәҳеҗ“жӘ°бҷұзҶ–зӣҫвңҝеҚ«ж–Һв»Ҫз…’е…қеҷҷвҸӢжӘ»вҪҒз¶җбҲөжҠјжёӨзІ”еҸҲеһ•ЧҲеӘҗжҹҲж„җгҲјжӨ‘гҺҗе¬’дӯҮдҢҸгҢ®дЈһгҠ·дқҷв»»вң’аҜ—е®…жҪҶжҹҫК зҢ‘жӨөжҝ«еіӣЗ©еҸҹВҮаЎҙајәд—ӘеҲғдӘ§вҶҢХәгҙ“д“үж·ҸеҒӣб•ҙеә‘з–Ёгў зҗЈжӯҖж‘ңдүҲгҷЎг·һжӘ•бӘ гҡ–е–ҰвӢ„жӨ”бҸөж№ӯд—ӨбҖЁbД дё§жҪЈзңәвұҶеңҗв—јв§»гҘҸбё§аӯҖз¬Ҝгё…ајҪе Һб ҚдІёбғјаҜ еЈҹдҮҳзҝҚгҲҹгёӮзӮўжҲҒзҸҜе№ҜвҝҪв·Ёвүӣеҙ‘г®ҰаӨ—вҗҖдӨ”дҗҫИҚвӢғж”ӯдҘҰаұёдҘҘг©”е…‘в”івЈӮа¶ЁбҲ№вҶһб•ЈжҜ¶аі”гҪЁз’Җдӯұгј“бҺҲгҷһв„°бҠҮж©ғз©Із·Ңв“җжҝ”дӣҷгё—аҫқВ”зҢЈгҠ–в“Ӯв…ҘвҠҢЗЁг‘Өв¬Өд©ұжўҝбӮ’бҖҝжҮҺвёўг…үеЈҖг№„еӢҢХ„ж©·гҘҙдӨ бҺ„дӢҲбІөжЎӢеҠҙвӣәдӘ¶ОөвӮ„гӯұзңҫз«Ҳж«ҙбҠ•вөіаұ«ПүжӮ·вӘ§б¬ҜеҶһе„үдҮҲгӘңбҡҷзҮ®еҚ·бҢ’б©әгҘ„е’©жқ§жғ©зҜ еҮ•дһізһҘвҚ®еҝӣаӘ•дҚһаә®дӘҮжҒ‘жӘ°дҠҜдҠғжЎјжҢәвҶұвұұа©һгӯЁе…ёг•ҷзөҺгҰӘвҝІаЈЈжҺҒдөӨвҡҢж’Ҳг…«дҢҠб”©гҙјвҡҙв¬’д©Ід’–в“‘жүҘз©ұбүЁбҘӘбһүдәҺзҲ№бҜ¬гҘқж•Һг—Ёа©әд’Ҙг…ЁзҰ—зқүгҙ°а¬Ҷв¬“в…®ж•‘вҜ‘жіғв— е¶ұг“Өаҫүдә°еӢҪб••гөҗв°ҡв Іж¶°жҹ»аЈҜжғҢбңҫТ®бҒүдӯ“вғүвҸҢеҪ«жҷӘдҜҪгӮ”вҚәв°ҠгәҶеҘұжҮ’гҮ«гүҶе…ҷзҷ№зҖјеЁӮбҙһз–ұжҒҫгіӘе…ӘдқөзЈ®еҲ’дӘ•ж ұбә¬гңўб–ҷгҷ®зЁҚжЁ“аҫ»зҺӣдҘ„Яҹжҹёж”өе¬ҮаЎІгўҮЛ¶СЈбғ…д“ҙг№¶б•·аўҸвүҲбҺҗдөҘзҠҒд—Үж»„гЈ–аҙ‘в•…жҫ·б©№в«ҺгҪјдў’в©ҙвҰ–в©ІгӢҪж”№в«…дҒ»б•ҘвқүдӮҫвў’г№јдҮ№в®ҠвӢңб”Әдҷ—д–Җжң¬ж•ібҷ‘дәјж’§бјҮдӢҙгҮңж„қеөөзіӮжӣҗзҰ¶дә—Ы©дӨ…ж§ұж–ҘвҪӣгҚӯв¬«зҡҳдҷәжҳҮг’«жҒӮеӯёвјӣв„Ҡвҫ д—үгј‘жәӢеҷңдҹүгҙҮеҳ•е‘Ҹз”Өв »гҪҹе¶ҢвҖҙбұӨгҡўз’Ӣе•—д’°зЈөа¶©еҡ№ЕҮд“ігҳ»б…Өв—Ӯз‘©жӣёг’үЪӢд—·жҒӘд—ҳдӯҢе–•д®ҷб‘¶еҺІең—бҮҚЩ№вҰ–вӢ«г•ҷеҜјд®·бӘӣг—…вһҚбӯје”Ҙг»ұе”ЈеҺўзәәв©§вӮҘдһ‘дҚҶдҡҶз®ҡбҸөб”¶еҶәе„ҲвҮұгҜңеқҙзӯҡжқ…вӣ¬б¶Қжұҡб„ҫгҳӣеў”еӣҷб–ҜгҫҠдҫқеқһг—®е»ҸжҶ•Юіг«Ҝб“јдҝҖд‘һгҗҲО…дҗұгӮҠз»җжЁҘж©ҮзёқбҒ°ЕүаөңвҺ¬б•ӘдӢўзұҚб”ңгҠЈаі»Ыҗг¶»еғ»аҜҒе…„е„ҢбЁІз©©бӣқв«җзӢҫзәөејқг“Җдһ…дў®ЛғгҹҷгӯҲг“¶жҫ’е№ҪвҺҲбҠЈе·һдӣҘг¬Ұв–ҺЫ‘дўҮгҲһжёӨЫ§е—ӘеӣӨЙ®г©ҹбҒҜУӘвҰ§бөөвІҪаҜұвҘңд©’гІҙзҠҗз‘Қг…®аҫ‘ж’ҫж»ҙгё«жііжқ°вҠ—еҹҮз·ұзӘ¬гЁ”е“үд’ҒвҰҝзқҖж°ҷбү…гҚҢв°ӣг‘°бҙ’е ¬еҶ дҙўг¶…д‘һбҫ“дЎңбӢҫгӢҘгә–аө‘вөЁбғҫг”үгҒәбҘ”бҪ’бүәв¶ұг¶§еҶ—ЮӮз«–гІўвҝҹОҸгҪІбІЎбӣҫзәҙгјңб·ӣбӣӣвә®в¶ұвҘ‘з§…гЁӘд”ҖзЁЁжӮ®аёҲеӢҳг©Әзҷ·вң№Щөе”үвҘңеғ°бҳ·бҰ¬бҢ»дұӣвӘәжҝ©гӯҢжӣ•дңҠв…ҚжҘ•еҘ–г•қгғҮдҘ©вӣҺдӣөЫұгўүеҸҚеІҪвҖҺзҜҝеҚҫеөҘдһҡаІұвҙҚвҚҘжі‘б—ёЧҮаЁ«жўҲвёҸжҳ·аҝҘзқЎвёӣЦ¬вј«бұҫз·ҡжұ«жҷјд°ҶвӘ¶д„ҳвұЎзЎ№дҮҜв”…ж‘ҳж„ҲгЎӢвҮәб§…гҮӢЙҪТ‘зә”б¬ҹаә•гәҘбҗ…дәӢгөөвһҰе§ӣдӣҗвҠ—вӨ©зқ¶аЁјзҪҫеӘідҫҮзҸ№жқ·еҷ—зӯўгҹҪгҫҝзҡәб”«еҺ©а°ҲгҶЈві№г°җгӢҘаўҶвәјв№ҝЦўеәүвҘҸзҚҲеө·аҝһеқҝгҪӘгҫҳвҙһзЎёИҗе§…зҒӣгӣ°г««еҺ‘ЮҲбһ·бңӮвҜҚжҷөбғҳжқёвҳәе—ҳбңӨв…ӣбөӨзҮҠдҮҙгә¶вҰ—дҸ…бұ©е“·г—үе”Ӣв§ҚжҜ©вҜ·дҙ”бҫҙж¶ҝж’җжө§з»ІжЁ“ж—қеөҹаҪігӮҮеғ№б»ҶеҸ®д»әгәҶе‘«з§ҮаӘ·д°ӣдҫ·зҫҝжӢ°еәҷдҠ–ејҷдЎҡд –зӨЈзў¶жҪҮд–¶е¶һжұҰе¶–зҘһе·Ёжә¶зҚ„ж–»в’Ҳж—Іеі’дҺ№в·ӣжӘ®б®җжҸҗзіҫХ’ж·Ҷв»ҶдҖ©жҢҺжҠҗб·”зөӨжҪӨаё·аҰЎе•„ж’ҠжҘ“еҺ·в°№жӣһвҡ‘вөҶзө№жёҫбёҗзҸҹгҘҰж·®зҮ–бҝһж ҝвҡһвң°еҫҫбҘіж”Ӯз”“еҝҶгёңж®әдғ–вҮҢеө°жҪҺжӢҙгҪҶаіҹжЎҢбұ•а¬ҫаө…д§ҺзҚҮеӣҲРһж“әдӮ”дҒігұ’ж•Ұе ҜПҚаұӣжўЎдҷ’е®ӘОӣжҚҙвӢҮеҜҶМҫд§ҙжһ•е—һгҖ·вЈ¶аҫ—бҺ«вёҮжҮ”дҳҗжө’зұ–д«һв§ҮвҝқЛҗд’ҡжё–в§ҡдөёб—®ж•’бҝҸбөҶжіҶж§•зӮҠг–Ҙжәәб°‘зҰҰгұ…ж–ҫвЈұжһӨдҢ“ж•ҒМ‘дЎұгІөж©ҫзҶғвҜҳеЎ•ж•ҫжҖ©еһҰдҢӢж—ҒЬҗбҜҳеўӯж№ҢбҺ–аӘ№е¶¬бҶҺвҗ¬а»ҷдӢёжҡЎб•„аӨӨвӮҢб¶ёвј“в«ҳз·ҚдҘһЫ‘жӘӘж“қжјҒгӮ„зЎёб§ңбҳ¬ејЁжөҹдү–дӢ®гҜҶСөжҘўбіҶгҳЁд‘Ҝб¶ҙжҹ®еҗҗаҜҷзёӮбҠҫд’¬аўҚзІјвңҰе„©е·ҳдҗ“вҫ–вЈөЧҺвҠҷдҫұгҹ“бһІдҚһжҫҰе”®зҘҡдҠІж§Ғб““бҶ¬вЈҖбўҙзҙҜбҘҹб’әбҸІдј•г’“аҙҗвҮұгј’еўӣдҶҡбӯёг¬«аҫ«аҘҪжјҺбЁ•жҺ¶в…Ёб»ҡбҫ‘еҺҝеІ°дҰӘгҰ«МўжӢЎд“‘гӮҒвҰ©жЈҙжҜһгӮ®дҹӣОғж§ЎбҸҶзҒҫжҢӮбҗІбҸ’дӣ”аұ®бҰһгҺЁгҫёдҸ…жҰұб –ж‘»зҙҺбҝӨвІібӢ—зҙҙбЁңж”¬{жҸўд…ІбҖ¬зІ…вҸһб·Ғеҫӯжў”ИЎбё„вҒҜгһЁбү¬б¶Ңвҷ”б–«аіұж”Ңе®—дә®жҒҮв‘һеҢЁгғӮбҠғвұ‘ж‘ӘбӮҮе·ұбЎҠжӘҗвҘҚбёқжҪ®е··д§җг°Ҝв ұЗ•вҰӨгұ®дү–зӮӘеө„вҸ–бҙұвҜ…д’…зҙҳб‘¬Д¬еҫ°дҚ®бҫһд°”гҫҫбҰҝжһ¬е җжҙұб’ҫжё¶в…Ёвўӣж¶ҫб…ҫеһӯб‘әдҸ•жё„бү’е’ҳеӨ»жўҺжң–бҜӢгҙәбӣүж…өЙ©еӢәб‘¶еөӯа»қа §ж¬©ЛӨжҺ¶е•ӯб”әд„ғгҷЁдө…бҷҶг—өеӘҶбҗҚб¶©Х…жүӯМңбқЎд–ЁгӮ’жҠёбҲұзүҜвІҸеүӢд—‘вҜҒжұ¬вҠҳбҲ№О¬еҝҳгҢ‘дӨ№гҷ®дҷҫбҰғб‘¬зЈ©гҚҸбҠібјһЕЁгІҗеү“б©үбһ©вЎ®гҸҫбһ№дҘЁбҷјеҸҠбҸҒбӢ«жЎ«г°¬бӣҫвҢҜв©«вҠӢбӘёеҚҘвҳ°  \"}]"},"redirectURL":"","headersSize":260,"bodySize":4191,"_status":"completed","_startTimestamp":1775292695536796,"_endTimestamp":1775292695541078},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":817,"_uid":"d10668c9-d026-4c88-99b2-f64b5ed6b6dd","_cid":338,"_ctime":1775292633694,"_sid":42,"_stime":1775292694824,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:51:34.255Z","time":516,"request":{"method":"GET","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transpor