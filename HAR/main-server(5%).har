ring":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNkpdF"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775293381090783,"_endTimestamp":1775293381098308},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 09:03:02 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2417"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":2974,"mimeType":"text/plain","text":"1097:43232[{\"ret\":0,\"compress\":true,\"serverTime\":1775293382771,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЖ№жүұбҖўбЈЁДҖТҖЧҖФҮд ®ж„јеҖҘдҮ‘вҖібҘІдӘҷж” аұғзҗ„ж”үвҖҰжңёе№ҖжҜҠбЎұаЁ жҷҡеёҜдҙҠб’°бңӮе”өаәӯдҚ№вқӮб•¶вЈҖж’°ејҶвҪөKНЈвҫҲеҢҒвҒ еҮёгҖ б–ҲбұңГ дҰЁбҳҒбҺІб„ҙВ”зҚ—бЁўбҗ аҝҺдҢҙв„ҷз°ўд…ҒгғҪв’”вҷ¶бјёд№ӯв’…гҠ’ФҚгҖёMдЁҪд’Ёеҙ”вҶҗбһ·в°Ӣб  бІІаҰҢеҲЁВ§зё И•ГҗзҚ в‘ҹзҖҫд°ҲФҙвЁЎвІғ\\\\дҪ“жҖЈг“Ұз·ҡвҷқб°ЈЧҳв——ЫҗжғҠ!аЈҢв…ЎдӘҺаЁҰРЎжҢҲбһ¬Ы»е©ҹа§ўдҚәдўҙгӯҝжҖ«еӘӘЪ№еһёд‘җвјўдҢҘд…¬гң вқЈгҶҖе  Г‘дғЎб өв©Ј9зҗ©жһЈК¶вҗ а¶ӮжҗЁгҖ бҮ»дқ д•ӮбЎҳзҷғг јеЎҳдҢҗбҘ°дұҺа¬ЈаўҖд…ӯдү№дҮ дҳҝдұ№д…ӮдҖҪж’ аЎӨеё аЎӘдҡіж“Өа¬ідҳӮгЁўг»ҜгҺҚж ҙаІЎвҖЎз”Һбҳ§В з¶ бқһеҖӘ,З„зҠ гёҢвҹёжһ‘дҗұаІ©вҠ°гҖіг…®гӮҲаөҲб¬ұз “е‘ҝгҝёж„§Вҷз—ҖЖӮе’ҳзҙәеҗ ХІд„ә5дЁ©вҖЎз°ўвӨӨвҖўзўјзҚҷд“Үеў”е”ЎдЈғвҹӨзқ©бәҘз„–а °дӣ№дҖ ајӨЭҜб¬‘аҙӮУ°ЕҲжғҪб  вңҖж„“ЖҗбҘҠжҖЁгҸһгҸЁа«ҘвҘӨзҫёжҒҹаІ°еҒЈгҹӣзі жіҹбҖҗвҠҫгҷ¬дөөзј вҳқжҘӘаӨҳзққжҲўг©ҫа»ЈаЎҲвӮЎгұ„а»ЈзўҷдӨҘвҶүжЈҗС¬ЬӨбӮ“УҷдӮ“вҳЎбЎ„ДўгӮІвҚ«еҷәдҫҰаӨҳЗғжҡӮа» д‘ҝжЎҖUгЁҘВЁе івҢҲжҖҖЖөИөвҖ°\\\\еҳҘб„„г–Ҝг”ҢгәЁаЈјвҙ¬а ўгң—б„ б‘ӯеў©г…ҸзЁ‘вј«жҸҗг©ҰМ©з «ЦЎеё§РЁгҖЁеҺ’гҠ°дўҲг’ұвӢҲе”ҫжҺ–еӯҶз§–жҚғаўһдІӯбҸЁВҙб…№вӯ‘ХЎв ҜзҮӘа№Өв•Ғв Ёе…ҖвҒӢгғһбҚҹвңјбҷҷжһ№дӯҡжһёд”§вҖёзӨҫгү’вәҰМ°зӯӨОҢаөүг„Җа·¬жЎәгҡ¬ФҖж–ҫж¬ 7жҘ·жҷ’е“җвӘ°ОіжҖ®дһҲвЎ»вҷ©еӘ·жәӢв ҙвҸ„б©өаҪ’д¶“в·°г©Іаұ Тһв»ўа¬Ғеү¶г©ҘдҪҙбҖ а·ҒжЈҡИ¬з…ҹб әв„ЎаЁӢгҸ¬аөІеҜҡгҺЎвҘ–зӣҝГје»°Ж”г•ёа °д »гҡ»д–ңСәбһһз•ҖбҖЈжӨ»в•·еҸҲгҰӢжҫҡвҰ¬жӘҡеһ•вЎҒв№“в¬Јв¶ҳв¬Јжө„бёҡжҒЎдЁҠа әвҗәДғжҙ»жҺ„жӨӣгҚҪвҝ•д®үвұӣаҘ·з•ҡжҰҫжҜ ЭәжҰҗд“Іж…ңжҘ—г“ҠеһҖжҜҡвҲ¶бЁҰзҪ«бҘ»еҫҮв¬ўзһҹж©Ӣеө“ж»Ӣеһҳд–»г„ӣв»«е¬ўб§Җж®ҺдҫҲдҚәбіәбЈјаҫҮв–ңж·§ж“§з‘Ҷвһ•бҪҲз“№бҝҰб”‘жӯҘвһҚбҜҶаіӯжӘҶвҙ“ж®ҮвӨҮжҙүбіҙбҫҲгҙ…её§еқ®д„¶бөЈеҰҰб»јбЎ№еөҙе§¶вЈҝб¶әжҚӨж©¶гң–бө¶д®ҡеұ‘жҲөбЎЎжүқб»ӣгӢҘејҜвҙ—б®ӣд«Ҫеј”а»іеө®ЛЁбӨ жҘӣе»ӘжӮ ИӮзў„бҺІзӘ°вҒ§гңҶбҡ•ж·ҪдҖЈзҸ°еҒҝгҶўд№–аЁЁгҒӘеҜҗНҝгҠ·бҪўеІ’вңҢејҜв¬Ҷдһӯг¬–г§үе·үе° аҰ”аҘўбӨ®з·ӣеҒҒвЎҹдҹҶз№ҫвҜҚвҘһж°ҡзЈҫб’Қз‘һвҜҶзҷҺг…ӣе”Ӣг¬·вЈғжІҷЕҚз·ҫеҸҖж—ҷг®ҢдҸ¬гӘјеӣЁз”—вҺ·зІӯг–әж©ҮвҚ—еөңзҶҡз”Ӣжҡ жҮӯе§§ж¶“дЎҷЗҖе °гҜҮНҸг…ҺбёҖе“өж•қЯұеұ»дҶЈеҜҮг« ВЎзқһзң„ИҠг№ғжҷқгҜіИҜдҡӣбүҚдҘ— вҰӮаҙўеү’вӣјжҲЎВўа§ңжҹҪЙҮдӣӣвҹғг®ёаЁ’жј«зӮ”в°Ӣд‘—ж¬ҲбЁұз°Өб„»жҖӯдЁ§бҗЁвӯ°зҠәгҖӮең…в”Ҫз«ЈзЎҝеҶ’gзҢ з§•Дҳа«–а №дәҫдҢЈе¬®МЎеҪӣв»”д“ҖжЈ—дұҙа¬ҶеҫӢбҲһж«ҒвҝӯвӢұб…әе’ңЮҹЪӯзҪҚаҰ®гӨҒеҳҰбІјдҷҡжҸ гҮёгҸҮдһёдҝҙеӨҲд№‘бһҖвҖҜжҫғе»ҙвҠқеүәз«ӮдӢівҠҜдӯҸаҘұгҢізәҳж§ұеҙ§вҒҝдҺүа·–е©ҲвЎӯе¶җдІҡбҢөаҰ°бһіг…ҷжӢҢг»…бүЁЛҲгҶ–гЈҮаў–дІівҳҫб°ғд©“зІҰвәӢзІ‘вӣҚа …еҚҙеҸұжӘ¶гҡҒбі¬жҒҡжөҰв—„зҺўв‘ӨжҲ¬г–Ҷд•©зҶҲз„®бј¬дҝЎВҢеӮ…б’һв’¬ж§©жҚӯаҘүвҺёгғЎбқ’д§¶еҢ¶г…ҮбҷҘжҹ»в°Ҝвҙ–ді№вҮӯжҰҫжҝ’в№Һвү©д”…зү§зҰ§а«Әб”Ҳзҷҷг®ҝе©әбҷіб«ІеҠ гәҶбә“еЈңзҚ«гҙҳдӘүзәӮзҳҜбһ”К ГҘбҠҝв’һвҹәз©Ұвҳјдәөж”—зң‘дҠҫбҰЁеҠҪдҪ”жҠӮвҙҙеҶҶбҡҢеЎЁаӘҺбңҡб„ӨвӨүвһІзҪ„дӘ„в№ҘЖ…бҗҙдұӘб“әвҜүдұјж—ёж“Әаі‘бҚ№гҰ’ең°д„ҙзҷ бЎЁдӨ°зҮ«бӮҘЫҳгЈҳЦҝбЁёзқҒвғҗг·Ӯж¶–ЮҖгҮЎбІӢДЎгҗӨвҮ°е’ еҖ№вғ«г«ҲеӘўбҺІе§ЁеўӘвҝӮР»дҮјбҡҲаҪ„ДҫбҘҘб№қбҒ’вҚӮгҠӢвҢ…з…ёзҢҢд°Әжј·б–ҰжұөгҰ—б”’вҪҚжҳ¬а №б¬ӨЖҡбҝўЙҗвҺёвЎ§РұдҶЁгў дЎ©КұжӨібҮ’бқҲзІЁвҰҘаҝ”гү„ЛҲгҫЎеүҲIг«”ЧәбҠЈа ёВқНіаІҘеҡҠМҺжЎҲНЁз№ҫвҰҡдҷ»жӯөвҸўбһҺвӯҶе–ўзЎҠКҖжҪҡаЎӨЖҘеёЈбһҲа§ӣг¬Ӣд„өж©Һж·°еөЁбҢӨгҜ”ФҢвҺ—бүұзҗҫжқЁеәөжӯ¬жҜәЛҝбҝӣз°ЎзҠҖФЈж®ӢдҷҷПҺеҙӘзҖ°зӯ°еҠ‘е”„зӯЁ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":2417,"_status":"completed","_startTimestamp":1775293381780441,"_endTimestamp":177529