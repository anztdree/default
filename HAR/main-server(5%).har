Ҫ—з§үзғӣбІ аҰҡзҪје№қб—үз«‘еәңгЈҜд’ұеҮәвҗ“жЁіаўЈдӯідӣҒбҢҒг°¶д·ҮзӨ”зҙӯдӢІбұӯе§ҜеҒҡвһІвЎ§вүҲеӨЈжӨӮеҷЁеӨҲз®№еҜ¶вЎізҺңжҮҘзҶ®зӣ§Й®бһҰгЈҒбҖҫгҜўв—Јг«ҺбһҪгӘҒеӢ»жӨҺа·ҝгЈңдҸіЦІжҘ§з¬ҺеүўзЈңв©ІдӘ–дҷӮТҺз¬јд ®в©‘ЭҠж‘һб©ӘзүЈа ‘гҺёбў®еғҰжӨ‘вӯҜдӣҶвЎңФ©бҘӣЪҶбӯҝЯўбҙ°дң©бӢјЪұдұҳЮЎд©ҳв—¶ж…Ўе®ҠвӣұзҒ‘зЎ®жҢ–бҷӮж—‘дұҸеӨ№в№Җжҷ©ж»әвҹӘж§ҫеҜ©гқ‘вһ–еұҺж“үгҶёвҸүе“«гӨ№жөҖжһұаӯҹвӣҶжҸёвӘҫеҚ§зҺ№гҶӘз®ҶдӮ®зҜҫзӘұеҖ жҶ”а·ЎдӮҮдҖЈе¶җ-гҶЎж°»зҳүзөҗПқг”¬ЧЎвЎҠЙҒвҗ Э—б”ҝдӮҶе•ғбҰӨгҒҢаіӢдҢҸеӢҚбӢҰб«®жұЈвЁіг©¬д—–дӘ¶в№·бӘүвӣҲг„ҲбҰўгғҚгӢҲз••б®ўб•ӨбҰҰгҒӢвҸғвҙ бҮЁд…•гҲҘеҳ•а«ҸгҹҫжңҪ в…ҙаӯөа«Ҫе»өеңңТўзӮҶеҢЎзЎІаўІгҒ“еӣ¶дҖёдұ•в©ұеҚ–ж‘ҘЭҗз•©еёӢжұ–жҝ“Р°бӣүеӣӢеҪЎб ҪеҗҠжӘҶаЈөаӘ ЕҶдҮ°Х uж ЈвҡүвөӣвһӢжӨҶб§Ұб ҘвӣҡдҫұЯ вҫ№б«Ӣд¬°  \"}]"},"redirectURL":"","headersSize":260,"bodySize":1253,"_status":"completed","_startTimestamp":1775293127034297,"_endTimestamp":1775293127041201},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"477","comment":"","_id":1416,"_uid":"97ca12a3-66fc-48b6-be2d-98dec93ca052","_cid":477,"_ctime":1775292841240,"_sid":85,"_stime":1775293122185,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":57404,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:58:41.649Z","time":250,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNjqHa&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"144"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","valu