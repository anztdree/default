Ўж»ҳ&еЈ зҳізӨ”гәёЙһбӘҰМҖеҗөД°еҲ Оёб¬Ҹжҝ°е¬Ғдіўб ¶аҪөеҘҸж“ҙжҰға§§еҰүеӘ§б№ҘвһҒдғӣаІ©вҠңе«ҙбў”аіЎбЎһе“¶ЬҠд·Јв«ӮаіЈбЎҪе»ізҡ аӨ„вҮҡеӨ«жҜҰжҚҫгӘҝгҺ®дҖ бғҠОӢе•№ж »з®һЙЎг ҜвҰ зұүЮ‘бЎқзҖӢвҒҚбҶ»б¬јж№”дӘ·е‘ұгҲҰеүәвӘӘж ЈеүӮдӣ‘еүғзҠҡж ҪД»вһғб–•д°·в»Ҡ$еңҝбҗ ХҪПҙвҡҘеҮ”ЗҶеҢіеҲ¬дұіжёҘзӣһвҲҝПһЪҷеҷҢвҖ  \"}]212:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":false,\"data\":\"{\\\"_curMainTask\\\":{\\\"6002\\\":{\\\"_id\\\":6002,\\\"_curCount\\\":10102,\\\"_targetCount\\\":10103,\\\"_state\\\":1}},\\\"type\\\":\\\"Notify\\\",\\\"action\\\":\\\"mainTaskChange\\\"}\"},null]"},"redirectURL":"","headersSize":260,"bodySize":1442,"_status":"completed","_startTimestamp":1775292774448690,"_endTimestamp":1775292774455218},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":999,"_uid":"6bd6bbc2-844e-4c08-8c30-624db241c173","_cid":338,"_ctime":1775292633694,"_sid":85,"_stime":1775292774180,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:53.987Z","time":257,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiVPI&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"188"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiVPI"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"postData":{"mimeType":"text/