Ҹ…гІ„зһҚеҚңдҠәбЎ·бЎјбӮ¬дҲ дҜҮгҰІа«ҢжҰјбҶҢдЎҝгү’дңІа®јдҷәзҺӮдһәгҲҝв…Ңзіўж°Һв¬ўж•¬еўҹгҖҮв ә,бқЎе°ё$[ең Г¶б ҪдӮЎбәҜеҢ бҝҰеғ е°өЛҖвҲҙдҖ зҢЎеҳ§зЁұеұ“бЎҰЛЈз«®вЁҘЬҡвІғМқд·•е…¬жұғб•ӣКҘжұҝвёҡзҪҰаәЈбЎҶЭ•ЫҘеөігўҺе‘ЈбўҶа®—еӘӣеҖўбІЁг“¶вҶҶз«ёбҜҫзҖҢзҮ°$б• жҺ—в®ҡа®қжҝ дЎҺЖәгҖҝХҒж№Ҷа ӣзҺҲВ„г®Қв»ўдҠҫе”‘бҰұаҝ…дһҺе•ӣб«ӣдҘ°жғқв§үд„қКҒвҪ°бҮүд°ҙжјҠ$дҙ§в„…!вҜҖзӘ©еғ”гҡЎгҷ“жҡҚдІҖзҠӨа°ЎвҲҝДЎЖҳгҹҢвҖ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":1293,"_status":"completed","_startTimestamp":1775292768577741,"_endTimestamp":1775292768583996},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":979,"_uid":"1a5be346-a370-4159-b46f-0f7b0858a99e","_cid":338,"_ctime":1775292633694,"_sid":75,"_stime":1775292767707,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:47.307Z","time":279,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiTn0&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"188"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"PrNiTn0"},{"name":"sid","value":"w2Yh8brTQOPYRQmpAAPs"}],"postData":{"mimeType":"text/plain","text":"184:4257[\"handler.process\",{\"type\":\"hero\",\"action\":\"autoLevelUp\",\"userId\":\"33cabb81-987d-4712-81c8-0d88b4c63132\",\"heroId\":\"3af5ef3e-ca46-4c1f-a8