w2Yh8brTQOPYRQmpAAPs"}],"headersSize":248,"bodySize":0,"_status":"completed","_startTimestamp":1775292646756426,"_endTimestamp":1775292646761783},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"w2Yh8brTQOPYRQmpAAPs"}],"headers":[{"name":"Server","value":"nginx/1.16.0"},{"name":"Date","value":"Sat, 04 Apr 2026 08:50:47 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3154"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":3957,"mimeType":"text/plain","text":"1407:438[{\"ret\":0,\"compress\":true,\"serverTime\":1775292647803,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвҲ зҢёжҖЁбҢ¬вЁЈб·‘Kд§”ЙЁЕҗеҒ“бҝһвё вҢұ<В¬Г”Вјз„ЎжұқеҲ е ¶вҗўгҚӘдҝ®бөҖЖ§еІҳдўөз° жҙқбҗҳгӣ‘вғўжј бӯӨKбҙӢж”“вҗҷеҠҳгңҖж…ҙб©ңеҰүаўҜбү·жӢҺгҒ°жЁ»з“Ҙг„ гҚ¶г№ҢеҘҶајӢдҷ°бҚ„ж‘өгЎҫзӮҫЛӢе©ЁвҮҠз•Ҡеһ«еҙҳгЎ–б№јаӘҜбөҡвҘүзҒҸб°үО…зұ‘жҘ¬е–Ҝбғ—еЎ»б–ҒвӘ„г“ҚбҠҒзҚ№ВҠдҹҶв®«жҪ–дЎҠзҲҷдҘҠгҢұЫңгјөдҢ«б–ұзғЈзҠ„д©Ӯгғ“гә¬д‘·ЗҢд°—ж®ЁдүөзұңзөғдЈӢа»…дЈ¬зё№вөҒг¶һе”ӘдҘҮж§ўз…ҒвӮҒзҶІзөӢвІөж…јзөҹа№Ғ еҙј&зҚЎбЎ„гӨұТ°В”зөӢ'ж¬ҖаІҶДӨзҠЎе“Ӯа°Ј!гҡ®в ӘдҫЈбҘӨбјҫЯ°зғҙжӨӯдһ„бғҺг‘ҹвқ„ж° вҫ®аҘҖв„ҷЖ„дұҚаҜҘз ӘдҘҸбҸӨзҘЁа®…зү бҷ еҮғв«ҘРҰдҘҒвў•зҸҚеһҚе®•дҡІе’ҸзҲ°зё№еҮҚП¬гөӘдҙҺбЁ°б”§еӮ§жӨ•еңҝе¬Ҹд…јв„ҖеҹҸб§ЈЖҷдҙ№ЪҗХңгӮ вўіг¶–бўҸз°Җз…ҶгҺӨдІ“аӨҢдҒ№ВҒг”ңМ«бқ„д–‘гӢҚвӘӯз–җгҹҢжҘӢдҙӯгҝ§гҹҪвңҷеҢёв®қз«ўЦүеӣЈвҮөг”Ҫзҷ•ж”ҷгңҝа»ңжЈҰб«Ҫв ҮаіҙзӢёвҜ“ж–җзҫҝгҖӣзӢұг·ҡеқ«г·¬зјҙе ӮгҢ…еҶңгҷҘг»·дғҶзҙ•вҺҘзӘӢжҪ…бЎ¬еҮҶг»ӣзҲҢж–ңа№§дҚӨЫҮеЁ“а№ гҠ“е»іеЁ“д№ г…“ж№¶еҫЈб№Ӣд «в№°вҺ—ж©»д—ұб«ӣеҙҜжёәб„–ж„¶д”“ж…“дӨ¬еҷЁвҘ—бүҠаҪІе ҙгң–гңӣдӣ еҶҸе’ӯеҮҹдӨ”аў…дӮҖе…Җв¶¬г”ҖвўҜд„ңбҲ¬гҶ„гҳӘаЁңбёҜз…Җбҗ°еҶҲвұӯе…ёгқ’жӢјгӮ©вҘ„г…©жҒҠЮІб№ҡві–дҠөеЁ¶дҷҗд‘•д¬’дҫігҠје§өжҘўвЎіжә¶Х§аӨ„е—ҘгӨ–е»өгЈҚе·–дҷ¶ЕҰеҮҜдҢ–дӣ“б©Іе“”вҠ©зӨӘбҮұВ вЎ«з…әв·ӨеӣӮвҝ‘дёІгқ–дЁ‘в”ӘаӨӘгҘҠжҡөеңҜдҳҠв“‘еӣ–гқ–еӣҖв…іеҷ§еӣ‘еҳҰд«ҚгҲ‘г«Ұзҷ•дҷҚб–‘вқҲвӘўг“Ҡв—°в…өв”ұдҶ—г№“еүӨж—…гӯүзҳ…еҘҜзҳҷг·ҲбјҚеҚ©дёҮеҖ—еҘ’г¬“зё¬гј•е’ІбЁ•е•ўвӨҶдҡ®г§ӯгЁҺв»ҙзҘҳбҡҖе№қд–үг”ұе ӘеәҪвңҺз”ёвҚЈз•ҶеөҸе»ҝбӨЁеәғвЁҢдөҳв¬”б•ҶеәҸаё„гІ”еҮҮеҝ¬г’өгүҜв· жһүвЁ•вҡҢа ҙгҢҸд•ңгҗ»г— зјҲа©Ӯг®©г¶ҺдёҺНғвү•Лјг Ӣг«іг ёОҺд ёж…ҡвЈ®вё‘гғҜа»Ұв„ҜжўҶвӢ©г©¶в®ұEвүҗгҺқдҗ–дӘ’д…¶зҰӣд©¬б·ҫдҙҢЦӮзҪ вўҒгҗ№зҘқЯІбҰ…д¬ёдӘ…дјҝдҖӨжҢӘбҢўе°Ҹжә„жҪ“бҷҙзёЎеҗӣдӢ—дјңзІҚеңҚдҳёжҶҚеәҗвҸ¶жҺӘа§¶б§Ҹгҳёз»»в¬ідӣ”ж¬ЈвјӘвёӘеқҫајҡжўҢб®ІКҝеӯҶзәӮе»ңж“ІеӯҜвЁҪжҡ¶д“®гёңбҷҰж·ҸеҶ’д©ҝд җеҙ вҢ”з°ҳгҜәе‘·еҚҫгөҶвҗҺг»Ўзё жЈҒзЁ”б¬әбүҹж…ҶжӮ®зҶ‘ж·°вһўеқңдҗ”г®«дҸӨж§ёж…Ёзҗ№вҺЁз¬ҺжҚҘжІ®зӯҳзіҚдҰәж©®з…•ж’»дҪёдҠ®гһ„в“ҝвңҰвҸңж©Ҫжҡ’гҺҡв»әеҡҢзіЁзҚҢд®№еҰөдҜҹв ҶЭІзЁ“д“Ёз ЎгҖ”е ңЧҜд®јвҹҜаўІз©үв®“зҜәб»һзҠӢгӣ—жёәзҹҺб°Ёгҳ»жҹҲвӣ¬жІҰеһҷдӘ¬дЈ»гҙҶбҪҒеҖҫб•ӨбјҶжҢҚв•¬г·ҚдҠӣЬҙз«–гҹ”з‘ҝгһҢеҖёај…дҚҪдҚҰе§ЈеЁӨб•”г§ зҗ…жҪ«жҺҫе—„Л§жҸ…зЁҙзҳ•бҙӨвөҶЫҝгё“б¶Ңа§ҡе°ҙз¬ҳбӯҪСҢз‘«д ҘдҪҷгӘ жҹізёЁаіўаҜ§вҲҡд«Ҫаұ‘еҶ—д°әдўӨб«©бҠ–бҚҙа·ӮеёјбҠёбҷҘдүӣаөӨвҰ«д‘ жҺ‘аҙ‘дЈәбҒҫзӨ»вӢ«ж“ӮжҜҙаөҙгөҳвўҰдқҘвј—жҘҷз‘һеЈҢг»Ҷвҡңе Іж‘ҷб®әзһ·гҘҙбҫІв°§зӢҠбҚӢбң„дЁҙеӢөз°°е°ҖгҫіеҒӢбЈ—бўҸжӣІиҖғбҠ бҮҚб–©жүібӢ‘б‘ҙЬ»в–Ҷзў«гӢҠзёҠжҙҡбғёг•ҪеҘ¬г—“дІҗзүёеғ·аўұжҺҫдә®жҙ–бҜҙж‘‘гўҰдӘҘб‘ӨгҜ–вӘҜдұҷе–®аҜ§вҰҮвғІбҡёз¶ еүҠгҺҝзҠҖз‘ҜбүёдЁұзҙҠжҲӮб®•вұҡвӢ«дҢҗдӘһеғ·б¶’е№Ұз•ұЙҒгіҫбҲӯбұҝгІІг ҷжЈҲбЁёжҚҰбў»ЬӮгҡјбҲҪбӯҘеҷ’вҺ„д»ҰзҶҘа¬јеІөН·аұ–е•Ҡе№»жёӮз“№д¶Ҷг©ӢжҡҶе„ӨжЁ—бҘ°дҙҶзӮөгјғд—ҪаЁ№ж‘һа№Ҷе¶°в§ҝб•ЈгҺӮвҘ…жүівүүбҗӨвҷөжҮҝдіӮгҝ„д©ӢИ—ж”ҳе‘үгЁӮЖ…дёўж–ўеҢҮеҳ§а«ӣгҮўзҲӘе”·дҪҢжҢұжұқбЁ’ж»§еӢҡгҖҶзӘңзҗ”жҙ„аіЎеҷјзӣӘб§”бҚёаұҡгҠ¶д¬җб…ӘгЎҒб’·бҠҫа«®г·ӯд–ҙд”өжқҜз§һвҙҠзҷҝж•ҙШғд¬ҮеүҷвҜӘгҘӘб“јв©ҹз—Һг·ҳвЈқж•—вҙ°вӢӢа ҺбҷҒз§Ёж·ҘгҪ–жүҲд№өв’°б•ҸгІөбҺ•зҚІвјіеј”жӮ„аЈ…дҙҗеЎҮдІҫб„әгҸӨзӮҡТҖдңӨж’Ҳе¶…ЪІбҚідҹҖз•үбһ¶ж№ҜбҷұгҸўбў©в·Ұбӣ’еҡҰжҰ®д»ұвӢҮжҷёеҹҶв®Ҷг•¶д“„вЁғдІ’біҺгіҷвҷЁзҘҜв‘ҖзҪҲвҢҠеҲүб…ІжӨӘд№ҠбӣңеЈ…г’‘з©өзҠңиҖҒжіўзҸҡеӯёгҰҹдІ’з—«з—®г—¶еўҡд’ҡжЎ—еҙқвӘҷд№„б—¬вЁ¬гҸ–в“»гә•еҮҮаЁңдўіЫ вҙҰжҒІз…‘ејӮзҮ”а·ҒгҹҘж… вңҶаӘҢг…”жҪһеҷ®д•Ҙе¶ңаіҺз·іе§—д№ҸзЎ®дҰ°дң¬дҝҙжҰҮдӢЎв’іеұҚе©Ӯд©Ӣд‘ҝж“’дІігӢҷзҖҪбҘ„бҙҘв•ігі’жІӢК•ХЈе§өвһӮг•©вӨ–в—»б•Ӣе·’еқЈг°–в®–еЎјдҷҡзјҚгӮ«д®•гҝЈгҘәбҡҡг»Ҹеө·дёҶжҪЁзӘ‘РүЫөзҖҘеҳҲз…ұеЁӘеҝ“д‘ңвЁҙбҺҢб•ҶеҶІвҢ–г•Ҙа°ҒПјд”ҰаЎөжҖҙДҜв®ғаҘҒв§ӢвҮӢб¶¶г©ІеҲ¬е§әз©»еҜ§а№өаЈ¬дўұзұібҶ№е„Ҫвҗ¶б·ҙг®Ңдө‘ж°ёзә“жқөеҚ‘дҪ®бғӣвөҪз§јКјгӢ”ЭҮдҳҪг–ҘбөЎзҳһв—®б»өз”ів©Ңбҡҡб…Ҷгүәзӯҳе©Ҝжҫҗгң‘вўҚОҗж№іеҳүз·ӢжёӘбӘһб°ңдҖ”з”“бЁүдЎ«Уўж№“дұҪаҙҮаҘ»аўҸг§ҒН е„қг—ҹаЁҫжҮ‘гҲһжқӣа«Һг’ҷжәҳеҸ№віҶгҘҫв©ҙзӨҶе’ еЁүб©ңа°”гҷӢаІүМ·в©ҸбһӢЫҘдҶ“зәӢв©«б—ӢжҸүгҝҰвӯ°вҡҜг··гҢҮе•ұгЁҚз«ӢжӘідғәбә…гә¬б–“д“Ҡзү”ж¬”г—өжІҢдӢҰеҰІбЎ·еҲ гІәж¶…а©ҡжү„діҫа¬•е№Қб–Ҳжҗ»жҮӣгҗҸвјңеўңб—’гӢ•зғ¬жҙ©бі»зҡҘејјзҠјеҜје…§вҸҸд¬ўж”ҘгңӢе«ҫжҚіШ—гһјжҘҪа®ҢгәҠвһҲУ®з®¬в»ӘвіҚб©ёа§ЈжҘәвіҳвӯҷгёӯдҪјвһҫгҝҙжҫӣж»©жҹәгјҸеІІеҝһзөҠг§ӨжғҲајӘзҚӯб¬Ӯг ҳж‘ҳв”қбҰ§аұҙгұ—ж¶Җбҡ‘зҙ—бҝғдҘҚб‘Іж»ІеҠәві§вІ·дүІвЈӘе·ҖКӣг–·жң‘а№Қж„ҚбҗҒжҪҮзҪҷвң»гҗ¶еҸҷеҚўж«ӢдҢһжөҖдӯҡбё–бҫӘзЈҡг®»е ҳзӣ’зһҷз¬ҢжҗҚжё«з·ҫаҜ§еҙ·еӣІз®Ізұ·еҢ’в”„зіҢб”Ӣз•үеҝјб—әеұӢз«“з¶јв ҡе¬”аә•з–»еҰ®бӢӘбҖ  \"}]"},"redirectURL":"","headersSize":260,"bodySize":3154,"_status":"completed","_startTimestamp":1775292646994799,"_endTimestamp":1775292647001055},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"340","comment":"","_id":723,"_uid":"a19cd122-1bb8-45cb-925c-5fb8aaaa26c8","_cid":340,"_ctime":1775292640285,"_sid":7,"_stime":1775292646756,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":59694,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:50:46.546Z","time":274,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNi0I2&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"370"}],"queryString":[{"name":"EI