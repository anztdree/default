r 2026 08:52:22 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2165"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=w2Yh8brTQOPYRQmpAAPs; Path=/; HttpOnly"}],"content":{"size":2642,"mimeType":"text/plain","text":"986:4343[{\"ret\":0,\"compress\":true,\"serverTime\":1775292742169,\"server0Time\":25200000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЖ№жүұбҖўбЈЁДҖТҖЧҖФҮд ®ж„јеҖҘдҮ‘вҖібҘІдӘҷж” аұғзҗ„ж”үвҖҰжңёе№ҖжҜҠбЎұа«Ӣв©ід“ҜбҘЎжӯҲдҗӯвҮҡSгЎ№д№ҘКЎг„ұдҚҡб—ўГҢз„ёб’·ФўК®жҶ ГӢв„ҒзӮӘЙ¬вғҸТјдўЁеҖЈеҺ№еі°аЈҖВқгЁёе„»ж°Ҹзҗ®ЪҘаІ•бҮұбҘёзІӮв§өбә№дЎҒг– жҖЎгҷ°зҷ„бҙҮе„«дӯҗе©№ві Д„дӨ“жҠ°вҖӨвҖҗ/еҗҘдҺәЕҒзјәдҒіж§Җб°Һв ҜС”КӘб‘—вҗ§вҺӯгҠіаӨў вҹ®бғҖж•—ФҘз¶ҲгҒҸжҖ§вў‘б°№д—ҶзЁјб’…е’©вғ•аӘ“бі®бҮӮвҰӣОҖд¬җбҗӯд—ҸдҳІгҺ”ФҰвҒ°Вҡг®«З вҒҙжҖЎеӘҲrеҙ зҷғвҖ»д®Ҳuб“ү%е®¬вӮЁж‘Әб’Ј!жјӮЪ ж—үвҒҲдҖҝдҒ…бҒӨOХӮдҜЁвӨҪб…ўдўүзҷ¬гғҜгӢҲб®”бә„дҚұе“әгҶ ж“’бҙҺвҫ°б”ӘвҢ‘г№ӘеӢҙKбҗІдһ¶б•ӘдҡҘб•Ібұәд»ҸвЎҗг”Ӯб№қШғгҳ°бӮұвҰ >СҡеҚ•зӮҷжүҲеҖўвЈ бөҗmжғ гҢ«гәёв« аў”гҢіб®…гӨўдЈҠві¬гҒ—дҷ§дЎҖг§ңжҡҒдҲҪдҳӮе“ӮПўжҠ б•ҝдҖ°а Ҳа©ҷе·ҜзҚқд’қдҷӮДЁгЎ©ЮғзЎ“г”җаҰӯжҳўвҳЎгЎЈді©е ©1дғҝР»гҰёд“јВҘгӢүајЁЪҰгҷғеЎӮДҗвҖЎе—°в ©зҸҝејҝдҮ аіҲбҺҙИ Юөдғ„б¬—дҒӣеҗҗг№ҜдҒЈзё»еҒҰИ•дӨҗГӮд•ЈзЈ”вҝәШЎдўҪдӮ®б ¬СЎбҡ·дҲҺПҝбҢәв»ЈвҢҡд”»жҢҠаұЈа§¶д•ҙдҷӮбҠўд—ҠзҢ§вҺЁжјідқҺб§Ә жҶӮа·ўдЎҗЪӨеқҲаҫІдөІвҸ»е¬ёСӨаә—жіҰвӨҠбәӮб‘қК°жҳҫв»°жӮӮkеҡ…жІҲзҒ¬ж©Ӣзң®д«°зҖҘдҸҮ а°үгӢ©біҜбЎҢд ЁеҶәаҫӮв”°гҹЎж„һВЈpаҪҸе·Ҳвҝ®аҰЁВ«зЎӨаҝ«зӨҙвҝ©вҮ°гЎ¬бҢҒв®ІЖұв©Ҷві‘аәЈеҖәаіҘзҠ¬дӮўгҠӣвӨӨа©ӯг¬ЁгҺ¬зҺ¶жӨҢдә°З•вҷ§вқҘе·ңбңҒзҚӮгһ°гҷөвөҚв„¬ж•Ғз•ўЕ©бҷ ЧұеҘқдҢ”в©ҘгӯҲв„…вҹҲбӣ„ИҰаөҷв·ҖеӢөР жұЁбҠҺд·ғвҝҺеӨӨб—§дғҚб№ҸгЁҢбҸ®з§һвҒ§зҰЎгЎҚЦҹГӨд—ұгҷүзӣӨдҷӘвү«вҘҲжүүгҚ°жІ№гЈҠж·ҷгҪҲв№ӢвҗҚбҳҶг’үг•…бҘҜг–ҪгёҰеЈӯгҠ–е”ҰбұЎМӯв“…зҳқв—„аөӮа ӢаҙівӘӢа¬Ҹг“«д¶Ів—ӮвҙёжӯҲз’ғг«Ҝз–Ғе үж¶ҢаҫҚзұҫвҹ«зҘҗJХҒвұҸаў·вҷҠбҢ‘г…ӢвүҜв—…в—ҺНҢжҚғг Ӣж”ўГүз·ҶвіҲО°з“–ПҷгҗҝОҳбҖјб Ұбҳәз”ЁжҚҠвөҲжҒәбҗғвҹ—жҺӮзҠ‘жҸҡгқҫвөәз–үбҢӨЭЎб”ҙжҸ®еҢ§вәёгҸҮвұүжЈҢз¬үг“—вқЁв”Ҝв®јжүңз¶ӯг·ҶжЎәз¶ҘвҒҹа°ҹгёӨе•Іж Ҫе”Ҫвёҝд®ӘзЁ№в°җжҝҸвӯЈвҒӣвҸҰжӮәжҢҰзҠІб®ҳж“јбҺҶз¶үIа«»е¶ҺгҠҝж·”жӨҸеҚҮвҰ»зұүЧҝгҺ…зҸ№вӢҫзЁҢе°ңжғңЭӮз°үЮідүҝЮӘжҷ»е—‘ж§Ҳв®ұжҘјвҹҪгҘҳаҙәз”№ж®ҷзҚңаҜёжқҳвёҲзәҹбӯҖбң·бҸӯзһҢеһ§гӨҢгҺҮг Үеўӯж№ҺгһјзҘҚзӯ…зҸҡж җдЎҹж®ҹг»¬д®Қб«ҺаҪ‘зҮҲдҸҸз—үдҸ’жёјвўҠжӯқв§«е·іеҶҡбҝҷбӢҸвӢ·жһ—еҷҶвҢҒеғ…жҲҢзҜ¶жіӢе„ҡб¶ҝжӮҲбЁ‘еҙ®гҢ–в°Ҡд«ҳд®қдҜіз’ӣеЎҷгҜҲгӯҹв„җдҫ—зҺ¶гҲҸа»Әж қв«ҰгІұдәҷеҺўзЁӢбҫ•дөЁаҪҫбҳІвҡЁжё°вҺЎгўӨа»ЁбҒҘР‘бӮұаәһвҗҖжҗ°г№•жЈ¬бЎҢз–ҳбҢҘе·–Ы—вё©в‘һгҖәзҳјбӣӮж»ўжҷјдүғе°ҳдЁўгҜ°еҒ”ГҶаёЎб әжҮ°бЎўбұһг“ҖвҰӣг—ҶзЈ”а§ғдҷ¬ж“Ҳж…ЁжҠ…жқўдЈҰв—°бЎізўұаӯҷбҺ·дӮ‘ПӮбҖ©е©үЖ©аЈ©dбҺ’д ӘГ аЁҙжӯІаұҰв’ҚжӮҷЛ г©Је—ёб¶ўдјӨг…ҰвҙЎд“…еһ©г‘ӮбӮҷбіҗбҖ©ФғаәӮеғҳа°•гң§г Іе‘Ңд ©жіІж№ёг¶¶в‘ЁдІӘд¬«аҘұгҝ…е…°дҰҲз«ўбҖҫб·ігәҫвғёдҺӘгЈҠдҖ¶М§еү•д„ вә§зҖЎР°в„¬б„Ұа©ғбҗ¬вҮӨв–§аІ„дҚЁаІўдҖ»а©…жүІдҶ‘еҹ«д©ҸаӨҒаЁ ВӢбӨ…гҳҫж“ҖжҲҰГів„„дҝўж’«дёҶЙ©вӯЁвӨ В‘аҙЎз¶ҷж‘ја§ўжӨҮбҢЎгҪүзҢЎвҶ“зЎҹвӘҚвӯЎзҙҹдәҷД„Х«дҸёжғӮаӘұвҜҳе…¬КігҹӘвөӨвӘҘжҒҫеүЁа№°бЈҗдӘҒвӢ№з…ҝжҗўзүҺдҠ°вҪҘдЎ»в— еҝҙв—·зҗұвҡөг…ҪбңІжҘҢгӢ®вә…ИӯејҗеҫӘбіқз—‘г®·дҶҸбҡӘеөҸз–ҳа®…ж…№д•Іе‘ӘжЈ„д©…в…¶Ч–б’ңдҚӢ М·зӮІаұөе‘ҪзҶҺб©Ўзұ°в–Өеӣ„а ©жҜӨжү©аіәдЁ   \"}]"},"redirectURL":"","headersSize":260,"bodySize":2165,"_status":"completed","_startTimestamp":1775292741169262,"_endTimestamp":1775292741202986},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.88.85.125","connection":"338","comment":"","_id":927,"_uid":"f6f2d859-119c-4627-b5ee-3c726e52fb9a","_cid":338,"_ctime":1775292633694,"_sid":57,"_stime":1775292739442,"_serverAddress":"47.88.85.125","_serverAddressFamily":0,"_serverPort":8001,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":56222,"_app":{"name":"2067","id":"com.guan.wangys51"}},{"startedDateTime":"2026-04-04T08:52:19.130Z","time":270,"request":{"method":"POST","url":"https://s2079-bs.popoh5.com:8001/socket.io/?EIO=3&transport=polling&t=PrNiMui&sid=w2Yh8brTQOPYRQmpAAPs","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s2079-bs.popoh5.com:8001"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent